<UserControl x:Class="MvcVisionSystem.WpfCandidateReviewPanel"
             x:Name="CandidateReviewRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <UserControl.Resources>
        <Style x:Key="CandidateReviewLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="CandidateReviewIconStyle" TargetType="{x:Type iconPacks:PackIconMaterial}">
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="CandidateReviewButtonStyle" TargetType="{x:Type ui:Button}">
            <Setter Property="Background" Value="{DynamicResource ToolbarButtonBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ToolbarButtonBorderBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
                    <Setter Property="Opacity" Value="0.45" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CandidateReviewListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource RowHoverBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SelectedRowBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource SelectedRowTextBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <SolidColorBrush x:Key="CandidateComparisonWarningBrush" Color="#F5C542" />
        <SolidColorBrush x:Key="CandidateComparisonWarningBorderBrush" Color="#806A2A" />

        <Style x:Key="CandidateComparisonPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CanvasBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ViewModel.IsComparisonHighOverlap, ElementName=CandidateReviewRoot}" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource CandidateComparisonWarningBorderBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CandidateComparisonOverlapTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Width" Value="42" />
            <Setter Property="TextAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ViewModel.IsComparisonHighOverlap, ElementName=CandidateReviewRoot}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource CandidateComparisonWarningBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="44" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="&#xC2E0;&#xB8B0;&#xB3C4;"
                       Style="{StaticResource CandidateReviewLabelStyle}" />
            <Slider x:Name="CandidateConfidenceSlider"
                    Grid.Column="1"
                    Minimum="0"
                    Maximum="1"
                    Value="0"
                    TickFrequency="0.05"
                    IsSnapToTickEnabled="True"
                    VerticalAlignment="Center"
                    ValueChanged="CandidateConfidenceSlider_ValueChanged" />
            <TextBlock x:Name="CandidateConfidenceText"
                       Grid.Column="2"
                       Text="{Binding ViewModel.ConfidenceText, ElementName=CandidateReviewRoot}"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       FontFamily="Segoe UI"
                       FontSize="11"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center" />
        </Grid>
        <TextBlock x:Name="CandidateDetailText"
                   Grid.Row="1"
                   Text="{Binding ViewModel.DetailText, ElementName=CandidateReviewRoot}"
                   Foreground="{DynamicResource SecondaryTextBrush}"
                   FontFamily="Segoe UI"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8" />
        <Border x:Name="SelectedCandidateSummaryPanel"
                Grid.Row="2"
                Background="{DynamicResource ToolbarButtonBrush}"
                BorderBrush="{DynamicResource ToolbarButtonBorderBrush}"
                BorderThickness="1"
                CornerRadius="5"
                Padding="8,5"
                Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="&#xC120;&#xD0DD; &#xD6C4;&#xBCF4;"
                           Foreground="{DynamicResource DisabledTextBrush}"
                           FontFamily="Segoe UI"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Margin="0,0,8,0"
                           VerticalAlignment="Center" />
                <TextBlock x:Name="SelectedCandidateSummaryText"
                           Grid.Column="1"
                           Text="{Binding ViewModel.SelectedCandidate.Title, ElementName=CandidateReviewRoot, TargetNullValue=-}"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           FontFamily="Segoe UI"
                           FontSize="12"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>
        <Border x:Name="CandidateComparisonPanel"
                Grid.Row="3"
                Style="{StaticResource CandidateComparisonPanelStyle}"
                Visibility="{Binding ViewModel.ComparisonVisibility, ElementName=CandidateReviewRoot}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="46" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="AI &#xD6C4;&#xBCF4;"
                           Foreground="{DynamicResource DisabledTextBrush}"
                           FontFamily="Segoe UI"
                           FontSize="10"
                           FontWeight="SemiBold" />
                <TextBlock Grid.Column="2"
                           Text="&#xD604;&#xC7AC; &#xB77C;&#xBCA8;"
                           Foreground="{DynamicResource DisabledTextBrush}"
                           FontFamily="Segoe UI"
                           FontSize="10"
                           FontWeight="SemiBold" />
                <TextBlock x:Name="CandidateCompareCandidateText"
                           Grid.Row="1"
                           Text="{Binding ViewModel.ComparisonCandidateText, ElementName=CandidateReviewRoot}"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           TextWrapping="Wrap"
                           Margin="0,4,0,0" />
                <TextBlock x:Name="CandidateCompareCurrentText"
                           Grid.Row="1"
                           Grid.Column="2"
                           Text="{Binding ViewModel.ComparisonCurrentText, ElementName=CandidateReviewRoot}"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           TextWrapping="Wrap"
                           Margin="0,4,0,0" />
                <TextBlock x:Name="CandidateCompareOverlapText"
                           Grid.Row="0"
                           Grid.Column="1"
                           Grid.RowSpan="2"
                           Text="{Binding ViewModel.ComparisonOverlapText, ElementName=CandidateReviewRoot}"
                           Style="{StaticResource CandidateComparisonOverlapTextStyle}" />
                <StackPanel Grid.Row="2"
                            Grid.ColumnSpan="3"
                            Margin="0,8,0,0">
                    <UniformGrid Columns="3">
                        <ui:Button x:Name="PreviousCandidateButton"
                                   Style="{StaticResource CandidateReviewButtonStyle}"
                                   AutomationProperties.Name="&#xC774;&#xC804; &#xD6C4;&#xBCF4;"
                                   ToolTip="&#xC774;&#xC804; AI &#xD6C4;&#xBCF4;&#xB97C; &#xC120;&#xD0DD;&#xD569;&#xB2C8;&#xB2E4;."
                                   IsEnabled="{Binding ViewModel.IsPreviousCandidateEnabled, ElementName=CandidateReviewRoot}"
                                   Click="PreviousCandidateButton_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <iconPacks:PackIconMaterial Style="{StaticResource CandidateReviewIconStyle}" Kind="ChevronUp" />
                                <TextBlock Text="&#xC774;&#xC804;" VerticalAlignment="Center" />
                            </StackPanel>
                        </ui:Button>
                        <ui:Button x:Name="FocusCandidateButton"
                                   Style="{StaticResource CandidateReviewButtonStyle}"
                                   AutomationProperties.Name="&#xD6C4;&#xBCF4; &#xCD08;&#xC810;"
                                   ToolTip="&#xC120;&#xD0DD;&#xD55C; AI &#xD6C4;&#xBCF4;&#xB97C; &#xCE94;&#xBC84;&#xC2A4; &#xAC00;&#xC6B4;&#xB370;&#xB85C; &#xAC00;&#xC838;&#xC635;&#xB2C8;&#xB2E4;."
                                   IsEnabled="{Binding ViewModel.IsFocusCandidateEnabled, ElementName=CandidateReviewRoot}"
                                   Click="FocusCandidateButton_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <iconPacks:PackIconMaterial Style="{StaticResource CandidateReviewIconStyle}" Kind="CrosshairsGps" />
                                <TextBlock Text="&#xCD08;&#xC810;" VerticalAlignment="Center" />
                            </StackPanel>
                        </ui:Button>
                        <ui:Button x:Name="NextCandidateButton"
                                   Style="{StaticResource CandidateReviewButtonStyle}"
                                   AutomationProperties.Name="&#xB2E4;&#xC74C; &#xD6C4;&#xBCF4;"
                                   ToolTip="&#xB2E4;&#xC74C; AI &#xD6C4;&#xBCF4;&#xB97C; &#xC120;&#xD0DD;&#xD569;&#xB2C8;&#xB2E4;."
                                   IsEnabled="{Binding ViewModel.IsNextCandidateEnabled, ElementName=CandidateReviewRoot}"
                                   Click="NextCandidateButton_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <iconPacks:PackIconMaterial Style="{StaticResource CandidateReviewIconStyle}" Kind="ChevronDown" />
                                <TextBlock Text="&#xB2E4;&#xC74C;" VerticalAlignment="Center" />
                            </StackPanel>
                        </ui:Button>
                    </UniformGrid>
                    <UniformGrid Columns="3" Margin="0,5,0,0">
                        <ui:Button x:Name="ConfirmSelectedCandidateButton"
                                   Style="{StaticResource CandidateReviewButtonStyle}"
                                   AutomationProperties.Name="&#xC120;&#xD0DD; &#xD655;&#xC815;"
                                   ToolTip="{Binding ViewModel.ConfirmSelectedToolTip, ElementName=CandidateReviewRoot}"
                                   IsEnabled="{Binding ViewModel.IsConfirmSelectedEnabled, ElementName=CandidateReviewRoot}"
                                   Click="ConfirmSelectedCandidateButton_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <iconPacks:PackIconMaterial Style="{StaticResource CandidateReviewIconStyle}" Kind="CheckboxMarkedCircleOutline" />
                                <TextBlock Text="&#xD655;&#xC815;" VerticalAlignment="Center" />
                            </StackPanel>
                        </ui:Button>
                        <ui:Button x:Name="ConfirmAllCandidatesButton"
                                   Style="{StaticResource CandidateReviewButtonStyle}"
                                   AutomationProperties.Name="&#xC804;&#xCCB4; &#xD655;&#xC815;"
                                   ToolTip="{Binding ViewModel.ConfirmAllToolTip, ElementName=CandidateReviewRoot}"
                                   IsEnabled="{Binding ViewModel.IsConfirmAllEnabled, ElementName=CandidateReviewRoot}"
                                   Click="ConfirmAllCandidatesButton_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <iconPacks:PackIconMaterial Style="{StaticResource CandidateReviewIconStyle}" Kind="CheckAll" />
                                <TextBlock Text="&#xC804;&#xCCB4; &#xD655;&#xC815;" VerticalAlignment="Center" />
                            </StackPanel>
                        </ui:Button>
                        <ui:Button x:Name="SkipSelectedCandidateButton"
                                   Style="{StaticResource CandidateReviewButtonStyle}"
                                   AutomationProperties.Name="&#xC2A4;&#xD0B5;"
                                   ToolTip="{Binding ViewModel.SkipSelectedToolTip, ElementName=CandidateReviewRoot}"
                                   IsEnabled="{Binding ViewModel.IsSkipSelectedEnabled, ElementName=CandidateReviewRoot}"
                                   Click="SkipSelectedCandidateButton_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <iconPacks:PackIconMaterial Style="{StaticResource CandidateReviewIconStyle}" Kind="SkipNext" />
                                <TextBlock Text="&#xC2A4;&#xD0B5;" VerticalAlignment="Center" />
                            </StackPanel>
                        </ui:Button>
                    </UniformGrid>
                    <TextBlock x:Name="CandidatePostActionPolicyText"
                               Text="{Binding ViewModel.PostActionPolicyText, ElementName=CandidateReviewRoot}"
                               Foreground="{DynamicResource DisabledTextBrush}"
                               FontFamily="Segoe UI"
                               FontSize="10"
                               Margin="2,5,0,0"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Grid>
        </Border>
        <Border x:Name="CandidateReviewHistoryPanel"
                 Grid.Row="4"
                Background="{DynamicResource CanvasBrush}"
                BorderBrush="{DynamicResource BorderBrushDark}"
                BorderThickness="1"
                CornerRadius="5"
                Padding="8,6"
                Margin="0,0,0,8"
                Visibility="{Binding ViewModel.ReviewHistoryVisibility, ElementName=CandidateReviewRoot}">
            <StackPanel>
                <TextBlock Text="&#xAC80;&#xD1A0; &#xC774;&#xB825;"
                           Foreground="{DynamicResource DisabledTextBrush}"
                           FontFamily="Segoe UI"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4" />
                <ItemsControl x:Name="CandidateReviewHistoryItems"
                              ItemsSource="{Binding ViewModel.ReviewHistory, ElementName=CandidateReviewRoot}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       FontFamily="Segoe UI"
                                       FontSize="10"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="0,1,0,0" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
        <ListBox x:Name="CandidateListBox"
                 Grid.Row="5"
                 Background="Transparent"
                 BorderThickness="0"
                 Foreground="{DynamicResource SecondaryTextBrush}"
                 ItemsSource="{Binding ViewModel.Candidates, ElementName=CandidateReviewRoot}"
                 SelectedItem="{Binding ViewModel.SelectedCandidate, ElementName=CandidateReviewRoot, Mode=TwoWay}"
                 ItemContainerStyle="{StaticResource CandidateReviewListBoxItemStyle}"
                 ScrollViewer.CanContentScroll="True"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 SelectionChanged="CandidateListBox_SelectionChanged"
                 PreviewKeyDown="CandidateListBox_PreviewKeyDown">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,2,0,4" ToolTip="{Binding ToolTip}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <iconPacks:PackIconMaterial Kind="{Binding IconKind}"
                                                    Width="16"
                                                    Height="16"
                                                    Margin="0,2,8,0"
                                                    Foreground="{Binding StateBrush}"
                                                    VerticalAlignment="Top" />
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{Binding Title}"
                                       FontFamily="Segoe UI"
                                       FontSize="12"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding SecondaryText}"
                                       FontFamily="Segoe UI"
                                       FontSize="11"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
