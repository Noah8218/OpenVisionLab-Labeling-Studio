<UserControl x:Class="MvcVisionSystem.WpfCanvasPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:canvas="clr-namespace:OpenVisionLab.ImageCanvas.Views;assembly=OpenVisionLab.ImageCanvas"
             xmlns:mvvm="clr-namespace:OpenVisionLab.Mvvm.Behaviors;assembly=OpenVisionLab.Mvvm"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <UserControl.Resources>
        <Style x:Key="CanvasCommandButtonStyle" TargetType="{x:Type ui:Button}">
            <Setter Property="Height" Value="26" />
            <Setter Property="MinWidth" Value="38" />
            <Setter Property="Padding" Value="7,0" />
            <Setter Property="Margin" Value="3,0,0,0" />
            <Setter Property="Appearance" Value="Transparent" />
            <Setter Property="Background" Value="{DynamicResource ToolbarButtonBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ToolbarButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ToolbarButtonHoverBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}" />
                    <Setter Property="Opacity" Value="0.45" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CanvasCommandIconStyle" TargetType="{x:Type iconPacks:PackIconMaterial}">
            <Setter Property="Width" Value="13" />
            <Setter Property="Height" Value="13" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <SolidColorBrush x:Key="DetectionOverlayConfirmableBackgroundBrush" Color="#33031D12" />
        <SolidColorBrush x:Key="DetectionOverlayConfirmableBorderBrush" Color="#5524D366" />
        <SolidColorBrush x:Key="DetectionOverlayConfirmableAccentBrush" Color="#24D366" />
        <SolidColorBrush x:Key="DetectionOverlayConfirmableChipBrush" Color="#1F24D366" />
        <SolidColorBrush x:Key="DetectionOverlayDuplicateBackgroundBrush" Color="#331E1705" />
        <SolidColorBrush x:Key="DetectionOverlayDuplicateBorderBrush" Color="#806A2A" />
        <SolidColorBrush x:Key="DetectionOverlayDuplicateAccentBrush" Color="#F5C542" />
        <SolidColorBrush x:Key="DetectionOverlayDuplicateChipBrush" Color="#33F5C542" />
        <SolidColorBrush x:Key="DetectionOverlayReviewBackgroundBrush" Color="#331E1302" />
        <SolidColorBrush x:Key="DetectionOverlayReviewBorderBrush" Color="#805A3B0A" />
        <SolidColorBrush x:Key="DetectionOverlayReviewAccentBrush" Color="#F59E0B" />
        <SolidColorBrush x:Key="DetectionOverlayReviewChipBrush" Color="#33F59E0B" />

        <Style x:Key="DetectionOverlayPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource DetectionOverlayBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DetectionOverlayBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="10,8" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding DetectionOverlayStatusKey}" Value="Confirmable">
                    <Setter Property="Background" Value="{StaticResource DetectionOverlayConfirmableBackgroundBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource DetectionOverlayConfirmableBorderBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding DetectionOverlayStatusKey}" Value="Duplicate">
                    <Setter Property="Background" Value="{StaticResource DetectionOverlayDuplicateBackgroundBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource DetectionOverlayDuplicateBorderBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding DetectionOverlayStatusKey}" Value="Review">
                    <Setter Property="Background" Value="{StaticResource DetectionOverlayReviewBackgroundBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource DetectionOverlayReviewBorderBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DetectionOverlaySummaryTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource DetectionOverlaySummaryTextBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding DetectionOverlayStatusKey}" Value="Confirmable">
                    <Setter Property="Foreground" Value="{StaticResource DetectionOverlayConfirmableAccentBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding DetectionOverlayStatusKey}" Value="Duplicate">
                    <Setter Property="Foreground" Value="{StaticResource DetectionOverlayDuplicateAccentBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding DetectionOverlayStatusKey}" Value="Review">
                    <Setter Property="Foreground" Value="{StaticResource DetectionOverlayReviewAccentBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DetectionOverlayActionButtonStyle" TargetType="{x:Type ui:Button}" BasedOn="{StaticResource CanvasCommandButtonStyle}">
            <Setter Property="Height" Value="22" />
            <Setter Property="MinWidth" Value="44" />
            <Setter Property="Margin" Value="0,0,3,0" />
            <Setter Property="Padding" Value="4,0" />
        </Style>



        <Style x:Key="CanvasAnnotationCommandButtonStyle" TargetType="{x:Type ui:Button}" BasedOn="{StaticResource CanvasCommandButtonStyle}">
            <Setter Property="Width" Value="30" />
            <Setter Property="MinWidth" Value="30" />
            <Setter Property="Height" Value="27" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="4,0,0,0" />
        </Style>
        <Style x:Key="CanvasAnnotationSaveButtonStyle" TargetType="{x:Type ui:Button}" BasedOn="{StaticResource CanvasCommandButtonStyle}">
            <Setter Property="Height" Value="27" />
            <Setter Property="MinWidth" Value="88" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Margin" Value="8,0,4,0" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="True">
                    <Setter Property="Background" Value="#DC2626" />
                    <Setter Property="BorderBrush" Value="#EF4444" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EF4444" />
                    <Setter Property="BorderBrush" Value="#F87171" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource ToolbarButtonBorderBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}" />
                    <Setter Property="Opacity" Value="0.62" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CanvasAnnotationToolListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>

        <Style x:Key="CanvasAnnotationToolItemStyle" TargetType="ListBoxItem">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource ToolbarButtonBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ToolbarButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="IsEnabled" Value="{Binding IsActionEnabled}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource ToolbarButtonHoverBrush}" />
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ItemChrome" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="CanvasAnnotationToolItemTemplate">
            <Grid Width="36"
                  Height="36"
                  mvvm:EventCommandBehavior.EventName="MouseLeftButtonUp"
                  mvvm:EventCommandBehavior.Command="{Binding DataContext.AnnotationToolSelectionChangedCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                  mvvm:EventCommandBehavior.CommandParameter="{Binding}"
                  AutomationProperties.Name="{Binding Text}"
                  AutomationProperties.HelpText="{Binding ToolTip}"
                  ToolTip="{Binding ToolTip}">
                <iconPacks:PackIconMaterial x:Name="ToolIcon"
                                            Kind="{Binding IconKind}"
                                            Width="18"
                                            Height="18"
                                            Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center" />
                <Ellipse x:Name="PendingBadge"
                         Width="5"
                         Height="5"
                         Margin="0,4,4,0"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Top"
                         Fill="#F5C542"
                         Visibility="Collapsed" />
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsConnected}" Value="False">
                    <Setter TargetName="ToolIcon" Property="Opacity" Value="0.62" />
                    <Setter TargetName="PendingBadge" Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsActionEnabled}" Value="False">
                    <Setter TargetName="ToolIcon" Property="Opacity" Value="0.55" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <Style x:Key="CanvasLabelClassListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="MaxWidth" Value="240" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="CanvasLabelClassItemStyle" TargetType="ListBoxItem">
            <Setter Property="MinWidth" Value="58" />
            <Setter Property="Height" Value="27" />
            <Setter Property="Padding" Value="7,0" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ToolbarButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource ToolbarButtonHoverBrush}" />
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="CanvasLabelClassItemTemplate">
            <StackPanel Orientation="Horizontal"
                        ToolTip="{Binding ToolTip}">
                <Border Width="10"
                        Height="10"
                        CornerRadius="2"
                        Background="{Binding DrawBrush}"
                        Margin="0,0,5,0"
                        VerticalAlignment="Center" />
                <TextBlock x:Name="CanvasLabelClassNameText"
                           Text="{Binding DisplayText}"
                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           FontWeight="SemiBold"
                           MaxWidth="82"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" />
            </StackPanel>
        </DataTemplate>

        <Style x:Key="CanvasDisplayModeListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="CanvasDisplayModeItemStyle" TargetType="ListBoxItem">
            <Setter Property="MinWidth" Value="42" />
            <Setter Property="Height" Value="27" />
            <Setter Property="Padding" Value="7,0" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ToolbarButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource ToolbarButtonHoverBrush}" />
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="CanvasDisplayModeItemTemplate">
            <TextBlock Text="{Binding DisplayText}"
                       ToolTip="{Binding ToolTip}"
                       Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"
                       FontFamily="Segoe UI"
                       FontSize="11"
                       FontWeight="SemiBold"
                       TextAlignment="Center"
                       VerticalAlignment="Center" />
        </DataTemplate>
        <Style x:Key="DetectionOverlaySelectedBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource DetectionOverlaySelectedBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DetectionOverlayBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="7,5" />
            <Setter Property="Margin" Value="0,7,0,0" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding DetectionOverlayStatusKey}" Value="Confirmable">
                    <Setter Property="Background" Value="{StaticResource DetectionOverlayConfirmableChipBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource DetectionOverlayConfirmableAccentBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding DetectionOverlayStatusKey}" Value="Duplicate">
                    <Setter Property="Background" Value="{StaticResource DetectionOverlayDuplicateChipBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource DetectionOverlayDuplicateAccentBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding DetectionOverlayStatusKey}" Value="Review">
                    <Setter Property="Background" Value="{StaticResource DetectionOverlayReviewChipBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource DetectionOverlayReviewAccentBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Background="{DynamicResource CanvasBrush}"
            BorderBrush="{DynamicResource BorderBrushDark}"
            BorderThickness="1"
            CornerRadius="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border Background="{DynamicResource PanelHeaderBrush}"
                    CornerRadius="6,6,0,0"
                    BorderBrush="{DynamicResource BorderBrushDark}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <TextBlock Text="캔버스"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               FontFamily="Segoe UI"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="12,0"
                               VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,8,0">
                        <ui:Button x:Name="FitCanvasButton"
                                   Style="{StaticResource CanvasCommandButtonStyle}"
                                   ToolTip="이미지를 캔버스에 맞춥니다."
                                   IsEnabled="{Binding IsFitEnabled}"
                                   Command="{Binding FitCommand}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="FitToPageOutline" Style="{StaticResource CanvasCommandIconStyle}" />
                                <TextBlock Text="맞춤" VerticalAlignment="Center" />
                            </StackPanel>
                        </ui:Button>
                        <ui:Button x:Name="ActualSizeCanvasButton"
                                   Style="{StaticResource CanvasCommandButtonStyle}"
                                   ToolTip="이미지를 1:1 픽셀 크기로 표시합니다."
                                   IsEnabled="{Binding IsActualSizeEnabled}"
                                   Command="{Binding ActualSizeCommand}">
                            <TextBlock Text="1:1" VerticalAlignment="Center" />
                        </ui:Button>
                        <ui:Button x:Name="PanCanvasButton"
                                   Style="{StaticResource CanvasCommandButtonStyle}"
                                   ToolTip="이미지 이동 모드로 전환합니다."
                                   IsEnabled="{Binding IsPanEnabled}"
                                   Command="{Binding PanCommand}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="CursorMove" Style="{StaticResource CanvasCommandIconStyle}" />
                                <TextBlock Text="이동" VerticalAlignment="Center" />
                            </StackPanel>
                        </ui:Button>
                        <ui:Button x:Name="FocusCandidateCanvasButton"
                                   Style="{StaticResource CanvasCommandButtonStyle}"
                                   ToolTip="선택한 AI 후보 위치로 이동합니다."
                                   IsEnabled="{Binding IsFocusCandidateEnabled}"
                                   Command="{Binding FocusCandidateCommand}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="CrosshairsGps" Style="{StaticResource CanvasCommandIconStyle}" />
                                <TextBlock Text="후보" VerticalAlignment="Center" />
                            </StackPanel>
                        </ui:Button>
                        <ui:Button x:Name="ResetAiOverlayCanvasButton"
                                   Style="{StaticResource CanvasCommandButtonStyle}"
                                   ToolTip="수동 라벨은 유지하고 AI 후보 표시만 지웁니다."
                                   IsEnabled="{Binding IsResetAiOverlayEnabled}"
                                   Command="{Binding ResetAiOverlayCommand}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="LayersOffOutline" Style="{StaticResource CanvasCommandIconStyle}" />
                                <TextBlock Text="후보 지움" VerticalAlignment="Center" />
                            </StackPanel>
                        </ui:Button>
                    </StackPanel>
                </Grid>
            </Border>
            <Border x:Name="CanvasWorkflowContextStrip"
                    Grid.Row="1"
                    Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource BorderBrushDark}"
                    BorderThickness="0,0,0,1"
                    Padding="8,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border x:Name="CanvasWorkflowStepChip"
                            Background="{DynamicResource AccentBrush}"
                            CornerRadius="4"
                            Padding="7,3"
                            Margin="0,0,7,0"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="TimelineCheckOutline"
                                                        Width="13"
                                                        Height="13"
                                                        Margin="0,0,4,0"
                                                        Foreground="White"
                                                        VerticalAlignment="Center" />
                            <TextBlock x:Name="CanvasCurrentStepText"
                                       Text="{Binding CurrentWorkflowStepText}"
                                       Foreground="White"
                                       FontFamily="Segoe UI"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1"
                            Background="{DynamicResource ToolbarButtonBrush}"
                            BorderBrush="{DynamicResource ToolbarButtonBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="7,3"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="도구"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       FontFamily="Segoe UI"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Margin="0,0,5,0"
                                       VerticalAlignment="Center" />
                            <TextBlock x:Name="CanvasCurrentToolText"
                                       Text="{Binding CurrentWorkflowToolText}"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       FontFamily="Segoe UI"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       MaxWidth="96"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2"
                            Background="{DynamicResource CanvasBrush}"
                            BorderBrush="{DynamicResource ToolbarButtonBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="7,3"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            ToolTip="{Binding FirstLabelLoopText}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="ArrowDecisionAutoOutline"
                                                        Width="13"
                                                        Height="13"
                                                        Margin="0,0,5,0"
                                                        Foreground="{DynamicResource SecondaryTextBrush}"
                                                        VerticalAlignment="Center" />
                            <TextBlock x:Name="CanvasFirstLabelLoopText"
                                       Text="{Binding FirstLabelLoopText}"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       FontFamily="Segoe UI"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       MaxWidth="260"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <DockPanel Grid.Column="3"
                               LastChildFill="True"
                               VerticalAlignment="Center"
                               ToolTip="{Binding CurrentWorkflowActionText}">
                        <TextBlock Text="다음"
                                   DockPanel.Dock="Left"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Margin="0,0,6,0"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="CanvasNextActionText"
                                   Text="{Binding CurrentWorkflowActionText}"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />
                    </DockPanel>
                </Grid>
            </Border>
            <Border x:Name="CanvasLayerVisibilityStrip"
                    Grid.Row="2"
                    Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource BorderBrushDark}"
                    BorderThickness="0,0,0,1"
                    Padding="8,3"
                    ToolTip="{Binding CanvasLayerModeToolTip}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Background="{DynamicResource ToolbarButtonBrush}"
                            BorderBrush="{DynamicResource AccentBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="7,3"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center">
                        <TextBlock x:Name="CanvasLayerModeTitleText"
                                   Text="{Binding CanvasLayerModeTitleText}"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </Border>
                    <TextBlock x:Name="CanvasLayerModeDetailText"
                               Grid.Column="1"
                               Text="{Binding CanvasLayerModeDetailText}"
                               Visibility="Collapsed"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontFamily="Segoe UI"
                               FontSize="10.5"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" />
                    <Border x:Name="CanvasLabelLayerChip"
                            Grid.Column="2"
                            Background="{DynamicResource CanvasBrush}"
                            BorderBrush="{DynamicResource ToolbarButtonBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="7,3"
                            Margin="8,0,0,0"
                            VerticalAlignment="Center">
                        <TextBlock x:Name="CanvasLabelLayerText"
                                   Text="{Binding CanvasLabelLayerText}"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </Border>
                    <Border x:Name="CanvasInferenceLayerChip"
                            Grid.Column="3"
                            Background="{DynamicResource CanvasBrush}"
                            BorderBrush="{DynamicResource ToolbarButtonBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="7,3"
                            Margin="4,0,0,0"
                            VerticalAlignment="Center">
                        <TextBlock x:Name="CanvasInferenceLayerText"
                                   Text="{Binding CanvasInferenceLayerText}"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </Border>
                </Grid>
            </Border>
            <Border x:Name="CanvasAnnotationToolBar"
                    Grid.Row="3"
                    MinHeight="37"
                    Background="{DynamicResource FrameBrush}"
                    BorderBrush="{DynamicResource BorderBrushDark}"
                    BorderThickness="0,0,0,1"
                    Padding="8,3">
                <WrapPanel x:Name="CanvasAnnotationToolBarItems"
                           Orientation="Horizontal"
                           VerticalAlignment="Center">
                    <TextBlock Text="빠른 도구"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontFamily="Segoe UI"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               Visibility="Collapsed" />
                        <Border x:Name="CanvasBrushSizeControl"
                                Visibility="{Binding MaskBrushControlVisibility}"
                                Background="{DynamicResource CanvasBrush}"
                                BorderBrush="{DynamicResource ToolbarButtonBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="4,0"
                                Margin="2,0,6,0"
                                Height="27"
                                VerticalAlignment="Center"
                                ToolTip="&#xBE0C;&#xB7EC;&#xC2DC;/&#xC9C0;&#xC6B0;&#xAC1C; &#xD06C;&#xAE30;">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#xBE0C;&#xB7EC;&#xC2DC;"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           FontFamily="Segoe UI"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Margin="0,0,5,0"
                                           VerticalAlignment="Center" />
                                <ui:Button x:Name="CanvasDecreaseBrushSizeButton"
                                           Style="{StaticResource CanvasAnnotationCommandButtonStyle}"
                                           Width="24"
                                           MinWidth="24"
                                           Margin="0"
                                           ToolTip="&#xBE0C;&#xB7EC;&#xC2DC; &#xD06C;&#xAE30; &#xC904;&#xC774;&#xAE30;"
                                           Command="{Binding DecreaseBrushSizeCommand}">
                                    <iconPacks:PackIconMaterial Kind="Minus" Width="13" Height="13" />
                                </ui:Button>
                                <TextBlock x:Name="CanvasBrushSizeText"
                                           Text="{Binding BrushSizeText}"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           FontFamily="Segoe UI"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Width="38"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center" />
                                <ui:Button x:Name="CanvasIncreaseBrushSizeButton"
                                           Style="{StaticResource CanvasAnnotationCommandButtonStyle}"
                                           Width="24"
                                           MinWidth="24"
                                           Margin="0"
                                           ToolTip="&#xBE0C;&#xB7EC;&#xC2DC; &#xD06C;&#xAE30; &#xB298;&#xB9AC;&#xAE30;"
                                           Command="{Binding IncreaseBrushSizeCommand}">
                                    <iconPacks:PackIconMaterial Kind="Plus" Width="13" Height="13" />
                                </ui:Button>
                            </StackPanel>
                        </Border>
                        <TextBlock Text="&#xBAA8;&#xB4DC;"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Margin="0,0,5,0"
                                   VerticalAlignment="Center" />
                        <ListBox x:Name="CanvasDisplayModeListBox"
                                 Style="{StaticResource CanvasDisplayModeListBoxStyle}"
                                 ItemContainerStyle="{StaticResource CanvasDisplayModeItemStyle}"
                                 ItemTemplate="{StaticResource CanvasDisplayModeItemTemplate}"
                                 ItemsSource="{Binding DisplayModes}"
                                 SelectedItem="{Binding SelectedDisplayMode, Mode=TwoWay}"
                                 ToolTip="{Binding CanvasLayerModeToolTip}"
                                 mvvm:InputCommandBehaviors.SelectedItemChangedCommand="{Binding DisplayModeSelectionChangedCommand}">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                        </ListBox>
                        <ui:Button x:Name="CanvasSaveAnnotationButton"
                                   Style="{StaticResource CanvasAnnotationSaveButtonStyle}"
                                   ToolTip="{Binding AnnotationSaveToolTip}"
                                   IsEnabled="{Binding IsAnnotationSaveEnabled}"
                                   Command="{Binding SaveAnnotationCommand}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="ContentSaveOutline"
                                                            Width="13"
                                                            Height="13"
                                                            Margin="0,0,5,0"
                                                            VerticalAlignment="Center" />
                                <TextBlock x:Name="CanvasSaveAnnotationText"
                                           Text="{Binding AnnotationSaveActionText}"
                                           FontFamily="Segoe UI"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </ui:Button>
                        <ui:Button x:Name="CanvasCompleteNoObjectButton"
                                   Style="{StaticResource CanvasAnnotationSaveButtonStyle}"
                                   MinWidth="92"
                                   ToolTip="{Binding NoObjectCompletionToolTip}"
                                   AutomationProperties.AutomationId="CanvasCompleteNoObjectButton"
                                   AutomationProperties.Name="{Binding NoObjectCompletionActionText}"
                                   IsEnabled="{Binding IsNoObjectCompletionEnabled}"
                                   Command="{Binding CompleteNoObjectCommand}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="MinusCircleOutline"
                                                            Width="13"
                                                            Height="13"
                                                            Margin="0,0,5,0"
                                                            VerticalAlignment="Center" />
                                <TextBlock x:Name="CanvasCompleteNoObjectText"
                                           Text="{Binding NoObjectCompletionActionText}"
                                           FontFamily="Segoe UI"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </ui:Button>
                        <Border x:Name="CanvasAnnotationSaveStateCard"
                                Background="{DynamicResource CanvasBrush}"
                                BorderBrush="{DynamicResource ToolbarButtonBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="7,3"
                                Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                ToolTip="{Binding AnnotationSaveToolTip}">
                            <StackPanel>
                                <TextBlock x:Name="CanvasAnnotationSaveStatusTitleText"
                                           Text="{Binding AnnotationSaveStatusTitleText}"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           FontFamily="Segoe UI"
                                           FontSize="10.5"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock x:Name="CanvasAnnotationSaveStatusDetailText"
                                           Text="{Binding AnnotationSaveStatusDetailText}"
                                           Visibility="Collapsed"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           FontFamily="Segoe UI"
                                           FontSize="9.5"
                                           MaxWidth="230"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Border>
                        <StackPanel Orientation="Horizontal"
                                    Margin="6,0,0,0"
                                    VerticalAlignment="Center">
                            <TextBlock x:Name="CanvasLabelClassSelectorLabel"
                                       Text="&#xD074;&#xB798;&#xC2A4;"
                                       ToolTip="새 박스에 적용할 클래스입니다. 현재 이미지에 저장된 라벨 목록이 아닙니다."
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       FontFamily="Segoe UI"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Margin="0,0,5,0"
                                       VerticalAlignment="Center" />
                            <ListBox x:Name="CanvasLabelClassListBox"
                                     Style="{StaticResource CanvasLabelClassListBoxStyle}"
                                     ItemContainerStyle="{StaticResource CanvasLabelClassItemStyle}"
                                     ItemTemplate="{StaticResource CanvasLabelClassItemTemplate}"
                                     ItemsSource="{Binding LabelClasses}"
                                     SelectedItem="{Binding SelectedLabelClass, Mode=TwoWay}"
                                     mvvm:InputCommandBehaviors.SelectedItemChangedCommand="{Binding LabelClassSelectionChangedCommand}">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                            </ListBox>
                            <ui:Button x:Name="CanvasOpenClassCatalogButton"
                                       Style="{StaticResource CanvasAnnotationCommandButtonStyle}"
                                       AutomationProperties.AutomationId="CanvasOpenClassCatalogButton"
                                       AutomationProperties.Name="&#xD074;&#xB798;&#xC2A4; &#xAD00;&#xB9AC;"
                                       ToolTip="{Binding ActiveLabelClassActionToolTip}"
                                       Command="{Binding OpenClassCatalogCommand}">
                                <Grid>
                                    <iconPacks:PackIconMaterial Kind="TagMultipleOutline"
                                                                Width="14"
                                                                Height="14"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center" />
                                    <TextBlock x:Name="CanvasActiveLabelClassActionText"
                                               Text="{Binding ActiveLabelClassActionText}"
                                               Visibility="Collapsed" />
                                </Grid>
                            </ui:Button>
                        </StackPanel>
                        <Border x:Name="CanvasActiveLabelClassCard"
                                Background="{DynamicResource CanvasBrush}"
                                BorderBrush="{DynamicResource ToolbarButtonBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="7,3"
                                Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                Visibility="Collapsed"
                                ToolTip="{Binding ActiveLabelClassDetailText}">
                            <StackPanel>
                                    <TextBlock x:Name="CanvasActiveLabelClassTitleText"
                                               Text="{Binding ActiveLabelClassTitleText}"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               FontFamily="Segoe UI"
                                               FontSize="10.5"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock x:Name="CanvasActiveLabelClassDetailText"
                                               Text="{Binding ActiveLabelClassDetailText}"
                                               Visibility="Collapsed"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               FontFamily="Segoe UI"
                                               FontSize="9.5"
                                               MaxWidth="250"
                                               TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Border>
                        <Border x:Name="CanvasSelectedToolChip"
                                Background="{DynamicResource PanelBrush}"
                                BorderBrush="{DynamicResource ToolbarButtonBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="7,3"
                                Margin="8,0,4,0"
                                VerticalAlignment="Center"
                                Visibility="Collapsed"
                                ToolTip="{Binding SelectedAnnotationTool.ToolTip}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="선택"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           FontFamily="Segoe UI"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Margin="0,0,5,0"
                                           VerticalAlignment="Center" />
                                <TextBlock x:Name="CanvasSelectedToolText"
                                           Text="{Binding SelectedAnnotationTool.Text}"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           FontFamily="Segoe UI"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           MaxWidth="80"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                </WrapPanel>
            </Border>
            <Border x:Name="DetectionResultOverlay"
                    Grid.Row="4"
                    Margin="10,8,10,8"
                        MaxWidth="560"
                        MaxHeight="92"
                        ClipToBounds="True"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Style="{StaticResource DetectionOverlayPanelStyle}"
                        ToolTip="{Binding DetectionOverlayDetailText}"
                    Visibility="{Binding DetectionOverlayVisibility}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="DetectionOverlayTitleText"
                                   Text="검출 결과"
                                   Foreground="{DynamicResource DetectionOverlayTitleTextBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="DetectionOverlaySummaryText"
                                   Grid.Column="1"
                                   Text="{Binding DetectionOverlaySummaryText}"
                                   Style="{StaticResource DetectionOverlaySummaryTextStyle}"
                                   FontFamily="Segoe UI"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Margin="8,0,0,0"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />
                        <Border x:Name="DetectionOverlaySelectedBorder"
                                Grid.Row="1"
                                Grid.ColumnSpan="2"
                                Margin="0,5,0,0"
                                Padding="6,4"
                                Style="{StaticResource DetectionOverlaySelectedBorderStyle}">
                            <DockPanel LastChildFill="True">
                                <WrapPanel x:Name="DetectionOverlayActionPanel"
                                           DockPanel.Dock="Right"
                                           Margin="8,0,0,0"
                                           Visibility="{Binding DetectionOverlayActionsVisibility}">
                            <ui:Button x:Name="CanvasOverlayPreviousCandidateButton"
                                       Style="{StaticResource DetectionOverlayActionButtonStyle}"
                                       AutomationProperties.AutomationId="CanvasOverlayPreviousCandidateButton"
                                       AutomationProperties.Name="&#xC774;&#xC804; &#xD6C4;&#xBCF4;"
                                       ToolTip="이전 AI 후보를 선택합니다."
                                       IsEnabled="{Binding IsPreviousCandidateEnabled}"
                                       Command="{Binding PreviousCandidateCommand}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <iconPacks:PackIconMaterial Kind="ChevronUp" Style="{StaticResource CanvasCommandIconStyle}" />
                                    <TextBlock Text="&#xC774;&#xC804;" VerticalAlignment="Center" />
                                </StackPanel>
                            </ui:Button>
                            <ui:Button x:Name="CanvasOverlayFocusCandidateButton"
                                       Style="{StaticResource DetectionOverlayActionButtonStyle}"
                                       AutomationProperties.AutomationId="CanvasOverlayFocusCandidateButton"
                                       AutomationProperties.Name="&#xD6C4;&#xBCF4; &#xCD08;&#xC810;"
                                       ToolTip="선택한 AI 후보를 캔버스 가운데로 가져옵니다."
                                       IsEnabled="{Binding IsFocusCandidateEnabled}"
                                       Command="{Binding FocusCandidateCommand}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <iconPacks:PackIconMaterial Kind="CrosshairsGps" Style="{StaticResource CanvasCommandIconStyle}" />
                                    <TextBlock Text="&#xD6C4;&#xBCF4;" VerticalAlignment="Center" />
                                </StackPanel>
                            </ui:Button>
                            <ui:Button x:Name="CanvasOverlayFocusCurrentLabelButton"
                                       Style="{StaticResource DetectionOverlayActionButtonStyle}"
                                       AutomationProperties.AutomationId="CanvasOverlayFocusCurrentLabelButton"
                                       AutomationProperties.Name="&#xAE30;&#xC900; &#xB77C;&#xBCA8; &#xC120;&#xD0DD;"
                                       ToolTip="&#xACB9;&#xCE58;&#xB294; &#xAE30;&#xC874; &#xB77C;&#xBCA8;&#xC744; &#xC120;&#xD0DD;&#xD569;&#xB2C8;&#xB2E4;."
                                       IsEnabled="{Binding IsFocusCurrentLabelEnabled}"
                                       Command="{Binding FocusCurrentLabelCommand}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <iconPacks:PackIconMaterial Kind="CrosshairsGps" Style="{StaticResource CanvasCommandIconStyle}" />
                                    <TextBlock Text="&#xAE30;&#xC900;" VerticalAlignment="Center" />
                                </StackPanel>
                            </ui:Button>
                            <ui:Button x:Name="CanvasOverlayNextCandidateButton"
                                       Style="{StaticResource DetectionOverlayActionButtonStyle}"
                                       AutomationProperties.AutomationId="CanvasOverlayNextCandidateButton"
                                       AutomationProperties.Name="&#xB2E4;&#xC74C; &#xD6C4;&#xBCF4;"
                                       ToolTip="다음 AI 후보를 선택합니다."
                                       IsEnabled="{Binding IsNextCandidateEnabled}"
                                       Command="{Binding NextCandidateCommand}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <iconPacks:PackIconMaterial Kind="ChevronDown" Style="{StaticResource CanvasCommandIconStyle}" />
                                    <TextBlock Text="&#xB2E4;&#xC74C;" VerticalAlignment="Center" />
                                </StackPanel>
                            </ui:Button>
                            <ui:Button x:Name="CanvasOverlayConfirmSelectedCandidateButton"
                                       Style="{StaticResource DetectionOverlayActionButtonStyle}"
                                       AutomationProperties.AutomationId="CanvasOverlayConfirmSelectedCandidateButton"
                                       AutomationProperties.Name="&#xC120;&#xD0DD; &#xD655;&#xC815;"
                                       ToolTip="선택한 AI 후보를 라벨로 확정합니다."
                                       IsEnabled="{Binding IsConfirmSelectedEnabled}"
                                       Command="{Binding ConfirmSelectedCommand}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <iconPacks:PackIconMaterial Kind="CheckboxMarkedCircleOutline" Style="{StaticResource CanvasCommandIconStyle}" />
                                    <TextBlock Text="&#xD655;&#xC815;" VerticalAlignment="Center" />
                                </StackPanel>
                            </ui:Button>
                            <ui:Button x:Name="CanvasOverlaySkipSelectedCandidateButton"
                                       Style="{StaticResource DetectionOverlayActionButtonStyle}"
                                       AutomationProperties.AutomationId="CanvasOverlaySkipSelectedCandidateButton"
                                       AutomationProperties.Name="&#xC2A4;&#xD0B5;"
                                       ToolTip="선택한 AI 후보를 스킵합니다."
                                       IsEnabled="{Binding IsSkipSelectedEnabled}"
                                       Command="{Binding SkipSelectedCommand}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <iconPacks:PackIconMaterial Kind="SkipNext" Style="{StaticResource CanvasCommandIconStyle}" />
                                    <TextBlock Text="&#xC2A4;&#xD0B5;" VerticalAlignment="Center" />
                                </StackPanel>
                            </ui:Button>
                                </WrapPanel>
                                <TextBlock x:Name="DetectionOverlaySelectedText"
                                           Text="{Binding DetectionOverlaySelectedText}"
                                           Foreground="{DynamicResource DetectionOverlaySelectedTextBrush}"
                                           FontFamily="Segoe UI"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           MaxWidth="220"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center" />
                            </DockPanel>
                        </Border>
                        <TextBlock x:Name="DetectionOverlayDetailText"
                                   Grid.Row="1"
                                   Text="{Binding DetectionOverlayDetailText}"
                                   Foreground="{DynamicResource DetectionOverlayDetailTextBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="10"
                                   Visibility="Collapsed" />
                    </Grid>
                </Border>
            <Grid Grid.Row="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="46" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border x:Name="CanvasAnnotationToolRail"
                        Grid.Column="0"
                        Background="{DynamicResource FrameBrush}"
                        BorderBrush="{DynamicResource BorderBrushDark}"
                        BorderThickness="0,0,1,0"
                        Padding="4,6"
                        AutomationProperties.Name="&#xB77C;&#xBCA8;&#xB9C1; &#xB3C4;&#xAD6C;">
                    <StackPanel>
                        <ListBox x:Name="CanvasAnnotationToolListBox"
                                 Style="{StaticResource CanvasAnnotationToolListBoxStyle}"
                                 ItemContainerStyle="{StaticResource CanvasAnnotationToolItemStyle}"
                                 ItemTemplate="{StaticResource CanvasAnnotationToolItemTemplate}"
                                 ItemsSource="{Binding AnnotationTools}"
                                 SelectedItem="{Binding SelectedAnnotationTool, Mode=TwoWay}"
                                 mvvm:InputCommandBehaviors.SelectedItemChangedCommand="{Binding AnnotationToolSelectionChangedCommand}">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Vertical" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                        </ListBox>
                        <Border Height="1"
                                Background="{DynamicResource ToolbarButtonBorderBrush}"
                                Margin="3,2,3,6" />
                        <ui:Button x:Name="CanvasUndoAnnotationButton"
                                   Style="{StaticResource CanvasAnnotationCommandButtonStyle}"
                                   Width="38"
                                   Height="34"
                                   Margin="0,0,0,4"
                                   AutomationProperties.Name="&#xB418;&#xB3CC;&#xB9AC;&#xAE30;"
                                   ToolTip="{Binding UndoAnnotationTool.ToolTip}"
                                   IsEnabled="{Binding UndoAnnotationTool.IsActionEnabled}"
                                   Command="{Binding UndoAnnotationCommand}">
                            <iconPacks:PackIconMaterial Kind="Refresh" Width="15" Height="15" />
                        </ui:Button>
                        <ui:Button x:Name="CanvasRedoAnnotationButton"
                                   Style="{StaticResource CanvasAnnotationCommandButtonStyle}"
                                   Width="38"
                                   Height="34"
                                   Margin="0,0,0,4"
                                   AutomationProperties.Name="&#xB2E4;&#xC2DC; &#xC801;&#xC6A9;"
                                   ToolTip="{Binding RedoAnnotationTool.ToolTip}"
                                   IsEnabled="{Binding RedoAnnotationTool.IsActionEnabled}"
                                   Command="{Binding RedoAnnotationCommand}">
                            <iconPacks:PackIconMaterial Kind="Reload" Width="15" Height="15" />
                        </ui:Button>
                        <ui:Button x:Name="CanvasDeleteAnnotationButton"
                                   Style="{StaticResource CanvasAnnotationCommandButtonStyle}"
                                   Width="38"
                                   Height="34"
                                   Margin="0"
                                   AutomationProperties.Name="&#xC120;&#xD0DD; &#xB77C;&#xBCA8; &#xC0AD;&#xC81C;"
                                   ToolTip="{Binding DeleteAnnotationTool.ToolTip}"
                                   IsEnabled="{Binding DeleteAnnotationTool.IsActionEnabled}"
                                   Command="{Binding DeleteAnnotationCommand}">
                            <iconPacks:PackIconMaterial Kind="TrashCanOutline" Width="15" Height="15" />
                        </ui:Button>
                    </StackPanel>
                </Border>
                <canvas:RoiImageCanvasView x:Name="MainCanvasView"
                                           Grid.Column="1"
                                           IsViewerToolBarVisible="False" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
