<UserControl x:Class="MvcVisionSystem.WpfClassCatalogPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:mvvm="clr-namespace:OpenVisionLab.Mvvm.Behaviors;assembly=OpenVisionLab.Mvvm">
    <UserControl.Resources>
        <Style x:Key="ClassCatalogIconStyle" TargetType="{x:Type iconPacks:PackIconMaterial}">
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="ClassCatalogButtonStyle" TargetType="{x:Type ui:Button}">
            <Setter Property="Background" Value="{DynamicResource ToolbarButtonBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ToolbarButtonBorderBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Height" Value="28" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Margin" Value="5,0,0,0" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
                    <Setter Property="Opacity" Value="0.45" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ClassCatalogTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="28" />
            <Setter Property="Background" Value="{DynamicResource InputBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="6,4" />
        </Style>

        <Style x:Key="ClassCatalogSectionLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>

        <Style x:Key="ClassCatalogListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="ToolTip" Value="{Binding ToolTip}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource RowHoverBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SelectedRowBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource SelectedRowTextBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ClassColorPresetItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource ToolbarButtonBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ToolbarButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Margin" Value="0,0,5,5" />
            <Setter Property="MinWidth" Value="70" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource RowHoverBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SelectedRowBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource SelectedRowTextBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="ClassCatalogColorPresetTemplate">
            <StackPanel Orientation="Horizontal">
                <Border Width="11"
                        Height="11"
                        CornerRadius="2"
                        Background="{Binding Brush}"
                        Margin="0,0,7,0"
                        VerticalAlignment="Center" />
                <TextBlock Text="{Binding Name}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border x:Name="ClassCatalogGuidePanel"
                Background="{DynamicResource SurfaceAltBrush}"
                BorderBrush="{DynamicResource BorderBrushDark}"
                BorderThickness="1"
                Padding="8"
                Margin="0,0,0,10">
            <StackPanel>
                <TextBlock x:Name="ClassCatalogGuideTitleText"
                           Text="{Binding ClassCatalogGuideTitleText}"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           FontFamily="Segoe UI"
                           FontSize="13"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
                <TextBlock x:Name="ClassCatalogGuideDetailText"
                           Text="{Binding ClassCatalogGuideDetailText}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           TextWrapping="Wrap"
                           Margin="0,4,0,0" />
                <TextBlock x:Name="ClassCatalogSummaryText"
                           AutomationProperties.AutomationId="ClassCatalogSummaryText"
                           Text="{Binding ClassCatalogSummaryText}"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           Margin="0,5,0,0" />
                <TextBlock x:Name="CurrentDrawingClassTitleText"
                           AutomationProperties.AutomationId="CurrentDrawingClassTitleText"
                           Text="{Binding CurrentDrawingClassTitleText}"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           Margin="0,6,0,0" />
                <TextBlock x:Name="CurrentDrawingClassDetailText"
                           AutomationProperties.AutomationId="CurrentDrawingClassDetailText"
                           Text="{Binding CurrentDrawingClassDetailText}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontFamily="Segoe UI"
                           FontSize="10.5"
                           TextWrapping="Wrap"
                           Margin="0,2,0,0" />
                <TextBlock x:Name="ClassCatalogActionText"
                           AutomationProperties.AutomationId="ClassCatalogActionText"
                           Text="{Binding ClassCatalogActionText}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontFamily="Segoe UI"
                           FontSize="10.5"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           Margin="0,3,0,0" />
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="1"
                   Text="&#xD074;&#xB798;&#xC2A4;"
                   Style="{StaticResource ClassCatalogSectionLabelStyle}" />
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="ClassNameBox"
                     AutomationProperties.AutomationId="ClassNameBox"
                     Style="{StaticResource ClassCatalogTextBoxStyle}"
                     Text="{Binding ClassName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="&#xD074;&#xB798;&#xC2A4; &#xC774;&#xB984;"
                     mvvm:InputCommandBehaviors.PreviewKeyInputCommand="{Binding ClassNamePreviewKeyDownCommand}" />
            <ui:Button x:Name="AddClassButton"
                       Grid.Column="1"
                       Style="{StaticResource ClassCatalogButtonStyle}"
                       MinWidth="62"
                       AutomationProperties.Name="&#xD074;&#xB798;&#xC2A4; &#xCD94;&#xAC00;"
                       ToolTip="&#xD074;&#xB798;&#xC2A4; &#xCD94;&#xAC00;"
                       Command="{Binding AddClassCommand}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <iconPacks:PackIconMaterial Style="{StaticResource ClassCatalogIconStyle}" Kind="Plus" />
                    <TextBlock Text="&#xCD94;&#xAC00;" VerticalAlignment="Center" />
                </StackPanel>
            </ui:Button>
            <ui:Button x:Name="RemoveClassButton"
                       Grid.Column="3"
                       Style="{StaticResource ClassCatalogButtonStyle}"
                       MinWidth="76"
                       AutomationProperties.Name="&#xD074;&#xB798;&#xC2A4; &#xC0AD;&#xC81C;"
                       ToolTip="&#xC120;&#xD0DD;&#xD55C; &#xD074;&#xB798;&#xC2A4; &#xC0AD;&#xC81C;"
                       Command="{Binding RemoveClassCommand}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <iconPacks:PackIconMaterial Style="{StaticResource ClassCatalogIconStyle}" Kind="TrashCanOutline" />
                    <TextBlock Text="&#xC0AD;&#xC81C;" VerticalAlignment="Center" />
                </StackPanel>
            </ui:Button>
            <ui:Button x:Name="RenameClassButton"
                       Grid.Column="2"
                       Style="{StaticResource ClassCatalogButtonStyle}"
                       MinWidth="64"
                       AutomationProperties.Name="&#xC120;&#xD0DD;&#xD55C; &#xD074;&#xB798;&#xC2A4; &#xC774;&#xB984; &#xBCC0;&#xACBD;"
                       ToolTip="&#xC120;&#xD0DD;&#xD55C; &#xD074;&#xB798;&#xC2A4; &#xC774;&#xB984; &#xBCC0;&#xACBD;"
                       Command="{Binding RenameClassCommand}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <iconPacks:PackIconMaterial Style="{StaticResource ClassCatalogIconStyle}" Kind="PencilOutline" />
                    <TextBlock Text="&#xBCC0;&#xACBD;" VerticalAlignment="Center" />
                </StackPanel>
            </ui:Button>
        </Grid>

        <Expander x:Name="ClassColorAdvancedPanel"
                  Grid.Row="3"
                  Header="{Binding ClassColorSectionTitleText}"
                  Foreground="{DynamicResource SecondaryTextBrush}"
                  FontFamily="Segoe UI"
                  FontSize="11"
                  FontWeight="SemiBold"
                  IsExpanded="False"
                  Margin="0,9,0,0">
            <Grid Margin="0,5,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ListBox x:Name="ClassColorBox"
                         AutomationProperties.AutomationId="ClassColorBox"
                         AutomationProperties.Name="&#xD074;&#xB798;&#xC2A4; &#xC0C9;&#xC0C1;"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                         ItemsSource="{Binding ColorPresets}"
                         SelectedItem="{Binding SelectedColorPreset, Mode=TwoWay}"
                         ItemTemplate="{StaticResource ClassCatalogColorPresetTemplate}"
                         ItemContainerStyle="{StaticResource ClassColorPresetItemStyle}"
                         ToolTip="&#xD074;&#xB798;&#xC2A4; &#xC0C9;&#xC0C1;&#xC744; &#xC120;&#xD0DD;&#xD558;&#xC138;&#xC694;. &#xC815;&#xC0C1;&#xC740; &#xCD08;&#xB85D;, &#xBD88;&#xB7C9;&#xC740; &#xBE68;&#xAC15;&#xCC98;&#xB7FC; &#xD604;&#xC7A5; &#xAE30;&#xC900;&#xC73C;&#xB85C; &#xAD6C;&#xBD84;&#xD569;&#xB2C8;&#xB2E4;.">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>
                <ui:Button x:Name="ApplyClassColorButton"
                           Grid.Column="1"
                           Style="{StaticResource ClassCatalogButtonStyle}"
                           MinWidth="76"
                           AutomationProperties.Name="&#xC120;&#xD0DD;&#xD55C; &#xD074;&#xB798;&#xC2A4; &#xC0C9;&#xC0C1; &#xC801;&#xC6A9;"
                           ToolTip="&#xC120;&#xD0DD;&#xD55C; &#xD074;&#xB798;&#xC2A4; &#xC0C9;&#xC0C1; &#xC801;&#xC6A9;"
                           Command="{Binding ApplyClassColorCommand}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <iconPacks:PackIconMaterial Style="{StaticResource ClassCatalogIconStyle}" Kind="PaletteOutline" />
                        <TextBlock Text="&#xC0C9; &#xC801;&#xC6A9;" VerticalAlignment="Center" />
                    </StackPanel>
                </ui:Button>
            </Grid>
        </Expander>

        <TextBlock x:Name="ClassEditStatusText"
                   Grid.Row="4"
                   Text="{Binding StatusText}"
                   Foreground="{DynamicResource SecondaryTextBrush}"
                   FontFamily="Segoe UI"
                   FontSize="11"
                   TextWrapping="Wrap"
                   Margin="0,7,0,6" />
        <TextBlock x:Name="RecipeClassListHeader"
                   Grid.Row="5"
                   Text="{Binding RecipeClassListTitleText}"
                   ToolTip="{Binding RecipeClassListGuideText}"
                   Style="{StaticResource ClassCatalogSectionLabelStyle}"
                   Margin="0,2,0,5" />
        <ListBox x:Name="ClassListBox"
                 Grid.Row="6"
                 Background="Transparent"
                 BorderThickness="0"
                 Foreground="{DynamicResource SecondaryTextBrush}"
                 ItemsSource="{Binding Classes}"
                 SelectedItem="{Binding SelectedClass, Mode=TwoWay}"
                 ItemContainerStyle="{StaticResource ClassCatalogListBoxItemStyle}"
                 mvvm:InputCommandBehaviors.SelectedItemChangedCommand="{Binding ClassSelectionChangedCommand}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="10"
                                Height="10"
                                CornerRadius="2"
                                Background="{Binding DrawBrush}"
                                Margin="0,0,7,0"
                                VerticalAlignment="Center" />
                        <TextBlock Text="{Binding DisplayText}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </Grid>
</UserControl>
