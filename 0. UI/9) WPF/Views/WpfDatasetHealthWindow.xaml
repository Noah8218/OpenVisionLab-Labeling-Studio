<ui:FluentWindow x:Class="MvcVisionSystem.WpfDatasetHealthWindow"
                 x:Name="DatasetHealthWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="데이터셋 상태 분석"
                 Width="1320"
                 Height="820"
                 MinWidth="980"
                 MinHeight="650"
                 Background="{DynamicResource AppBackgroundBrush}"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="None"
                 WindowCornerPreference="Round"
                 WindowStartupLocation="CenterOwner">
    <ui:FluentWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <SolidColorBrush x:Key="AppBackgroundBrush" Color="#0C0D0F" />
            <SolidColorBrush x:Key="PanelBrush" Color="#171717" />
            <SolidColorBrush x:Key="CanvasBrush" Color="#101820" />
            <SolidColorBrush x:Key="BorderBrushDark" Color="#303030" />
            <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F7F7F7" />
            <SolidColorBrush x:Key="SecondaryTextBrush" Color="#B7B7B7" />
            <SolidColorBrush x:Key="AccentBrush" Color="#E53935" />
            <SolidColorBrush x:Key="ToolbarButtonBrush" Color="#252525" />
            <SolidColorBrush x:Key="ToolbarButtonBorderBrush" Color="#3A3A3A" />
            <SolidColorBrush x:Key="GridLineBrush" Color="#2A2A2A" />
            <SolidColorBrush x:Key="GridHeaderBrush" Color="#202020" />
            <SolidColorBrush x:Key="SelectedRowBrush" Color="#26384F" />
            <SolidColorBrush x:Key="SuccessBrush" Color="#22C55E" />
            <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B" />
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

            <Style x:Key="DatasetHealthActionButtonStyle" TargetType="{x:Type ui:Button}">
                <Setter Property="Height" Value="32" />
                <Setter Property="Padding" Value="11,4" />
                <Setter Property="Background" Value="{DynamicResource ToolbarButtonBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ToolbarButtonBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="FontFamily" Value="Segoe UI" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <Style x:Key="DatasetHealthTabStyle" TargetType="{x:Type TabItem}">
                <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
                <Setter Property="Background" Value="{DynamicResource ToolbarButtonBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ToolbarButtonBorderBrush}" />
                <Setter Property="Padding" Value="15,7" />
                <Setter Property="Margin" Value="0,0,4,0" />
                <Setter Property="FontFamily" Value="Segoe UI" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                        <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="{x:Type DataGrid}">
                <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource GridLineBrush}" />
                <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource GridLineBrush}" />
                <Setter Property="RowBackground" Value="{DynamicResource PanelBrush}" />
                <Setter Property="AlternatingRowBackground" Value="{DynamicResource CanvasBrush}" />
                <Setter Property="HeadersVisibility" Value="Column" />
                <Setter Property="AutoGenerateColumns" Value="False" />
                <Setter Property="CanUserAddRows" Value="False" />
                <Setter Property="CanUserDeleteRows" Value="False" />
                <Setter Property="CanUserResizeRows" Value="False" />
                <Setter Property="CanUserSortColumns" Value="False" />
                <Setter Property="SelectionMode" Value="Single" />
                <Setter Property="SelectionUnit" Value="FullRow" />
                <Setter Property="GridLinesVisibility" Value="Horizontal" />
                <Setter Property="FontFamily" Value="Segoe UI" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="RowHeight" Value="38" />
                <Setter Property="IsReadOnly" Value="True" />
            </Style>

            <Style TargetType="{x:Type DataGridColumnHeader}">
                <Setter Property="Background" Value="{DynamicResource GridHeaderBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource GridLineBrush}" />
                <Setter Property="BorderThickness" Value="0,0,0,1" />
                <Setter Property="Padding" Value="9,7" />
                <Setter Property="FontFamily" Value="Segoe UI" />
                <Setter Property="FontSize" Value="10" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>
        </ResourceDictionary>
    </ui:FluentWindow.Resources>

    <Grid Margin="20,18,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border Width="36"
                    Height="36"
                    Background="{DynamicResource CanvasBrush}"
                    BorderBrush="{DynamicResource BorderBrushDark}"
                    BorderThickness="1"
                    CornerRadius="5"
                    Margin="0,0,10,0">
                <iconPacks:PackIconMaterial Kind="DatabaseCheckOutline"
                                            Width="20"
                                            Height="20"
                                            Foreground="{DynamicResource AccentBrush}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center" />
            </Border>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="DatasetHealthTitleText"
                               Text="데이터셋 상태 분석"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               FontFamily="Segoe UI"
                               FontSize="16"
                               FontWeight="SemiBold" />
                    <Border Background="{DynamicResource CanvasBrush}"
                            BorderBrush="{DynamicResource BorderBrushDark}"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="6,2"
                            Margin="9,1,0,0">
                        <TextBlock x:Name="DatasetHealthPurposeText"
                                   Text="{Binding PurposeText}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="9.5"
                                   FontWeight="SemiBold" />
                    </Border>
                </StackPanel>
                <TextBlock x:Name="DatasetHealthDatasetNameText"
                           Text="{Binding DatasetName}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontFamily="Segoe UI"
                           FontSize="10.5"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding OutputRootText}"
                           Margin="0,3,0,0" />
            </StackPanel>
            <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center">
                <ui:Button x:Name="DatasetHealthRefreshButton"
                           Style="{StaticResource DatasetHealthActionButtonStyle}"
                           Command="{Binding RefreshCommand}"
                           AutomationProperties.Name="데이터셋 상태 분석 새로고침"
                           ToolTip="현재 Recipe 저장 데이터를 다시 읽습니다. 라벨이나 분할은 변경하지 않습니다.">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Refresh" Width="14" Height="14" Margin="0,0,5,0" />
                        <TextBlock Text="새로고침" VerticalAlignment="Center" />
                    </StackPanel>
                </ui:Button>
                <TextBlock Text="{Binding GeneratedAtText}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontFamily="Segoe UI"
                           FontSize="9"
                           HorizontalAlignment="Right"
                           Margin="0,5,0,0" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Background="{DynamicResource CanvasBrush}"
                BorderBrush="{DynamicResource BorderBrushDark}"
                BorderThickness="1"
                CornerRadius="5"
                Padding="12,10"
                Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <iconPacks:PackIconMaterial Kind="ChartBoxOutline"
                                            Width="18"
                                            Height="18"
                                            Foreground="{DynamicResource AccentBrush}"
                                            VerticalAlignment="Top"
                                            Margin="0,1,10,0" />
                <StackPanel Grid.Column="1">
                    <TextBlock x:Name="DatasetHealthStatusText"
                               Text="{Binding StatusText}"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               FontFamily="Segoe UI"
                               FontSize="12"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="DatasetHealthStatusDetailText"
                               Text="{Binding StatusDetailText}"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontFamily="Segoe UI"
                               FontSize="10.5"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0" />
                    <TextBlock x:Name="DatasetHealthScopeText"
                               Text="{Binding DataScopeText}"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontFamily="Segoe UI"
                               FontSize="9.5"
                               TextWrapping="Wrap"
                               Margin="0,5,0,0"
                               Opacity="0.88" />
                </StackPanel>
            </Grid>
        </Border>

        <TabControl x:Name="DatasetHealthTabs"
                    Grid.Row="2"
                    Background="Transparent"
                    BorderThickness="0"
                    ItemContainerStyle="{StaticResource DatasetHealthTabStyle}">
            <TabItem x:Name="DatasetHealthOverviewTab" Header="개요">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,12,0,0">
                        <Border Background="{DynamicResource PanelBrush}"
                                BorderBrush="{DynamicResource BorderBrushDark}"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="0"
                                Margin="0,0,0,14">
                            <ItemsControl x:Name="DatasetHealthMetrics" ItemsSource="{Binding Metrics}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="4" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{DynamicResource BorderBrushDark}"
                                                BorderThickness="0,0,1,0"
                                                Padding="14,13">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           FontFamily="Segoe UI"
                                                           FontSize="10"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Value}"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                                           FontFamily="Segoe UI"
                                                           FontSize="22"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="0,5,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsProblem}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Detail}"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           FontFamily="Segoe UI"
                                                           FontSize="9.5"
                                                           TextWrapping="Wrap"
                                                           Margin="0,5,0,0" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.45*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Background="{DynamicResource PanelBrush}"
                                    BorderBrush="{DynamicResource BorderBrushDark}"
                                    BorderThickness="1"
                                    CornerRadius="5"
                                    Padding="14"
                                    Margin="0,0,12,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="확인 항목"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               FontFamily="Segoe UI"
                                               FontSize="12"
                                               FontWeight="SemiBold" />
                                    <Grid Grid.Row="1" Margin="0,10,0,0">
                                        <ItemsControl x:Name="DatasetHealthIssueItems"
                                                      ItemsSource="{Binding Issues}"
                                                      Visibility="{Binding HasIssues, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="18" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <iconPacks:PackIconMaterial Kind="AlertCircleOutline"
                                                                                    Width="14"
                                                                                    Height="14"
                                                                                    Foreground="{DynamicResource WarningBrush}"
                                                                                    VerticalAlignment="Top"
                                                                                    Margin="0,1,4,0">
                                                            <iconPacks:PackIconMaterial.Style>
                                                                <Style TargetType="iconPacks:PackIconMaterial">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsBlocking}" Value="True">
                                                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </iconPacks:PackIconMaterial.Style>
                                                        </iconPacks:PackIconMaterial>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Text}"
                                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                                   FontFamily="Segoe UI"
                                                                   FontSize="10.5"
                                                                   TextWrapping="Wrap" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock Text="저장된 데이터에서 추가 확인이 필요한 구조적 문제는 없습니다."
                                                   Foreground="{DynamicResource SuccessBrush}"
                                                   FontFamily="Segoe UI"
                                                   FontSize="10.5"
                                                   TextWrapping="Wrap">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasIssues}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Grid>
                            </Border>
                            <Border Grid.Column="1"
                                    Background="{DynamicResource CanvasBrush}"
                                    BorderBrush="{DynamicResource BorderBrushDark}"
                                    BorderThickness="1"
                                    CornerRadius="5"
                                    Padding="14">
                                <StackPanel>
                                    <TextBlock Text="모델 채택 근거"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               FontFamily="Segoe UI"
                                               FontSize="12"
                                               FontWeight="SemiBold" />
                                    <TextBlock x:Name="DatasetHealthEvidenceBoundaryText"
                                               Text="{Binding EvidenceBoundaryText}"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               FontFamily="Segoe UI"
                                               FontSize="10.5"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0" />
                                    <TextBlock Text="이 화면의 점검 결과가 정상이어도 모델 정확도·TaktTime·현장 대표성을 대신하지 않습니다."
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               FontFamily="Segoe UI"
                                               FontSize="9.5"
                                               TextWrapping="Wrap"
                                               Margin="0,12,0,0" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="DatasetHealthSplitTab" Header="분할 / 라벨">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="분할별 저장 상태"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               FontFamily="Segoe UI"
                               FontSize="12"
                               FontWeight="SemiBold" />
                    <DataGrid x:Name="DatasetHealthSplitGrid"
                              Grid.Row="1"
                              ItemsSource="{Binding SplitRows}"
                              Visibility="{Binding IsYoloDataset, Converter={StaticResource BooleanToVisibilityConverter}}"
                              Margin="0,10,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="분할" Binding="{Binding SplitText}" Width="130" />
                            <DataGridTextColumn Header="이미지" Binding="{Binding ImageCount}" Width="90" />
                            <DataGridTextColumn Header="주 라벨" Binding="{Binding PrimaryAnnotationText}" Width="180" />
                            <DataGridTextColumn Header="상태" Binding="{Binding CoverageText}" Width="230" />
                            <DataGridTextColumn Header="세부" Binding="{Binding DetailText}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <Border x:Name="DatasetHealthAnomalyDetailsPanel"
                            Grid.Row="1"
                            Background="{DynamicResource PanelBrush}"
                            BorderBrush="{DynamicResource BorderBrushDark}"
                            BorderThickness="1"
                            CornerRadius="5"
                            Padding="16"
                            Margin="0,10,0,0"
                            Visibility="{Binding IsAnomalyDataset, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="정상 / 이상 검토와 학습 분할"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       FontFamily="Segoe UI"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                            <TextBlock x:Name="DatasetHealthAnomalyDetailText"
                                       Text="{Binding AnomalyDetailText}"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       FontFamily="Segoe UI"
                                       FontSize="10.5"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0" />
                            <TextBlock Text="분류용 데이터 내보내기는 학습 시작 시점에 수행되며, 이 창은 원본 이미지의 검토 상태를 기준으로 표시합니다."
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       FontFamily="Segoe UI"
                                       FontSize="9.5"
                                       TextWrapping="Wrap"
                                       Margin="0,10,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem x:Name="DatasetHealthClassesTab" Header="클래스 분포">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="주 라벨 기준 클래스 분포"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               FontFamily="Segoe UI"
                               FontSize="12"
                               FontWeight="SemiBold" />
                    <DataGrid x:Name="DatasetHealthClassGrid"
                              Grid.Row="1"
                              ItemsSource="{Binding ClassRows}"
                              Margin="0,10,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="클래스" Binding="{Binding ClassName}" Width="2*" />
                            <DataGridTextColumn Header="주 라벨 수" Binding="{Binding Count}" Width="120" />
                            <DataGridTemplateColumn Header="비율" Width="2*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid Margin="5,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="48" />
                                            </Grid.ColumnDefinitions>
                                            <ProgressBar Value="{Binding SharePercent}"
                                                         Minimum="0"
                                                         Maximum="100"
                                                         Height="8"
                                                         VerticalAlignment="Center"
                                                         Foreground="{DynamicResource SuccessBrush}"
                                                         Background="{DynamicResource CanvasBrush}" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding ShareText}"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       FontSize="10"
                                                       TextAlignment="Right"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="판정" Binding="{Binding StatusText}" Width="140" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</ui:FluentWindow>
