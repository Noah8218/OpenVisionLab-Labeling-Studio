<Window x:Class="MvcVisionSystem.WpfDatasetSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:local="clr-namespace:MvcVisionSystem"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="&#xB370;&#xC774;&#xD130;&#xC14B; &#xC120;&#xD0DD;"
        Width="900"
        Height="720"
        MinWidth="820"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        Background="#151515"
        Foreground="#F3F4F6"
        WindowStyle="None"
        ResizeMode="CanResize">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="0" />
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#1F1F1F" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#242424" />
        <SolidColorBrush x:Key="BorderBrush" Color="#3A3A3A" />
        <SolidColorBrush x:Key="AccentBrush" Color="#EF4444" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#B8BDC7" />
        <Style x:Key="DatasetSelectButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2D2D2D" />
            <Setter Property="Foreground" Value="#F3F4F6" />
            <Setter Property="BorderBrush" Value="#454545" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="13,7" />
            <Setter Property="MinWidth" Value="78" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="DatasetSelectPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource DatasetSelectButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        </Style>
        <Style x:Key="DatasetListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#F3F4F6" />
            <Setter Property="Background" Value="#202020" />
            <Setter Property="BorderBrush" Value="#363636" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2D1B1B" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#8B5C5C" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <DataTemplate x:Key="DatasetSelectionItemTemplate">
            <Grid Margin="12,10" ToolTip="{Binding ToolTipText}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="28" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <iconPacks:PackIconMaterial Kind="{Binding IconKind}"
                                            Width="18"
                                            Height="18"
                                            Foreground="{StaticResource AccentBrush}"
                                            VerticalAlignment="Top"
                                            Margin="0,2,0,0" />
                <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding RecipeName}"
                               FontFamily="Segoe UI"
                               FontSize="14"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding StoragePathText}"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontFamily="Segoe UI"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,5,0,0" />
                    <TextBlock Text="{Binding ImageRootPathText}"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontFamily="Segoe UI"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,3,0,0" />
                    <TextBlock Text="{Binding ClassesText, StringFormat=&#xD074;&#xB798;&#xC2A4;: {0}}"
                               Foreground="#E5E7EB"
                               FontFamily="Segoe UI"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,3,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="2"
                             MinWidth="112"
                             Margin="12,0,0,0"
                             VerticalAlignment="Center">
                    <Border x:Name="DatasetPurposeBadge"
                            Background="#303030"
                            BorderBrush="#454545"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="6,2"
                            HorizontalAlignment="Right"
                            Margin="0,0,0,5">
                        <TextBlock Text="{Binding PurposeText}"
                                   FontFamily="Segoe UI"
                                   FontSize="10"
                                   FontWeight="SemiBold" />
                    </Border>
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="#F3F4F6"
                               FontFamily="Segoe UI"
                               FontSize="11"
                               FontWeight="SemiBold"
                               TextAlignment="Right" />
                    <TextBlock Text="{Binding CountText}"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontFamily="Segoe UI"
                               FontSize="10"
                               TextAlignment="Right"
                               Margin="0,4,0,0" />
                    <TextBlock Text="{Binding OpenActionText}"
                               Foreground="#FCA5A5"
                               FontFamily="Segoe UI"
                               FontSize="10"
                               FontWeight="SemiBold"
                               TextAlignment="Right"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <local:WpfWindowTitleBar Grid.Row="0"
                                 TitleText="&#xB370;&#xC774;&#xD130;&#xC14B; &#xC120;&#xD0DD;"
                                 SubtitleText="OpenVisionLab Labeling Studio"
                                 IconKind="DatabaseSearchOutline" />

        <Grid Grid.Row="1" Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <Border x:Name="DatasetSourceRuleCard"
                        AutomationProperties.AutomationId="DatasetSourceRuleCard"
                        Background="#211C1C"
                        BorderBrush="{StaticResource AccentBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12"
                        Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <iconPacks:PackIconMaterial Kind="DatabaseCogOutline"
                                                    Width="20"
                                                    Height="20"
                                                    Foreground="{StaticResource AccentBrush}"
                                                    VerticalAlignment="Top"
                                                    Margin="0,2,10,0" />
                        <StackPanel Grid.Column="1">
                            <TextBlock x:Name="DatasetSourceRuleTitleText"
                                       AutomationProperties.AutomationId="DatasetSourceRuleTitleText"
                                       Text="{Binding DatasetSourceRuleTitleText}"
                                       FontFamily="Segoe UI"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                            <TextBlock x:Name="DatasetSourceRuleDetailText"
                                       AutomationProperties.AutomationId="DatasetSourceRuleDetailText"
                                       Text="{Binding DatasetSourceRuleDetailText}"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       FontFamily="Segoe UI"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,5,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border x:Name="ExistingDatasetOpenGuideCard"
                            AutomationProperties.AutomationId="ExistingDatasetOpenGuideCard"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12"
                            Margin="0,0,8,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <iconPacks:PackIconMaterial Kind="DatabaseSearchOutline"
                                                        Width="18"
                                                        Height="18"
                                                        Foreground="{StaticResource AccentBrush}"
                                                        VerticalAlignment="Top"
                                                        Margin="0,2,9,0" />
                            <StackPanel Grid.Column="1">
                                <TextBlock x:Name="ExistingDatasetGuideTitleText"
                                           Text="{Binding ExistingDatasetGuideTitleText}"
                                           FontFamily="Segoe UI"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap" />
                                <TextBlock x:Name="ExistingDatasetGuideDetailText"
                                           Text="{Binding ExistingDatasetGuideDetailText}"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           FontFamily="Segoe UI"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border x:Name="CreateDatasetGuideCard"
                            AutomationProperties.AutomationId="CreateDatasetGuideCard"
                            Grid.Column="1"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12"
                            Margin="8,0,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <iconPacks:PackIconMaterial Kind="FolderPlusOutline"
                                                        Width="18"
                                                        Height="18"
                                                        Foreground="{StaticResource AccentBrush}"
                                                        VerticalAlignment="Top"
                                                        Margin="0,2,9,0" />
                            <StackPanel Grid.Column="1">
                                <TextBlock x:Name="CreateDatasetGuideTitleText"
                                           Text="{Binding CreateDatasetGuideTitleText}"
                                           FontFamily="Segoe UI"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap" />
                                <TextBlock x:Name="CreateDatasetGuideDetailText"
                                           Text="{Binding CreateDatasetGuideDetailText}"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           FontFamily="Segoe UI"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                            <Button x:Name="CreateDatasetGuideButton"
                                    Grid.Column="2"
                                    Style="{StaticResource DatasetSelectPrimaryButtonStyle}"
                                    AutomationProperties.AutomationId="CreateDatasetGuideButton"
                                    AutomationProperties.Name="&#xC0C8; &#xC800;&#xC7A5; &#xD3F4;&#xB354;&#xB85C; &#xB370;&#xC774;&#xD130;&#xC14B; &#xB9CC;&#xB4E4;&#xAE30;"
                                    Command="{Binding CreateNewCommand}"
                                    Margin="12,0,0,0"
                                    Content="&#xB9CC;&#xB4E4;&#xAE30;" />
                        </Grid>
                    </Border>
                </Grid>
            </StackPanel>

            <Border Grid.Row="1"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10">
                <Grid>
                    <ListBox x:Name="DatasetSelectionListBox"
                             AutomationProperties.AutomationId="DatasetSelectionListBox"
                             Background="Transparent"
                             BorderThickness="0"
                             ItemContainerStyle="{StaticResource DatasetListItemStyle}"
                             ItemTemplate="{StaticResource DatasetSelectionItemTemplate}"
                             ItemsSource="{Binding Datasets}"
                             SelectedItem="{Binding SelectedDataset, Mode=TwoWay}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled" />
                    <Border x:Name="DatasetSelectionEmptyStatePanel"
                            AutomationProperties.AutomationId="DatasetSelectionEmptyStatePanel"
                            Visibility="{Binding EmptyStateVisibility}"
                            Background="{StaticResource PanelAltBrush}"
                            BorderBrush="{StaticResource AccentBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="20"
                            MaxWidth="420"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <StackPanel HorizontalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="DatabasePlusOutline"
                                                        Width="34"
                                                        Height="34"
                                                        Foreground="{StaticResource AccentBrush}"
                                                        HorizontalAlignment="Center"
                                                        Margin="0,0,0,10" />
                            <TextBlock Text="&#xC544;&#xC9C1; &#xC5F4; &#xB370;&#xC774;&#xD130;&#xC14B;&#xC774; &#xC5C6;&#xC2B5;&#xB2C8;&#xB2E4;"
                                       Foreground="#F3F4F6"
                                       FontFamily="Segoe UI"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="&#xC0C8; &#xB370;&#xC774;&#xD130;&#xC14B;&#xC740; &#xC0C8; &#xC800;&#xC7A5; &#xD3F4;&#xB354;&#xB97C; &#xAE30;&#xC900;&#xC73C;&#xB85C; &#xB77C;&#xBCA8;&#xC744; &#xBD84;&#xB9AC;&#xD569;&#xB2C8;&#xB2E4;."
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       FontFamily="Segoe UI"
                                       FontSize="12"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="0,7,0,14" />
                            <Button x:Name="CreateFirstDatasetButton"
                                    Style="{StaticResource DatasetSelectPrimaryButtonStyle}"
                                    AutomationProperties.AutomationId="CreateFirstDatasetButton"
                                    AutomationProperties.Name="&#xCCAB; &#xB370;&#xC774;&#xD130;&#xC14B; &#xB9CC;&#xB4E4;&#xAE30;"
                                    Command="{Binding CreateNewCommand}"
                                    HorizontalAlignment="Center"
                                    Content="&#xC0C8; &#xB370;&#xC774;&#xD130;&#xC14B; &#xB9CC;&#xB4E4;&#xAE30;" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="DatasetSelectionStatusText"
                           Text="{Binding StatusText}"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           FontFamily="Segoe UI"
                           FontSize="12"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="RefreshDatasetSelectionButton"
                            Style="{StaticResource DatasetSelectButtonStyle}"
                            AutomationProperties.AutomationId="RefreshDatasetSelectionButton"
                            AutomationProperties.Name="&#xB370;&#xC774;&#xD130;&#xC14B; &#xBAA9;&#xB85D; &#xC0C8;&#xB85C;&#xACE0;&#xCE68;"
                            Command="{Binding RefreshCommand}"
                            Margin="0,0,8,0"
                            Content="&#xC0C8;&#xB85C;&#xACE0;&#xCE68;" />
                    <Button x:Name="CreateNewDatasetFromSelectionButton"
                            Style="{StaticResource DatasetSelectButtonStyle}"
                            AutomationProperties.AutomationId="CreateNewDatasetFromSelectionButton"
                            AutomationProperties.Name="&#xC0C8; &#xB370;&#xC774;&#xD130;&#xC14B; &#xB9CC;&#xB4E4;&#xAE30;"
                            Command="{Binding CreateNewCommand}"
                            Margin="0,0,8,0"
                            Content="&#xC0C8; &#xB370;&#xC774;&#xD130;&#xC14B;" />
                    <Button x:Name="CancelDatasetSelectionButton"
                            Style="{StaticResource DatasetSelectButtonStyle}"
                            AutomationProperties.AutomationId="CancelDatasetSelectionButton"
                            AutomationProperties.Name="&#xB370;&#xC774;&#xD130;&#xC14B; &#xC120;&#xD0DD; &#xCDE8;&#xC18C;"
                            Command="{Binding CancelCommand}"
                            Margin="0,0,8,0"
                            Content="&#xCDE8;&#xC18C;" />
                    <Button x:Name="OpenSelectedDatasetButton"
                            Style="{StaticResource DatasetSelectPrimaryButtonStyle}"
                            AutomationProperties.AutomationId="OpenSelectedDatasetButton"
                            AutomationProperties.Name="&#xC120;&#xD0DD;&#xD55C; &#xB370;&#xC774;&#xD130;&#xC14B; &#xC5F4;&#xAE30;"
                            Command="{Binding OpenCommand}"
                            Content="&#xC120;&#xD0DD; &#xC5F4;&#xAE30;" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
