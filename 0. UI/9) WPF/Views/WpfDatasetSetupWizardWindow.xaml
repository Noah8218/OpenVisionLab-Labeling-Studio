<Window x:Class="MvcVisionSystem.WpfDatasetSetupWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:local="clr-namespace:MvcVisionSystem"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="&#xB370;&#xC774;&#xD130;&#xC14B; &#xC0DD;&#xC131;"
        Width="600"
        Height="740"
        MinWidth="560"
        MinHeight="650"
        WindowStartupLocation="CenterOwner"
        Background="#151515"
        Foreground="#F3F4F6"
        WindowStyle="None"
        ResizeMode="CanResize">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="0" />
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#1F1F1F" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#242424" />
        <SolidColorBrush x:Key="BorderBrush" Color="#3A3A3A" />
        <SolidColorBrush x:Key="AccentBrush" Color="#EF4444" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#B8BDC7" />
        <Style x:Key="WizardLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>
        <Style x:Key="WizardInputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#252525" />
            <Setter Property="Foreground" Value="#F3F4F6" />
            <Setter Property="BorderBrush" Value="#3D3D3D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style x:Key="WizardButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2D2D2D" />
            <Setter Property="Foreground" Value="#F3F4F6" />
            <Setter Property="BorderBrush" Value="#454545" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="13,7" />
            <Setter Property="MinWidth" Value="76" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="WizardPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource WizardButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        </Style>
        <Style x:Key="WizardListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="#252525" />
            <Setter Property="BorderBrush" Value="#3D3D3D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        </Style>
        <Style x:Key="WizardListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#F3F4F6" />
            <Setter Property="Background" Value="#2D2D2D" />
            <Setter Property="BorderBrush" Value="#454545" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="9,7" />
            <Setter Property="Margin" Value="0,0,6,6" />
            <Setter Property="MinWidth" Value="146" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <DataTemplate x:Key="PurposeItemTemplate">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <iconPacks:PackIconMaterial Kind="{Binding IconKind}"
                                            Width="15"
                                            Height="15"
                                            Margin="0,0,7,0"
                                            VerticalAlignment="Center" />
                <TextBlock Text="{Binding Text}"
                           FontFamily="Segoe UI"
                           FontSize="12"
                           VerticalAlignment="Center" />
            </StackPanel>
        </DataTemplate>
        <DataTemplate x:Key="SamplePresetItemTemplate">
            <StackPanel>
                <TextBlock Text="{Binding Text}"
                           FontFamily="Segoe UI"
                           FontSize="12"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding AvailabilityText}"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           TextWrapping="Wrap"
                           Margin="0,3,0,0" />
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <local:WpfWindowTitleBar Grid.Row="0"
                                 TitleText="&#xB370;&#xC774;&#xD130;&#xC14B; &#xC0DD;&#xC131;"
                                 SubtitleText="OpenVisionLab Labeling Studio"
                                 IconKind="FolderPlusOutline" />

        <Grid Grid.Row="1" Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,14">
                <TextBlock x:Name="WizardSummaryText"
                           Text="&#xBAA9;&#xC801;, Recipe, &#xC800;&#xC7A5; &#xACBD;&#xB85C;, &#xCD08;&#xAE30; &#xD074;&#xB798;&#xC2A4;&#xB97C; &#xD655;&#xC778;&#xD55C; &#xB4A4; &#xB77C;&#xBCA8;&#xB9C1;&#xC744; &#xC2DC;&#xC791;&#xD569;&#xB2C8;&#xB2E4;."
                           Foreground="{StaticResource SecondaryTextBrush}"
                           FontFamily="Segoe UI"
                           FontSize="12"
                           TextWrapping="Wrap" />
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border x:Name="DatasetPurposeSection"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12"
                            Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="&#xB370;&#xC774;&#xD130;&#xC14B; &#xBAA9;&#xC801;" Style="{StaticResource WizardLabelStyle}" />
                            <ListBox x:Name="WizardDatasetPurposeListBox"
                                     Style="{StaticResource WizardListBoxStyle}"
                                     ItemContainerStyle="{StaticResource WizardListItemStyle}"
                                     ItemTemplate="{StaticResource PurposeItemTemplate}"
                                     ItemsSource="{Binding DatasetPurposeModes}"
                                     SelectedItem="{Binding SelectedDatasetPurposeMode, Mode=TwoWay}">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                            </ListBox>
                        </StackPanel>
                    </Border>

                    <Border x:Name="DatasetSamplePresetSection"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12"
                            Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="&#xC2DC;&#xC791; &#xB370;&#xC774;&#xD130;" Style="{StaticResource WizardLabelStyle}" />
                            <ListBox x:Name="WizardSamplePresetListBox"
                                     Style="{StaticResource WizardListBoxStyle}"
                                     ItemTemplate="{StaticResource SamplePresetItemTemplate}"
                                     ItemsSource="{Binding SamplePresets}"
                                     SelectedItem="{Binding SelectedSamplePreset, Mode=TwoWay}">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource WizardListItemStyle}">
                                        <Setter Property="IsEnabled" Value="{Binding IsAvailable}" />
                                        <Setter Property="ToolTip" Value="{Binding ToolTip}" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                            </ListBox>
                        </StackPanel>
                    </Border>

                    <Border x:Name="DatasetRecipeSection"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12"
                            Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Recipe &#xC774;&#xB984;" Style="{StaticResource WizardLabelStyle}" />
                            <TextBox x:Name="WizardRecipeNameBox"
                                     Style="{StaticResource WizardInputStyle}"
                                     AutomationProperties.AutomationId="WizardRecipeNameBox"
                                     AutomationProperties.Name="Recipe &#xC774;&#xB984;"
                                     Text="{Binding RecipeName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="{Binding RecipeName}" />
                        </StackPanel>
                    </Border>

                    <Border x:Name="DatasetOutputRootSection"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12"
                            Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="&#xC800;&#xC7A5; &#xACBD;&#xB85C;" Style="{StaticResource WizardLabelStyle}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="WizardOutputRootPathBox"
                                         Grid.Column="0"
                                         Style="{StaticResource WizardInputStyle}"
                                         AutomationProperties.AutomationId="WizardOutputRootPathBox"
                                         AutomationProperties.Name="&#xB370;&#xC774;&#xD130;&#xC14B; &#xC800;&#xC7A5; &#xACBD;&#xB85C;"
                                         Text="{Binding OutputRootPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="{Binding OutputRootPath}" />
                                <Button x:Name="WizardBrowseOutputRootButton"
                                        Grid.Column="1"
                                        Style="{StaticResource WizardButtonStyle}"
                                        AutomationProperties.AutomationId="WizardBrowseOutputRootButton"
                                        AutomationProperties.Name="&#xB370;&#xC774;&#xD130;&#xC14B; &#xC800;&#xC7A5; &#xACBD;&#xB85C; &#xCC3E;&#xAE30;"
                                        Command="{Binding BrowseOutputRootCommand}"
                                        Margin="8,0,0,0"
                                        MinWidth="68">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="FolderOpenOutline" Width="14" Height="14" Margin="0,0,5,0" />
                                        <TextBlock Text="&#xCC3E;&#xAE30;" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border x:Name="DatasetClassesSection"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12">
                        <StackPanel>
                            <TextBlock Text="&#xCD08;&#xAE30; &#xD074;&#xB798;&#xC2A4;" Style="{StaticResource WizardLabelStyle}" />
                            <TextBox x:Name="WizardClassNamesBox"
                                     Style="{StaticResource WizardInputStyle}"
                                     AutomationProperties.AutomationId="WizardClassNamesBox"
                                     AutomationProperties.Name="&#xCD08;&#xAE30; &#xD074;&#xB798;&#xC2A4;"
                                     Text="{Binding ClassNamesText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     MinHeight="70" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border x:Name="DatasetPreviewSection"
                    Grid.Row="2"
                    Background="{StaticResource PanelAltBrush}"
                    BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12"
                    Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Text="&#xC0DD;&#xC131; &#xBBF8;&#xB9AC;&#xBCF4;&#xAE30;" Style="{StaticResource WizardLabelStyle}" />
                    <TextBlock x:Name="WizardPreviewText"
                               Text="{Binding PreviewText}"
                               Foreground="#E5E7EB"
                               FontFamily="Segoe UI"
                               FontSize="12"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Grid Grid.Row="3" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="WizardStatusText"
                           Grid.Column="0"
                           Text="{Binding StatusText}"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           FontFamily="Segoe UI"
                           FontSize="12"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="WizardCancelButton"
                            Style="{StaticResource WizardButtonStyle}"
                            AutomationProperties.AutomationId="WizardCancelButton"
                            AutomationProperties.Name="&#xB370;&#xC774;&#xD130;&#xC14B; &#xC0DD;&#xC131; &#xCDE8;&#xC18C;"
                            Command="{Binding CancelCommand}"
                            Margin="0,0,8,0"
                            Content="&#xCDE8;&#xC18C;" />
                    <Button x:Name="WizardCreateButton"
                            Style="{StaticResource WizardPrimaryButtonStyle}"
                            AutomationProperties.AutomationId="WizardCreateButton"
                            AutomationProperties.Name="&#xB370;&#xC774;&#xD130;&#xC14B; &#xC0DD;&#xC131;"
                            Command="{Binding CreateCommand}"
                            CommandParameter="{Binding SelectedItem, ElementName=WizardDatasetPurposeListBox}"
                            Content="&#xC0DD;&#xC131;" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
