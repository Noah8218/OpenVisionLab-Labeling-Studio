<UserControl x:Class="MvcVisionSystem.WpfImageQueuePanel"
             x:Name="ImageQueueRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:mvvm="clr-namespace:OpenVisionLab.Mvvm.Behaviors;assembly=OpenVisionLab.Mvvm">
    <UserControl.Resources>
        <Style x:Key="QueueIconStyle" TargetType="{x:Type iconPacks:PackIconMaterial}">
            <Setter Property="Width" Value="15" />
            <Setter Property="Height" Value="15" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

        <Style x:Key="ToolbarIconStyle" TargetType="{x:Type iconPacks:PackIconMaterial}">
            <Setter Property="Width" Value="13" />
            <Setter Property="Height" Value="13" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="QueueIconButtonStyle" TargetType="{x:Type ui:Button}">
            <Setter Property="Width" Value="40" />
            <Setter Property="MinWidth" Value="40" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Background" Value="{DynamicResource ToolbarButtonBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ToolbarButtonBorderBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SelectedRowBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                </DataTrigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{DynamicResource ToolbarButtonBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
                    <Setter Property="Opacity" Value="0.45" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="QueuePrimaryActionButtonStyle" TargetType="{x:Type ui:Button}">
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="6,0" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Background" Value="{DynamicResource SelectedRowBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{DynamicResource ToolbarButtonBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
                    <Setter Property="Opacity" Value="0.55" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="QueueQuickFilterButtonStyle" TargetType="{x:Type ui:Button}">
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="84" />
            <Setter Property="Padding" Value="7,0" />
            <Setter Property="Margin" Value="0,0,5,5" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Background" Value="{DynamicResource ToolbarButtonBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ToolbarButtonBorderBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SelectedRowBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                </DataTrigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{DynamicResource ToolbarButtonBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
                    <Setter Property="Opacity" Value="0.45" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ImageQueueColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource GridHeaderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GridLineBrush}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="5,4" />
        </Style>

        <Style x:Key="ImageQueueRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GridLineBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ToolbarButtonBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SelectedRowBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource SelectedRowTextBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                    <Setter Property="BorderThickness" Value="3,0,0,1" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ImageQueueCellStyle" TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GridLineBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Foreground" Value="{DynamicResource SelectedRowTextBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="QueueStatusBadgeStyle" TargetType="Border">
            <Setter Property="MinWidth" Value="42" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Padding" Value="7,0" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Background" Value="{Binding QueueBadgeBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{Binding QueueIconBrush}" />
            <Setter Property="BorderThickness" Value="1.25" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding QueueBadgeText}" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ImageQueueTextStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="5,1" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="ToolTip" Value="{Binding Detail}" />
        </Style>

        <Style x:Key="ImageQueueFilterComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="24" />
            <Setter Property="Background" Value="{DynamicResource InputBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="7,0,24,0" />
            <Setter Property="ItemTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding Text}"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                    </DataTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="{DynamicResource InputBrush}" />
                        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                        <Setter Property="Padding" Value="7,4" />
                        <Setter Property="MinHeight" Value="24" />
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SelectedRowBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SelectedRowBrush}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid SnapsToDevicePixels="True">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="3" />
                            <TextBlock Text="{Binding SelectedItem.Text, RelativeSource={RelativeSource TemplatedParent}}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontFamily="{TemplateBinding FontFamily}"
                                       FontSize="{TemplateBinding FontSize}"
                                       Margin="{TemplateBinding Padding}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       IsHitTestVisible="False" />
                            <ToggleButton Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="Transparent"
                                          BorderThickness="0">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border Background="Transparent">
                                            <ContentPresenter />
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <Path Data="M 0 0 L 4 4 L 8 0 Z"
                                      Width="8"
                                      Height="4"
                                      Stretch="Fill"
                                      Fill="{TemplateBinding Foreground}"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      Margin="0,0,8,0" />
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="{DynamicResource InputBrush}"
                                        BorderBrush="{DynamicResource InputBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="3">
                                    <ScrollViewer CanContentScroll="True">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="{DynamicResource PanelBrush}"
            BorderBrush="{DynamicResource BorderBrushDark}"
            BorderThickness="1"
            CornerRadius="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34" />
                <RowDefinition Height="216" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="{DynamicResource PanelHeaderBrush}"
                    CornerRadius="6,6,0,0"
                    BorderBrush="{DynamicResource BorderBrushDark}"
                    BorderThickness="0,0,0,1">
                <TextBlock Text="&#xC774;&#xBBF8;&#xC9C0; &#xD050;"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           FontFamily="Segoe UI"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Margin="12,0"
                           VerticalAlignment="Center" />
            </Border>

            <Grid Grid.Row="1" Margin="8,7,8,6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="32" />
                    <RowDefinition Height="28" />
                    <RowDefinition Height="82" />
                    <RowDefinition Height="34" />
                    <RowDefinition Height="22" />
                </Grid.RowDefinitions>

                <WrapPanel VerticalAlignment="Center">
                    <ui:Button Style="{StaticResource QueueIconButtonStyle}" ToolTip="&#xC124;&#xC815;&#xB41C; &#xC774;&#xBBF8;&#xC9C0; &#xD3F4;&#xB354; &#xBD88;&#xB7EC;&#xC624;&#xAE30;" AutomationProperties.Name="&#xC124;&#xC815; &#xD3F4;&#xB354;" Command="{Binding LoadImageRootCommand}">
                        <iconPacks:PackIconMaterial Style="{StaticResource QueueIconStyle}" Kind="FolderImage" />
                    </ui:Button>
                    <ui:Button Style="{StaticResource QueueIconButtonStyle}" ToolTip="&#xC774;&#xBBF8;&#xC9C0; &#xD3F4;&#xB354; &#xC120;&#xD0DD;" AutomationProperties.Name="&#xD3F4;&#xB354;" Command="{Binding BrowseImageFolderCommand}">
                        <iconPacks:PackIconMaterial Style="{StaticResource QueueIconStyle}" Kind="FolderOpen" />
                    </ui:Button>
                    <ui:Button Style="{StaticResource QueueIconButtonStyle}" ToolTip="&#xC774;&#xBBF8;&#xC9C0; &#xBAA9;&#xB85D; &#xC0C8;&#xB85C;&#xACE0;&#xCE68;" AutomationProperties.Name="&#xC0C8;&#xB85C;&#xACE0;&#xCE68;" Command="{Binding RefreshImageQueueCommand}">
                        <iconPacks:PackIconMaterial Style="{StaticResource QueueIconStyle}" Kind="Refresh" />
                    </ui:Button>
                    <ui:Button x:Name="NextUnlabeledPrimaryButton" Style="{StaticResource QueuePrimaryActionButtonStyle}" ToolTip="아직 완료하지 않은 다음 이미지를 엽니다" AutomationProperties.AutomationId="NextUnlabeledPrimaryButton" AutomationProperties.Name="다음 이미지" Command="{Binding NextUnlabeledCommand}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <iconPacks:PackIconMaterial Style="{StaticResource ToolbarIconStyle}" Kind="ArrowRightCircleOutline" />
                            <TextBlock Text="&#xB2E4;&#xC74C;" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </ui:Button>
                    <ui:Button x:Name="OpenSelectedQueueImageButton" Style="{StaticResource QueueIconButtonStyle}" ToolTip="&#xC120;&#xD0DD; &#xC774;&#xBBF8;&#xC9C0;&#xB97C; &#xB2E4;&#xC2DC; &#xC5F4;&#xAE30;" AutomationProperties.Name="&#xC5F4;&#xAE30;" IsEnabled="{Binding IsOpenSelectedImageEnabled}" Command="{Binding OpenSelectedQueueImageCommand}">
                        <iconPacks:PackIconMaterial Style="{StaticResource QueueIconStyle}" Kind="ImageOutline" />
                    </ui:Button>
                </WrapPanel>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="112" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="ImageQueueFilterBox"
                              Style="{StaticResource ImageQueueFilterComboBoxStyle}"
                              ToolTip="&#xC0C1;&#xD0DC; &#xD544;&#xD130;"
                              mvvm:InputCommandBehaviors.SelectedItemChangedCommand="{Binding FilterSelectionChangedCommand}" />
                    <Grid Grid.Column="2">
                        <iconPacks:PackIconMaterial Width="14"
                                                    Height="14"
                                                    Kind="Magnify"
                                                    Foreground="{DynamicResource DisabledTextBrush}"
                                                    Margin="7,0,0,0"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Left"
                                                    IsHitTestVisible="False" />
                        <TextBox x:Name="ImageQueueSearchBox"
                                 AutomationProperties.AutomationId="ImageQueueSearchBox"
                                 AutomationProperties.Name="&#xC774;&#xBBF8;&#xC9C0; &#xD050; &#xAC80;&#xC0C9;"
                                 Height="24"
                                 Background="{DynamicResource InputBrush}"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 BorderBrush="{DynamicResource InputBorderBrush}"
                                 FontFamily="Segoe UI"
                                 FontSize="12"
                                 Padding="24,2,6,2"
                                 ToolTip="&#xD30C;&#xC77C;&#xBA85; &#xAC80;&#xC0C9;"
                                 mvvm:InputCommandBehaviors.TextInputCommand="{Binding SearchTextChangedCommand}" />
                    </Grid>
                </Grid>

                <UniformGrid Grid.Row="2" Columns="3" Rows="2" VerticalAlignment="Center">
                    <ui:Button x:Name="QueueFilterAllButton" Style="{StaticResource QueueQuickFilterButtonStyle}" Tag="{Binding IsQueueFilterAllActive}" AutomationProperties.Name="&#xC804;&#xCCB4; &#xD544;&#xD130;" ToolTip="&#xC804;&#xCCB4; &#xC774;&#xBBF8;&#xC9C0; &#xBCF4;&#xAE30;" Command="{Binding QueueFilterAllCommand}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <iconPacks:PackIconMaterial Style="{StaticResource ToolbarIconStyle}" Kind="ViewListOutline" />
                            <TextBlock x:Name="QueueFilterAllText" Text="{Binding QueueFilterAllText}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </ui:Button>
                    <ui:Button x:Name="QueueFilterCandidateButton" Style="{StaticResource QueueQuickFilterButtonStyle}" Tag="{Binding IsQueueFilterCandidateActive}" AutomationProperties.Name="&#xD6C4;&#xBCF4; &#xD544;&#xD130;" ToolTip="AI &#xD6C4;&#xBCF4;&#xAC00; &#xC788;&#xB294; &#xC774;&#xBBF8;&#xC9C0;&#xB9CC; &#xBCF4;&#xAE30;" Command="{Binding QueueFilterCandidateCommand}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <iconPacks:PackIconMaterial Style="{StaticResource ToolbarIconStyle}" Kind="ImageSearch" />
                            <TextBlock x:Name="QueueFilterCandidateText" Text="{Binding QueueFilterCandidateText}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </ui:Button>
                    <ui:Button x:Name="QueueFilterFailedButton" Style="{StaticResource QueueQuickFilterButtonStyle}" Tag="{Binding IsQueueFilterFailedActive}" AutomationProperties.Name="&#xC2E4;&#xD328; &#xD544;&#xD130;" ToolTip="&#xAC80;&#xC0AC; &#xC2E4;&#xD328; &#xC774;&#xBBF8;&#xC9C0;&#xB9CC; &#xBCF4;&#xAE30;" Command="{Binding QueueFilterFailedCommand}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <iconPacks:PackIconMaterial Style="{StaticResource ToolbarIconStyle}" Kind="AlertCircleOutline" />
                            <TextBlock x:Name="QueueFilterFailedText" Text="{Binding QueueFilterFailedText}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </ui:Button>
                    <ui:Button x:Name="QueueFilterConfirmedButton" Style="{StaticResource QueueQuickFilterButtonStyle}" Tag="{Binding IsQueueFilterConfirmedActive}" AutomationProperties.Name="&#xD655;&#xC815; &#xD544;&#xD130;" ToolTip="&#xD655;&#xC815;&#xB41C; &#xC774;&#xBBF8;&#xC9C0;&#xB9CC; &#xBCF4;&#xAE30;" Command="{Binding QueueFilterConfirmedCommand}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <iconPacks:PackIconMaterial Style="{StaticResource ToolbarIconStyle}" Kind="CheckboxMarkedCircleOutline" />
                            <TextBlock x:Name="QueueFilterConfirmedText" Text="{Binding QueueFilterConfirmedText}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </ui:Button>
                    <ui:Button x:Name="QueueFilterSkippedButton" Style="{StaticResource QueueQuickFilterButtonStyle}" Tag="{Binding IsQueueFilterSkippedActive}" AutomationProperties.Name="&#xC2A4;&#xD0B5; &#xD544;&#xD130;" ToolTip="&#xC2A4;&#xD0B5;&#xD55C; &#xC774;&#xBBF8;&#xC9C0;&#xB9CC; &#xBCF4;&#xAE30;" Command="{Binding QueueFilterSkippedCommand}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <iconPacks:PackIconMaterial Style="{StaticResource ToolbarIconStyle}" Kind="SkipNext" />
                            <TextBlock x:Name="QueueFilterSkippedText" Text="{Binding QueueFilterSkippedText}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </ui:Button>
                    <ui:Button x:Name="QueueFilterNoCandidateButton" Style="{StaticResource QueueQuickFilterButtonStyle}" Tag="{Binding IsQueueFilterNoCandidateActive}" AutomationProperties.Name="&#xAC80;&#xCD9C;&#xC5C6;&#xC74C; &#xD544;&#xD130;" ToolTip="&#xAC80;&#xCD9C; &#xD6C4;&#xBCF4;&#xAC00; &#xC5C6;&#xB294; &#xC774;&#xBBF8;&#xC9C0;&#xB9CC; &#xBCF4;&#xAE30;" Command="{Binding QueueFilterNoCandidateCommand}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <iconPacks:PackIconMaterial Style="{StaticResource ToolbarIconStyle}" Kind="MinusCircleOutline" />
                            <TextBlock x:Name="QueueFilterNoCandidateText" Text="{Binding QueueFilterNoCandidateText}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </ui:Button>
                </UniformGrid>

                <WrapPanel Grid.Row="3" VerticalAlignment="Center">
                    <ui:Button x:Name="DetectSelectedQueueButton" Style="{StaticResource QueueIconButtonStyle}" ToolTip="&#xC120;&#xD0DD; &#xC774;&#xBBF8;&#xC9C0; &#xAC80;&#xC0AC;" AutomationProperties.Name="&#xC120;&#xD0DD; &#xAC80;&#xC0AC;" IsEnabled="{Binding IsDetectSelectedEnabled}" Command="{Binding DetectSelectedQueueCommand}">
                        <iconPacks:PackIconMaterial Style="{StaticResource QueueIconStyle}" Kind="ImageSearch" />
                    </ui:Button>
                    <ui:Button x:Name="BatchDetectQueueButton" Style="{StaticResource QueueIconButtonStyle}" ToolTip="&#xD45C;&#xC2DC; &#xBAA9;&#xB85D; &#xC77C;&#xAD04; &#xAC80;&#xC0AC;" AutomationProperties.Name="&#xC77C;&#xAD04; &#xAC80;&#xC0AC;" IsEnabled="{Binding IsBatchDetectEnabled}" Command="{Binding BatchDetectQueueCommand}">
                        <iconPacks:PackIconMaterial Style="{StaticResource QueueIconStyle}" Kind="PlaylistPlay" />
                    </ui:Button>
                    <ui:Button x:Name="RetryFailedQueueButton" Style="{StaticResource QueueIconButtonStyle}" ToolTip="&#xC2E4;&#xD328; &#xD56D;&#xBAA9; &#xC7AC;&#xC2DC;&#xB3C4;" AutomationProperties.Name="&#xC7AC;&#xC2DC;&#xB3C4;" IsEnabled="{Binding IsRetryFailedEnabled}" Command="{Binding RetryFailedQueueCommand}">
                        <iconPacks:PackIconMaterial Style="{StaticResource QueueIconStyle}" Kind="Reload" />
                    </ui:Button>
                    <ui:Button x:Name="StopBatchQueueButton" Style="{StaticResource QueueIconButtonStyle}" ToolTip="&#xC77C;&#xAD04; &#xAC80;&#xC0AC; &#xC911;&#xC9C0;" AutomationProperties.Name="&#xC911;&#xC9C0;" IsEnabled="{Binding IsStopBatchEnabled}" Command="{Binding StopBatchQueueCommand}">
                        <iconPacks:PackIconMaterial Style="{StaticResource QueueIconStyle}" Kind="StopCircleOutline" />
                    </ui:Button>
                </WrapPanel>

                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="78" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="BatchStatusText"
                               Text="&#xBC30;&#xCE58; &#xB300;&#xAE30;"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontFamily="Segoe UI"
                               FontSize="11"
                               VerticalAlignment="Center" />
                    <ProgressBar x:Name="BatchProgressBar"
                                 Grid.Column="1"
                                 Height="8"
                                 Minimum="0"
                                 Maximum="1"
                                 Value="0"
                                 VerticalAlignment="Center" />
                </Grid>
            </Grid>

            <DataGrid x:Name="ImageQueueGrid"
                      Grid.Row="2"
                      ColumnHeaderStyle="{StaticResource ImageQueueColumnHeaderStyle}"
                      RowStyle="{StaticResource ImageQueueRowStyle}"
                      CellStyle="{StaticResource ImageQueueCellStyle}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeRows="False"
                      EnableColumnVirtualization="True"
                      EnableRowVirtualization="True"
                      ScrollViewer.CanContentScroll="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      HeadersVisibility="Column"
                      IsReadOnly="True"
                      RowHeaderWidth="0"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      Background="Transparent"
                      BorderThickness="0"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="{DynamicResource GridLineBrush}"
                      Foreground="{DynamicResource SecondaryTextBrush}"
                      FontFamily="Segoe UI"
                      FontSize="12"
                      SelectedItem="{Binding SelectedQueueItem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      mvvm:InputCommandBehaviors.SelectedItemChangedCommand="{Binding QueueSelectionChangedCommand}"
                      mvvm:InputCommandBehaviors.MouseDoubleClickInputCommand="{Binding QueueMouseDoubleClickCommand}">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="&#xD30C;&#xC77C;" Width="*" MinWidth="116">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid Margin="4,2" ToolTip="{Binding Detail}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3" />
                                        <ColumnDefinition Width="18" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Width="3"
                                            MinHeight="30"
                                            CornerRadius="2"
                                            Background="{Binding QueueRowAccentBrush}" />
                                    <iconPacks:PackIconMaterial Grid.Column="1"
                                                                Width="14"
                                                                Height="14"
                                                                VerticalAlignment="Center"
                                                                HorizontalAlignment="Center"
                                                                Kind="{Binding QueueIconKind}"
                                                                Foreground="{Binding QueueIconBrush}" />
                                    <StackPanel Grid.Column="2" Margin="5,0,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding FileName}" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                            <Border Grid.Column="1" Style="{StaticResource QueueStatusBadgeStyle}">
                                                <TextBlock Text="{Binding QueueBadgeText}" Foreground="{Binding QueueIconBrush}" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" TextAlignment="Center" />
                                            </Border>
                                        </Grid>
                                        <TextBlock Text="{Binding QueueStatusSummary}" Foreground="{DynamicResource DisabledTextBrush}" FontSize="10" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="&#xB77C;&#xBCA8;" Binding="{Binding LabelStatus}" Width="50" ElementStyle="{StaticResource ImageQueueTextStyle}" />
                    <DataGridTextColumn Header="AI" Binding="{Binding DetectStatus}" Width="58" ElementStyle="{StaticResource ImageQueueTextStyle}" />
                    <DataGridTextColumn Header="&#xD06C;&#xAE30;" Binding="{Binding Dimensions}" Width="58" ElementStyle="{StaticResource ImageQueueTextStyle}" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</UserControl>
