                                <StackPanel>
                                    <TextBlock x:Name="YoloTrainingResultComparisonTitleText"
                                               Text="&#xD559;&#xC2B5; &#xACB0;&#xACFC; &#xBE44;&#xAD50;"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               FontFamily="Segoe UI"
                                               FontSize="10"
                                               FontWeight="SemiBold" />
                                    <TextBlock x:Name="YoloTrainingModelAdoptionDecisionText"
                                               AutomationProperties.AutomationId="YoloTrainingModelAdoptionDecisionText"
                                               Text="{Binding TrainingModelAdoptionDecisionText}"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               FontFamily="Segoe UI"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Margin="0,3,0,0"
                                               TextWrapping="Wrap" />
                                    <TextBlock x:Name="YoloTrainingResultComparisonText"
                                               Text="{Binding TrainingResultComparisonText}"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               FontFamily="Segoe UI"
                                               FontSize="10"
                                               Margin="0,3,0,0"
                                               TextWrapping="Wrap" />
                                    <ItemsControl x:Name="YoloTrainingResultReportItemsControl"
                                                  AutomationProperties.AutomationId="YoloTrainingResultReportItemsControl"
                                                  ItemsSource="{Binding TrainingResultReportItems}"
                                                  Margin="0,5,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="18" />
                                                        <ColumnDefinition Width="42" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <iconPacks:PackIconMaterial Kind="{Binding IconKind}"
                                                                                Width="13"
                                                                                Height="13"
                                                                                Foreground="{DynamicResource SecondaryTextBrush}"
                                                                                Margin="0,2,4,0"
                                                                                VerticalAlignment="Top" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Title}"
                                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                                               FontFamily="Segoe UI"
                                                               FontSize="9"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="{Binding Value}"
                                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                                   FontFamily="Segoe UI"
                                                                   FontSize="9"
                                                                   FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding Detail}"
                                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                                   FontFamily="Segoe UI"
                                                                   FontSize="8"
                                                                   TextWrapping="NoWrap"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock x:Name="YoloModelComparisonBasisText"
                                               AutomationProperties.AutomationId="YoloModelComparisonBasisText"
                                               Text="{Binding ModelComparisonBasisText}"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               FontFamily="Segoe UI"
                                               FontSize="9"
                                               FontWeight="SemiBold"
                                               Margin="0,2,0,0"
                                               TextWrapping="Wrap" />
                                    <WrapPanel Margin="0,3,0,0">
                                        <Button x:Name="YoloRunModelComparisonButton"
                                                AutomationProperties.AutomationId="YoloRunModelComparisonButton"
                                                Style="{StaticResource LearningWorkflowMiniButtonStyle}"
                                                ToolTip="{Binding RunModelComparisonToolTipText}"
                                                IsEnabled="{Binding IsRunModelComparisonEnabled}"
                                                Command="{Binding RunModelComparisonCommand}">
                                            <StackPanel Orientation="Horizontal">
                                                <iconPacks:PackIconMaterial Kind="SwapHorizontal" Width="12" Height="12" Margin="0,0,4,0" />
                                                <TextBlock Text="{Binding RunModelComparisonActionText}" FontFamily="Segoe UI" FontSize="10" FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Button>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                            <ItemsControl x:Name="YoloTrainingRunHistoryItemsControl"
                                          ItemsSource="{Binding TrainingRunHistoryItems}"
                                          Margin="0,4,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource ToolbarButtonBrush}"
                                                BorderBrush="{DynamicResource ToolbarButtonBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="3"
                                                Padding="5,3"
                                                Margin="0,0,0,3">
                                            <TextBlock Text="{Binding}"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       FontFamily="Segoe UI"
                                                       FontSize="10"
                                                       TextTrimming="CharacterEllipsis" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <WrapPanel Margin="0,2,0,0">
                                <Button x:Name="YoloFixClassesButton"
                                        Style="{StaticResource LearningWorkflowMiniButtonStyle}"
                                        ToolTip="&#xD074;&#xB798;&#xC2A4; &#xD0ED;&#xC73C;&#xB85C; &#xC774;&#xB3D9;"
                                        IsEnabled="{Binding IsYoloFixClassesEnabled}"
                                        Command="{Binding YoloFixClassesCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="TagMultipleOutline" Width="12" Height="12" Margin="0,0,4,0" />
                                        <TextBlock Text="&#xD074;&#xB798;&#xC2A4; &#xB4F1;&#xB85D;" FontFamily="Segoe UI" FontSize="10" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Button>
                                <Button x:Name="YoloFixLabelsButton"
                                        Style="{StaticResource LearningWorkflowMiniButtonStyle}"
                                        ToolTip="&#xB77C;&#xBCA8;&#xB9C1; &#xBAA8;&#xB4DC;&#xC640; &#xBC15;&#xC2A4; &#xB3C4;&#xAD6C;&#xB85C; &#xC774;&#xB3D9;"
                                        IsEnabled="{Binding IsYoloFixLabelsEnabled}"
                                        Command="{Binding YoloFixLabelsCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="ShapeSquareRoundedPlus" Width="12" Height="12" Margin="0,0,4,0" />
                                        <TextBlock Text="&#xB77C;&#xBCA8;&#xB9C1; &#xC2DC;&#xC791;" FontFamily="Segoe UI" FontSize="10" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Button>
                                <Button x:Name="YoloFixDatasetButton"
                                        Style="{StaticResource LearningWorkflowMiniButtonStyle}"
                                        ToolTip="YOLO &#xB370;&#xC774;&#xD130;&#xC14B; &#xC810;&#xAC80;&#xC73C;&#xB85C; &#xC774;&#xB3D9;"
                                        IsEnabled="{Binding IsYoloFixDatasetEnabled}"
                                        Command="{Binding YoloFixDatasetCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="CheckAll" Width="12" Height="12" Margin="0,0,4,0" />
                                        <TextBlock Text="&#xB370;&#xC774;&#xD130;&#xC14B; &#xC810;&#xAC80;" FontFamily="Segoe UI" FontSize="10" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Button>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                    <ItemsControl x:Name="YoloTrainingWorkflowItemsControl"
                                  ItemsSource="{Binding YoloTrainingWorkflowSteps}"
                                  ItemTemplate="{StaticResource YoloTrainingWorkflowStepTemplate}"
                                  Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Expander x:Name="LearningConceptsExpander"
                      Header="&#xC2EC;&#xD654; &#xAC1C;&#xB150;"
                      ToolTip="YOLO &#xC21C;&#xC11C;&#xB97C; &#xB530;&#xB77C;&#xD55C; &#xB4A4; &#xD544;&#xC694;&#xD560; &#xB54C;&#xB9CC; &#xC5FD;&#xC5B4; &#xBCF4;&#xC138;&#xC694;."
                      IsExpanded="False"
                      Foreground="{DynamicResource SecondaryTextBrush}"
                      Background="Transparent"
                      BorderBrush="{DynamicResource BorderBrushDark}"
                      Margin="0,0,0,0">
                <StackPanel Margin="0,8,0,0">
                    <TextBlock Text="&#xBAA8;&#xB4DC;"
                               Style="{StaticResource LearningWorkflowCaptionStyle}" />
                    <ListBox x:Name="LearningModeListBox"
                             Style="{StaticResource LearningWorkflowListBoxStyle}"
                             ItemContainerStyle="{StaticResource LearningWorkflowItemStyle}"
                             ItemTemplate="{StaticResource LearningWorkflowItemTemplate}"
                             ItemsSource="{Binding LearningModes}"
                             SelectedItem="{Binding SelectedMode, Mode=TwoWay}"
                             mvvm:InputCommandBehaviors.SelectedItemChangedCommand="{Binding LearningModeSelectionChangedCommand}">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                    </ListBox>


                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Left"
                                Margin="0,2,0,0">
                        <Border Background="#23351F"
                                BorderBrush="#3BCB62"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="8,5"
                                Margin="0,0,6,0">
                            <TextBlock x:Name="GroundTruthChipText"
                                       Text="{Binding GroundTruthChipText}"
                                       Foreground="#D6F9DD"
                                       FontFamily="Segoe UI"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                        </Border>
                        <Border Background="#1D2C3A"
                                BorderBrush="#50B4FF"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="8,5">
                            <TextBlock x:Name="PredictionChipText"
                                       Text="{Binding PredictionChipText}"
                                       Foreground="#D9EEFF"
                                       FontFamily="Segoe UI"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                        </Border>
                    </StackPanel>

                    <Border Background="{DynamicResource CanvasBrush}"
                            BorderBrush="{DynamicResource BorderBrushDark}"
                            BorderThickness="1"
                            CornerRadius="5"
                            Padding="9"
                            Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="{Binding ModeDetailText}"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       FontFamily="Segoe UI"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding StepDetailText}"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       FontFamily="Segoe UI"
                                       FontSize="11"
                                       Margin="0,5,0,0"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding ToolDetailText}"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       FontFamily="Segoe UI"
                                       FontSize="11"
                                       Margin="0,3,0,0"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Grid Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="76" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="42" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#xBE0C;&#xB7EC;&#xC2DC;"
                                   Style="{StaticResource LearningWorkflowCaptionStyle}"
                                   Margin="0,0,0,0" />
                        <Slider Grid.Column="1"
                                Minimum="2"
                                Maximum="64"
                                TickFrequency="2"
                                IsSnapToTickEnabled="True"
                                Value="{Binding BrushSize, Mode=TwoWay}"
                                VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding BrushSize, StringFormat={}{0}px}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center" />

                        <TextBlock Grid.Row="1"
                                   Text="&#xB9C8;&#xC2A4;&#xD06C;"
                                   Style="{StaticResource LearningWorkflowCaptionStyle}"
                                   Margin="0,8,0,0" />
                        <Slider Grid.Row="1"
                                Grid.Column="1"
                                Minimum="0.1"
                                Maximum="1"
                                TickFrequency="0.05"
                                IsSnapToTickEnabled="True"
                                Value="{Binding MaskOpacity, Mode=TwoWay}"
                                Margin="0,8,0,0"
                                VerticalAlignment="Center" />
                        <TextBlock Grid.Row="1"
                                   Grid.Column="2"
                                   Text="{Binding MaskOpacityPercentText}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Margin="0,8,0,0" />
                    </Grid>
                </StackPanel>
            </Expander>
                    </StackPanel>
            </Expander>
                </StackPanel>
            </Expander>
        </StackPanel>
    </ScrollViewer>
</UserControl>
