<UserControl x:Class="MvcVisionSystem.WpfLearningWorkflowPanel"
             x:Name="LearningWorkflowRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mvvm="clr-namespace:OpenVisionLab.Mvvm.Behaviors;assembly=OpenVisionLab.Mvvm"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">
    <UserControl.Resources>
        <Style x:Key="LearningWorkflowCaptionStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>

        <Style x:Key="LearningWorkflowListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="mvvm:InputCommandBehaviors.ForwardMouseWheelToAncestorScrollViewer" Value="True" />
        </Style>

        <Style x:Key="LearningWorkflowItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource ToolbarButtonBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ToolbarButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Margin" Value="0,0,5,5" />
            <Setter Property="MinHeight" Value="29" />
            <Setter Property="IsEnabled" Value="{Binding IsActionEnabled}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource ToolbarButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource ToolbarButtonDisabledBrush}" />
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{DynamicResource ToolbarButtonDisabledBorderBrush}" />
                                <Setter Property="Opacity" Value="0.72" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LearningWorkflowMiniButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource ToolbarButtonBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ToolbarButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="7,4" />
            <Setter Property="Margin" Value="0,5,5,0" />
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource ToolbarButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource ToolbarButtonPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource ToolbarButtonDisabledBrush}" />
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{DynamicResource ToolbarButtonDisabledBorderBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="LearningWorkflowItemTemplate">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" ToolTip="{Binding ToolTip}">
                <iconPacks:PackIconMaterial Kind="{Binding IconKind}"
                                            Width="14"
                                            Height="14"
                                            Margin="0,0,5,0"
                                            VerticalAlignment="Center" />
                <TextBlock Text="{Binding Text}"
                           FontFamily="Segoe UI"
                           FontSize="12"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="LearningStepItemTemplate">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <iconPacks:PackIconMaterial Kind="{Binding IconKind}"
                                            Width="13"
                                            Height="13"
                                            Margin="0,0,4,0"
                                            VerticalAlignment="Center" />
                <TextBlock Text="{Binding Text}"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           FontWeight="SemiBold" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="AnnotationToolItemTemplate">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        ToolTip="{Binding ToolTip}">
                <iconPacks:PackIconMaterial x:Name="ToolIcon"
                                            Kind="{Binding IconKind}"
                                            Width="14"
                                            Height="14"
                                            Margin="0,0,5,0"
                                            VerticalAlignment="Center" />
                <TextBlock x:Name="ToolNameText"
                           Text="{Binding Text}"
                           FontFamily="Segoe UI"
                           FontSize="12"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" />
                <Border x:Name="ToolCapabilityBadge"
                        Background="#1E3A2A"
                        BorderBrush="#2FB36D"
                        BorderThickness="1"
                        CornerRadius="3"
                        Padding="4,1"
                        Margin="5,0,0,0"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="ToolCapabilityText"
                               Text="{Binding DisplayCapabilityText}"
                               Foreground="#D8FBE5"
                               FontFamily="Segoe UI"
                               FontSize="9"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </Border>
            </StackPanel>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsConnected}" Value="False">
                    <Setter TargetName="ToolIcon" Property="Opacity" Value="0.62" />
                    <Setter TargetName="ToolNameText" Property="Opacity" Value="0.72" />
                    <Setter TargetName="ToolCapabilityBadge" Property="Background" Value="#342B16" />
                    <Setter TargetName="ToolCapabilityBadge" Property="BorderBrush" Value="#C69332" />
                    <Setter TargetName="ToolCapabilityText" Property="Foreground" Value="#FFE3A3" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsActionEnabled}" Value="False">
                    <Setter TargetName="ToolIcon" Property="Opacity" Value="0.55" />
                    <Setter TargetName="ToolNameText" Property="Opacity" Value="0.66" />
                    <Setter TargetName="ToolCapabilityBadge" Property="Background" Value="#20242A" />
                    <Setter TargetName="ToolCapabilityBadge" Property="BorderBrush" Value="#394150" />
                    <Setter TargetName="ToolCapabilityText" Property="Foreground" Value="#9FA7B4" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate x:Key="YoloTrainingWorkflowStepTemplate">
            <Border Background="{DynamicResource ToolbarButtonBrush}"
                    BorderBrush="{DynamicResource ToolbarButtonBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="7"
                    Margin="0,0,0,5"
                    Cursor="Hand"
                    mvvm:EventCommandBehavior.EventName="MouseLeftButtonUp"
                    mvvm:EventCommandBehavior.Command="{Binding DataContext.YoloTrainingWorkflowStepCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                    mvvm:EventCommandBehavior.CommandParameter="{Binding}"
                    ToolTip="{Binding ResultText}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="22" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Width="20"
                            Height="20"
                            Background="{DynamicResource AccentBrush}"
                            CornerRadius="10"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top">
                        <TextBlock Text="{Binding Order}"
                                   Foreground="White"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>

                    <iconPacks:PackIconMaterial Grid.Column="1"
                                                Kind="{Binding IconKind}"
                                                Width="15"
                                                Height="15"
                                                Foreground="{DynamicResource PrimaryTextBrush}"
                                                Margin="0,2,0,0"
                                                VerticalAlignment="Top" />

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{Binding Title}"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding ActionText}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   Margin="0,3,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Border Grid.Column="3"
                            CornerRadius="3"
                            Padding="5,3"
                            Margin="6,0,0,0"
                            VerticalAlignment="Top">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                        <Setter Property="Background" Value="#1E3A2A" />
                                        <Setter Property="BorderBrush" Value="#2FB36D" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="{Binding StateIconKind}"
                                                        Width="12"
                                                        Height="12"
                                                        Foreground="{DynamicResource PrimaryTextBrush}"
                                                        Margin="0,0,3,0"
                                                        VerticalAlignment="Center" />
                            <TextBlock Text="{Binding StateText}"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       FontFamily="Segoe UI"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <ScrollViewer x:Name="LearningWorkflowScrollViewer"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="10">
            <Border x:Name="CurrentWorkflowStepPanel"
                    Background="{DynamicResource CanvasBrush}"
                    BorderBrush="{DynamicResource AccentBrush}"
                    BorderThickness="1"
                    CornerRadius="5"
                    Padding="9"
                    Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Background="{DynamicResource AccentBrush}"
                            CornerRadius="4"
                            Padding="7,5"
                            MinWidth="46"
                            Margin="0,0,8,0"
                            VerticalAlignment="Top">
                        <TextBlock x:Name="CurrentStepNameText"
                                   Text="{Binding SelectedStep.Text}"
                                   Foreground="White"
                                   FontFamily="Segoe UI"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="현재 단계"
                                   Style="{StaticResource LearningWorkflowCaptionStyle}"
                                   Margin="0,0,0,2" />
                        <TextBlock x:Name="CurrentStepDetailText"
                                   Text="{Binding StepDetailText}"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="CurrentToolHintText"
                                   Text="{Binding ToolDetailText}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="10"
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>

            <TextBlock x:Name="LearningStepHeaderText"
                       Text="작업 단계"
                       Style="{StaticResource LearningWorkflowCaptionStyle}"
                       Margin="0,0,0,4" />
            <ListBox x:Name="LearningStepListBox"
                     Style="{StaticResource LearningWorkflowListBoxStyle}"
                     ItemContainerStyle="{StaticResource LearningWorkflowItemStyle}"
                     ItemTemplate="{StaticResource LearningStepItemTemplate}"
                     ItemsSource="{Binding LearningSteps}"
                     SelectedItem="{Binding SelectedStep, Mode=TwoWay}"
                     mvvm:InputCommandBehaviors.SelectedItemChangedCommand="{Binding LearningStepSelectionChangedCommand}"
                     Margin="0,0,0,10">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>

            <TextBlock x:Name="AnnotationToolHeaderText"
                       Text="&#xB77C;&#xBCA8;&#xB9C1; &#xB3C4;&#xAD6C;"
                       Style="{StaticResource LearningWorkflowCaptionStyle}"
                       Margin="0,0,0,4" />
            <ListBox x:Name="AnnotationToolListBox"
                     Style="{StaticResource LearningWorkflowListBoxStyle}"
                     ItemContainerStyle="{StaticResource LearningWorkflowItemStyle}"
                     ItemTemplate="{StaticResource AnnotationToolItemTemplate}"
                     ItemsSource="{Binding SelectableAnnotationTools}"
                     SelectedItem="{Binding SelectedTool, Mode=TwoWay}"
                     mvvm:InputCommandBehaviors.SelectedItemChangedCommand="{Binding AnnotationToolSelectionChangedCommand}"
                     Margin="0,0,0,10">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>

            <ItemsControl x:Name="AnnotationCommandToolItemsControl"
                          ItemsSource="{Binding AnnotationCommandTools}"
                          Margin="0,-4,0,10">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Style="{StaticResource LearningWorkflowMiniButtonStyle}"
                                Command="{Binding DataContext.AnnotationToolSelectionChangedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"
                                IsEnabled="{Binding IsActionEnabled}"
                                ToolTip="{Binding ToolTip}"
                                Margin="0,0,5,4">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="{Binding IconKind}"
                                                            Width="12"
                                                            Height="12"
                                                            Margin="0,0,4,0"
                                                            VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Text}"
                                           FontFamily="Segoe UI"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border x:Name="TutorialIntroPanel"
                    Background="{DynamicResource CanvasBrush}"
                    BorderBrush="{DynamicResource AccentBrush}"
                    BorderThickness="1"
                    CornerRadius="5"
                    Padding="9"
                    Margin="0,0,0,10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="SchoolOutline"
                                                    Width="16"
                                                    Height="16"
                                                    Foreground="{DynamicResource PrimaryTextBrush}"
                                                    Margin="0,0,6,0"
                                                    VerticalAlignment="Center" />
                        <TextBlock x:Name="TutorialIntroTitleText"
                                   Text="{Binding TutorialTitleText}"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock x:Name="TutorialIntroSummaryText"
                               Text="{Binding TutorialSummaryText}"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontFamily="Segoe UI"
                               FontSize="11"
                               Margin="0,6,0,0"
                               TextWrapping="Wrap" />
                    <Expander x:Name="TutorialChecklistExpander"
                              Header="&#xC0C1;&#xC138; &#xCCB4;&#xD06C;&#xB9AC;&#xC2A4;&#xD2B8;"
                              IsExpanded="False"
                              Foreground="{DynamicResource SecondaryTextBrush}"
                              Background="Transparent"
                              BorderBrush="{DynamicResource BorderBrushDark}"
                              Margin="0,7,0,0">
                    <ItemsControl x:Name="TutorialChecklistItemsControl"
                                  ItemsSource="{Binding TutorialChecklistItems}"
                                  Margin="0,6,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="17" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <iconPacks:PackIconMaterial Kind="CheckCircleOutline"
                                                                Width="12"
                                                                Height="12"
                                                                Foreground="{DynamicResource AccentBrush}"
                                                                Margin="0,2,4,0"
                                                                VerticalAlignment="Top" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding}"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               FontFamily="Segoe UI"
                                               FontSize="10"
                                               TextWrapping="Wrap" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    </Expander>
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="TutorialOpenHtmlGuideButton"
                                Style="{StaticResource LearningWorkflowMiniButtonStyle}"
                                Command="{Binding TutorialOpenHtmlGuideCommand}"
                                ToolTip="HTML &#xD29C;&#xD1A0;&#xB9AC;&#xC5BC;&#xC744; &#xBE0C;&#xB77C;&#xC6B0;&#xC800;&#xB85C; &#xC5FD;&#xB2C8;&#xB2E4;.">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="OpenInNew"
                                                            Width="12"
                                                            Height="12"
                                                            Margin="0,0,4,0"
                                                            VerticalAlignment="Center" />
                                <TextBlock Text="HTML &#xC5F4;&#xAE30;"
                                           FontFamily="Segoe UI"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <TextBlock Grid.Column="1"
                                   x:Name="TutorialHtmlGuidePathText"
                                   Text="{Binding TutorialHtmlPathText}"
                                   ToolTip="{Binding TutorialHtmlPathText}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="10"
                                   Margin="7,5,0,0"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border x:Name="YoloTrainingWorkflowPanel"
                    Background="{DynamicResource CanvasBrush}"
                    BorderBrush="{DynamicResource BorderBrushDark}"
                    BorderThickness="1"
                    CornerRadius="5"
                    Padding="9"
                    Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="YOLOv5 &#xD559;&#xC2B5; &#xC21C;&#xC11C;"
                               Style="{StaticResource LearningWorkflowCaptionStyle}" />
                    <TextBlock x:Name="YoloTrainingWorkflowSummaryText"
                               Text="{Binding TrainingWorkflowSummaryText}"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               FontFamily="Segoe UI"
                               FontSize="11"
                               TextWrapping="Wrap" />
                    <Border Background="{DynamicResource PanelBrush}"
                            BorderBrush="{DynamicResource BorderBrushDark}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="7"
                            Margin="0,7,0,0">
                        <StackPanel>
                            <TextBlock x:Name="YoloTrainingChecklistStatusText"
                                       Text="{Binding TrainingChecklistStatusText}"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       FontFamily="Segoe UI"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                            <TextBlock x:Name="YoloTrainingChecklistDetailText"
                                       Text="{Binding TrainingChecklistDetailText}"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       FontFamily="Segoe UI"
                                       FontSize="10"
                                       Margin="0,3,0,0"
                                       TextWrapping="Wrap" />
                            <TextBlock x:Name="YoloTrainingChecklistActionText"
                                       Text="{Binding TrainingChecklistActionText}"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       FontFamily="Segoe UI"
                                       FontSize="10"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap" />
                            <TextBlock x:Name="YoloTrainingHistoryText"
                                       Text="{Binding TrainingHistoryText}"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       FontFamily="Segoe UI"
                                       FontSize="10"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap" />
                            <ItemsControl x:Name="YoloTrainingRunHistoryItemsControl"
                                          ItemsSource="{Binding TrainingRunHistoryItems}"
                                          Margin="0,4,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource ToolbarButtonBrush}"
                                                BorderBrush="{DynamicResource ToolbarButtonBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="3"
                                                Padding="5,3"
                                                Margin="0,0,0,3">
                                            <TextBlock Text="{Binding}"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       FontFamily="Segoe UI"
                                                       FontSize="10"
                                                       TextTrimming="CharacterEllipsis" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <WrapPanel Margin="0,2,0,0">
                                <Button x:Name="YoloFixClassesButton"
                                        Style="{StaticResource LearningWorkflowMiniButtonStyle}"
                                        ToolTip="&#xD074;&#xB798;&#xC2A4; &#xD0ED;&#xC73C;&#xB85C; &#xC774;&#xB3D9;"
                                        IsEnabled="{Binding IsYoloFixClassesEnabled}"
                                        Command="{Binding YoloFixClassesCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="TagMultipleOutline" Width="12" Height="12" Margin="0,0,4,0" />
                                        <TextBlock Text="&#xD074;&#xB798;&#xC2A4; &#xB4F1;&#xB85D;" FontFamily="Segoe UI" FontSize="10" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Button>
                                <Button x:Name="YoloFixLabelsButton"
                                        Style="{StaticResource LearningWorkflowMiniButtonStyle}"
                                        ToolTip="&#xB77C;&#xBCA8;&#xB9C1; &#xBAA8;&#xB4DC;&#xC640; &#xBC15;&#xC2A4; &#xB3C4;&#xAD6C;&#xB85C; &#xC774;&#xB3D9;"
                                        IsEnabled="{Binding IsYoloFixLabelsEnabled}"
                                        Command="{Binding YoloFixLabelsCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="ShapeSquareRoundedPlus" Width="12" Height="12" Margin="0,0,4,0" />
                                        <TextBlock Text="&#xB77C;&#xBCA8;&#xB9C1; &#xC2DC;&#xC791;" FontFamily="Segoe UI" FontSize="10" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Button>
                                <Button x:Name="YoloFixDatasetButton"
                                        Style="{StaticResource LearningWorkflowMiniButtonStyle}"
                                        ToolTip="YOLO &#xB370;&#xC774;&#xD130;&#xC14B; &#xC810;&#xAC80;&#xC73C;&#xB85C; &#xC774;&#xB3D9;"
                                        IsEnabled="{Binding IsYoloFixDatasetEnabled}"
                                        Command="{Binding YoloFixDatasetCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="CheckAll" Width="12" Height="12" Margin="0,0,4,0" />
                                        <TextBlock Text="&#xB370;&#xC774;&#xD130;&#xC14B; &#xC810;&#xAC80;" FontFamily="Segoe UI" FontSize="10" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Button>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                    <ItemsControl x:Name="YoloTrainingWorkflowItemsControl"
                                  ItemsSource="{Binding YoloTrainingWorkflowSteps}"
                                  ItemTemplate="{StaticResource YoloTrainingWorkflowStepTemplate}"
                                  Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Expander x:Name="LearningConceptsExpander"
                      Header="&#xC2EC;&#xD654; &#xAC1C;&#xB150;"
                      ToolTip="YOLO &#xC21C;&#xC11C;&#xB97C; &#xB530;&#xB77C;&#xD55C; &#xB4A4; &#xD544;&#xC694;&#xD560; &#xB54C;&#xB9CC; &#xC5FD;&#xC5B4; &#xBCF4;&#xC138;&#xC694;."
                      IsExpanded="False"
                      Foreground="{DynamicResource SecondaryTextBrush}"
                      Background="Transparent"
                      BorderBrush="{DynamicResource BorderBrushDark}"
                      Margin="0,0,0,0">
                <StackPanel Margin="0,8,0,0">
                    <TextBlock Text="&#xBAA8;&#xB4DC;"
                               Style="{StaticResource LearningWorkflowCaptionStyle}" />
                    <ListBox x:Name="LearningModeListBox"
                             Style="{StaticResource LearningWorkflowListBoxStyle}"
                             ItemContainerStyle="{StaticResource LearningWorkflowItemStyle}"
                             ItemTemplate="{StaticResource LearningWorkflowItemTemplate}"
                             ItemsSource="{Binding LearningModes}"
                             SelectedItem="{Binding SelectedMode, Mode=TwoWay}"
                             mvvm:InputCommandBehaviors.SelectedItemChangedCommand="{Binding LearningModeSelectionChangedCommand}">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                    </ListBox>


                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Left"
                                Margin="0,2,0,0">
                        <Border Background="#23351F"
                                BorderBrush="#3BCB62"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="8,5"
                                Margin="0,0,6,0">
                            <TextBlock x:Name="GroundTruthChipText"
                                       Text="{Binding GroundTruthChipText}"
                                       Foreground="#D6F9DD"
                                       FontFamily="Segoe UI"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                        </Border>
                        <Border Background="#1D2C3A"
                                BorderBrush="#50B4FF"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="8,5">
                            <TextBlock x:Name="PredictionChipText"
                                       Text="{Binding PredictionChipText}"
                                       Foreground="#D9EEFF"
                                       FontFamily="Segoe UI"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                        </Border>
                    </StackPanel>

                    <Border Background="{DynamicResource CanvasBrush}"
                            BorderBrush="{DynamicResource BorderBrushDark}"
                            BorderThickness="1"
                            CornerRadius="5"
                            Padding="9"
                            Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="{Binding ModeDetailText}"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       FontFamily="Segoe UI"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding StepDetailText}"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       FontFamily="Segoe UI"
                                       FontSize="11"
                                       Margin="0,5,0,0"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding ToolDetailText}"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       FontFamily="Segoe UI"
                                       FontSize="11"
                                       Margin="0,3,0,0"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Grid Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="76" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="42" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#xBE0C;&#xB7EC;&#xC2DC;"
                                   Style="{StaticResource LearningWorkflowCaptionStyle}"
                                   Margin="0,0,0,0" />
                        <Slider Grid.Column="1"
                                Minimum="2"
                                Maximum="64"
                                TickFrequency="2"
                                IsSnapToTickEnabled="True"
                                Value="{Binding BrushSize, Mode=TwoWay}"
                                VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding BrushSize, StringFormat={}{0}px}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center" />

                        <TextBlock Grid.Row="1"
                                   Text="&#xB9C8;&#xC2A4;&#xD06C;"
                                   Style="{StaticResource LearningWorkflowCaptionStyle}"
                                   Margin="0,8,0,0" />
                        <Slider Grid.Row="1"
                                Grid.Column="1"
                                Minimum="0.1"
                                Maximum="1"
                                TickFrequency="0.05"
                                IsSnapToTickEnabled="True"
                                Value="{Binding MaskOpacity, Mode=TwoWay}"
                                Margin="0,8,0,0"
                                VerticalAlignment="Center" />
                        <TextBlock Grid.Row="1"
                                   Grid.Column="2"
                                   Text="{Binding MaskOpacityPercentText}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Margin="0,8,0,0" />
                    </Grid>
                </StackPanel>
            </Expander>
        </StackPanel>
    </ScrollViewer>
</UserControl>
