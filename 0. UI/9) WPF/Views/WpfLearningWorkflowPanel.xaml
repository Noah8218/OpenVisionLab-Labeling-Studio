<UserControl x:Class="MvcVisionSystem.WpfLearningWorkflowPanel"
             x:Name="LearningWorkflowRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mvvm="clr-namespace:OpenVisionLab.Mvvm.Behaviors;assembly=OpenVisionLab.Mvvm"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">
    <UserControl.Resources>
        <Style x:Key="LearningWorkflowCaptionStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>

        <Style x:Key="LearningWorkflowListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="mvvm:InputCommandBehaviors.ForwardMouseWheelToAncestorScrollViewer" Value="True" />
        </Style>

        <Style x:Key="LearningWorkflowItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource ToolbarButtonBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ToolbarButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Margin" Value="0,0,5,5" />
            <Setter Property="MinHeight" Value="29" />
            <Setter Property="IsEnabled" Value="{Binding IsActionEnabled}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource ToolbarButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource ToolbarButtonDisabledBrush}" />
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{DynamicResource ToolbarButtonDisabledBorderBrush}" />
                                <Setter Property="Opacity" Value="0.72" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LearningWorkflowMiniButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource ToolbarButtonBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ToolbarButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="7,4" />
            <Setter Property="Margin" Value="0,5,5,0" />
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource ToolbarButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource ToolbarButtonPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource ToolbarButtonDisabledBrush}" />
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{DynamicResource ToolbarButtonDisabledBorderBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FirstRunSamplePathShortcutButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="5" />
            <Setter Property="Width" Value="142" />
            <Setter Property="MinHeight" Value="50" />
            <Setter Property="Margin" Value="0,0,5,5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#172554" />
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="#3B82F6" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#1E3A8A" />
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="#60A5FA" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource ToolbarButtonDisabledBrush}" />
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{DynamicResource ToolbarButtonDisabledBorderBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LearningWorkflowMetricButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource ToolbarButtonBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ToolbarButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="3" />
            <Setter Property="Width" Value="42" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Margin" Value="0,0,3,3" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource ToolbarButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource ToolbarButtonPressedBrush}" />
                            </Trigger>
                            <DataTrigger Binding="{Binding IsWarning}" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#33280F" />
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="#C4922B" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsProblem}" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#3A1717" />
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="#E53935" />
                            </DataTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource ToolbarButtonDisabledBrush}" />
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{DynamicResource ToolbarButtonDisabledBorderBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="LearningWorkflowItemTemplate">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" ToolTip="{Binding ToolTip}">
                <iconPacks:PackIconMaterial Kind="{Binding IconKind}"
                                            Width="14"
                                            Height="14"
                                            Margin="0,0,5,0"
                                            VerticalAlignment="Center" />
                <TextBlock Text="{Binding Text}"
                           FontFamily="Segoe UI"
                           FontSize="12"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="LearningStepItemTemplate">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <iconPacks:PackIconMaterial Kind="{Binding IconKind}"
                                            Width="13"
                                            Height="13"
                                            Margin="0,0,4,0"
                                            VerticalAlignment="Center" />
                <TextBlock Text="{Binding Text}"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           FontWeight="SemiBold" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="FirstRunChecklistItemTemplate">
            <Border Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource BorderBrushDark}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="5"
                    Width="92"
                    MinHeight="57"
                    Margin="0,0,5,5"
                    ToolTip="{Binding ToolTip}"
                    AutomationProperties.AutomationId="{Binding Order, StringFormat=FirstRunChecklistItem{0}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="17"
                            Height="17"
                            Background="{DynamicResource AccentBrush}"
                            CornerRadius="8"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top">
                        <TextBlock Text="{Binding StepText}"
                                   Foreground="White"
                                   FontFamily="Segoe UI"
                                   FontSize="9"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="{Binding IconKind}"
                                                        Width="11"
                                                        Height="11"
                                                        Foreground="{DynamicResource SecondaryTextBrush}"
                                                        Margin="0,1,3,0"
                                                        VerticalAlignment="Top" />
                            <TextBlock Text="{Binding Title}"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       FontFamily="Segoe UI"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <TextBlock Text="{Binding ActionText}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="9"
                                   LineHeight="11"
                                   MaxHeight="24"
                                   TextWrapping="Wrap"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="FirstRunSamplePathItemTemplate">
            <Button x:Name="FirstRunSamplePathShortcutButton"
                    Style="{StaticResource FirstRunSamplePathShortcutButtonStyle}"
                    Command="{Binding DataContext.FirstRunSamplePathCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    CommandParameter="{Binding .}"
                    ToolTip="{Binding ToolTip}"
                    AutomationProperties.AutomationId="{Binding Order, StringFormat=FirstRunSamplePathShortcut{0}}"
                    AutomationProperties.Name="{Binding ShortcutAutomationName}"
                    AutomationProperties.HelpText="{Binding ToolTip}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="22" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="18"
                            Height="18"
                            Background="{DynamicResource AccentBrush}"
                            CornerRadius="9"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top">
                        <TextBlock Text="{Binding StepText}"
                                   Foreground="White"
                                   FontFamily="Segoe UI"
                                   FontSize="9"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1">
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,2">
                            <iconPacks:PackIconMaterial Kind="{Binding IconKind}"
                                                        Width="13"
                                                        Height="13"
                                                        Foreground="{DynamicResource SecondaryTextBrush}"
                                                        Margin="0,1,4,0"
                                                        VerticalAlignment="Top" />
                            <TextBlock Text="{Binding Title}"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       FontFamily="Segoe UI"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Grid.Row="1"
                               Grid.Column="1"
                               Text="{Binding ActionText}"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontFamily="Segoe UI"
                               FontSize="8"
                               LineHeight="9"
                               MaxHeight="10"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis" />
                    <Border Grid.Row="2"
                            Grid.Column="1"
                            Background="#172554"
                            BorderBrush="#3B82F6"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="3,0"
                            HorizontalAlignment="Left"
                            Margin="0,2,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="FirstRunSamplePathShortcutText"
                                       AutomationProperties.AutomationId="{Binding Order, StringFormat=FirstRunSamplePathShortcutText{0}}"
                                       Text="{Binding ShortcutActionText}"
                                       Foreground="#DBEAFE"
                                       FontFamily="Segoe UI"
                                       FontSize="8"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <iconPacks:PackIconMaterial Kind="ArrowRight"
                                                        Width="9"
                                                        Height="9"
                                                        Foreground="#DBEAFE"
                                                        Margin="3,1,0,0"
                                                        VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Button>
        </DataTemplate>

        <DataTemplate x:Key="AnnotationToolItemTemplate">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        mvvm:EventCommandBehavior.EventName="MouseLeftButtonUp"
                        mvvm:EventCommandBehavior.Command="{Binding DataContext.AnnotationToolSelectionChangedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        mvvm:EventCommandBehavior.CommandParameter="{Binding}"
                        ToolTip="{Binding ToolTip}">
                <iconPacks:PackIconMaterial x:Name="ToolIcon"
                                            Kind="{Binding IconKind}"
                                            Width="14"
                                            Height="14"
                                            Margin="0,0,5,0"
                                            VerticalAlignment="Center" />
                <TextBlock x:Name="ToolNameText"
                           Text="{Binding Text}"
                           FontFamily="Segoe UI"
                           FontSize="12"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" />
                <Border x:Name="ToolCapabilityBadge"
                        Background="#1E3A2A"
                        BorderBrush="#2FB36D"
                        BorderThickness="1"
                        CornerRadius="3"
                        Padding="4,1"
                        Margin="5,0,0,0"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="ToolCapabilityText"
                               Text="{Binding DisplayCapabilityText}"
                               Foreground="#D8FBE5"
                               FontFamily="Segoe UI"
                               FontSize="9"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </Border>
            </StackPanel>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsConnected}" Value="False">
                    <Setter TargetName="ToolIcon" Property="Opacity" Value="0.62" />
                    <Setter TargetName="ToolNameText" Property="Opacity" Value="0.72" />
                    <Setter TargetName="ToolCapabilityBadge" Property="Background" Value="#342B16" />
                    <Setter TargetName="ToolCapabilityBadge" Property="BorderBrush" Value="#C69332" />
                    <Setter TargetName="ToolCapabilityText" Property="Foreground" Value="#FFE3A3" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsActionEnabled}" Value="False">
                    <Setter TargetName="ToolIcon" Property="Opacity" Value="0.55" />
                    <Setter TargetName="ToolNameText" Property="Opacity" Value="0.66" />
                    <Setter TargetName="ToolCapabilityBadge" Property="Background" Value="#20242A" />
                    <Setter TargetName="ToolCapabilityBadge" Property="BorderBrush" Value="#394150" />
                    <Setter TargetName="ToolCapabilityText" Property="Foreground" Value="#9FA7B4" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate x:Key="TemplateWorkflowStepTemplate">
            <Border Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource BorderBrushDark}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="6"
                    Margin="0,0,0,5"
                    ToolTip="{Binding Detail}"
                    AutomationProperties.AutomationId="{Binding Order, StringFormat=TemplateWorkflowStep{0}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="22" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="18"
                            Height="18"
                            Background="{DynamicResource AccentBrush}"
                            CornerRadius="9"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top">
                        <TextBlock Text="{Binding StepText}"
                                   Foreground="White"
                                   FontFamily="Segoe UI"
                                   FontSize="9"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <iconPacks:PackIconMaterial Kind="{Binding IconKind}"
                                                        Width="12"
                                                        Height="12"
                                                        Foreground="{DynamicResource SecondaryTextBrush}"
                                                        Margin="0,2,4,0"
                                                        VerticalAlignment="Top" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Title}"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       FontFamily="Segoe UI"
                                       FontSize="10.5"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                            <Border Grid.Column="2"
                                    Background="#172554"
                                    BorderBrush="#3B82F6"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    Padding="4,1"
                                    Margin="5,0,0,0"
                                    VerticalAlignment="Top">
                                <TextBlock Text="{Binding LocationText}"
                                           Foreground="#DBEAFE"
                                           FontFamily="Segoe UI"
                                           FontSize="8"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding Detail}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="9.5"
                                   LineHeight="12"
                                   TextWrapping="Wrap"
                                   Margin="0,3,0,0" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="YoloTrainingWorkflowStepTemplate">
            <Border Background="{DynamicResource ToolbarButtonBrush}"
                    BorderBrush="{DynamicResource ToolbarButtonBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="7"
                    Margin="0,0,0,5"
                    Cursor="Hand"
                    mvvm:EventCommandBehavior.EventName="MouseLeftButtonUp"
                    mvvm:EventCommandBehavior.Command="{Binding DataContext.YoloTrainingWorkflowStepCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                    mvvm:EventCommandBehavior.CommandParameter="{Binding}"
                    ToolTip="{Binding ResultText}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="22" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Width="20"
                            Height="20"
                            Background="{DynamicResource AccentBrush}"
                            CornerRadius="10"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top">
                        <TextBlock Text="{Binding Order}"
                                   Foreground="White"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>

                    <iconPacks:PackIconMaterial Grid.Column="1"
                                                Kind="{Binding IconKind}"
                                                Width="15"
                                                Height="15"
                                                Foreground="{DynamicResource PrimaryTextBrush}"
                                                Margin="0,2,0,0"
                                                VerticalAlignment="Top" />

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{Binding Title}"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding ActionText}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   Margin="0,3,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Border Grid.Column="3"
                            CornerRadius="3"
                            Padding="5,3"
                            Margin="6,0,0,0"
                            VerticalAlignment="Top">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                        <Setter Property="Background" Value="#1E3A2A" />
                                        <Setter Property="BorderBrush" Value="#2FB36D" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="{Binding StateIconKind}"
                                                        Width="12"
                                                        Height="12"
                                                        Foreground="{DynamicResource PrimaryTextBrush}"
                                                        Margin="0,0,3,0"
                                                        VerticalAlignment="Center" />
                            <TextBlock Text="{Binding StateText}"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       FontFamily="Segoe UI"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="YoloTrainingProgressChipTemplate">
            <Border x:Name="YoloTrainingProgressChip"
                    AutomationProperties.AutomationId="{Binding Order, StringFormat=YoloTrainingProgressChip{0}}"
                    AutomationProperties.Name="{Binding Title}"
                    AutomationProperties.HelpText="{Binding ResultText}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="4,3"
                    Width="86"
                    MinHeight="28"
                    Margin="0,0,5,4"
                    Cursor="Hand"
                    mvvm:EventCommandBehavior.EventName="MouseLeftButtonUp"
                    mvvm:EventCommandBehavior.Command="{Binding DataContext.YoloTrainingWorkflowStepCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                    mvvm:EventCommandBehavior.CommandParameter="{Binding}"
                    ToolTip="{Binding ResultText}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                        <Border Width="17"
                                Height="17"
                                Background="{DynamicResource AccentBrush}"
                                CornerRadius="8"
                                Margin="0,0,4,0">
                            <TextBlock Text="{Binding Order}"
                                       Foreground="White"
                                       FontFamily="Segoe UI"
                                       FontSize="9"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="{Binding Title}"
                                   Grid.Column="1"
                                   AutomationProperties.AutomationId="{Binding Order, StringFormat=YoloTrainingProgressChipTitle{0}}"
                                   AutomationProperties.Name="{Binding Title}"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="8.5"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />
                    <StackPanel Grid.Column="2"
