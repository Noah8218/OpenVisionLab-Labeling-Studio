                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <StackPanel.Style>
                                                    <Style TargetType="{x:Type StackPanel}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasSelectedGroundTruthPreviewPredictionBox}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <Border Width="12" Height="3" Background="#32B8FF" CornerRadius="1" VerticalAlignment="Center" Margin="0,0,5,0" />
                                                <TextBlock Text="&#xC608;&#xCE21;"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           FontFamily="Segoe UI"
                                                           FontSize="9.5" />
                                            </StackPanel>
                                        </StackPanel>
                                        <TextBlock Grid.Row="3"
                                                   Text="{Binding GroundTruthPreviewDetailText}"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   FontFamily="Segoe UI"
                                                   FontSize="9.5"
                                                   TextWrapping="Wrap" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </TabItem>

                    <TabItem Header="&#xC2E4;&#xD589; &#xC870;&#xAC74;" Style="{StaticResource BenchmarkTabItemStyle}">
                        <DataGrid x:Name="ModelBenchmarkConditionGrid"
                                  ItemsSource="{Binding SelectedRuns}"
                                  AlternationCount="2"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="&#xBAA8;&#xB378;" Binding="{Binding DisplayName}" Width="1.2*" MinWidth="160" />
                                <DataGridTextColumn Header="&#xC791;&#xC5C5;" Binding="{Binding TaskText}" Width="90" />
                                <DataGridTemplateColumn Header="&#xD3C9;&#xAC00; &#xB370;&#xC774;&#xD130;" Width="2*" MinWidth="220">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel ToolTip="{Binding EvidenceFingerprintSha256}">
                                                <TextBlock Text="{Binding EvaluationDataPath}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding EvidenceFingerprintSummaryText}"
                                                           Foreground="{DynamicResource DisabledTextBrush}"
                                                           FontSize="9"
                                                           Margin="0,2,0,0" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="&#xBD84;&#xD560;" Binding="{Binding Run.Split}" Width="65" />
                                <DataGridTextColumn Header="&#xC774;&#xBBF8;&#xC9C0;" Binding="{Binding Run.EvidenceCount}" Width="65" />
                                <DataGridTextColumn Header="img" Binding="{Binding ImageSizeText}" Width="55" />
                                <DataGridTextColumn Header="batch" Binding="{Binding BatchSizeText}" Width="55" />
                                <DataGridTextColumn Header="&#xC2E0;&#xB8B0;&#xB3C4;" Binding="{Binding ConfidenceText}" Width="65" />
                                <DataGridTextColumn Header="Takt &#xC870;&#xAC74;" Binding="{Binding TimingProtocolText}" Width="1.2*" MinWidth="160" />
                                <DataGridTemplateColumn Header="&#xAC00;&#xC911;&#xCE58;" Width="2*" MinWidth="220">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel ToolTip="{Binding WeightsSha256}">
                                                <TextBlock Text="{Binding WeightsPath}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding WeightsSha256SummaryText}"
                                                           Foreground="{DynamicResource DisabledTextBrush}"
                                                           FontSize="9"
                                                           Margin="0,2,0,0" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="&#xBCF4;&#xACE0;&#xC11C;" Binding="{Binding SourcePath}" Width="2*" MinWidth="220" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                    <TabItem Header="&#xC784;&#xACC4;&#xAC12;" Style="{StaticResource BenchmarkTabItemStyle}">
                        <Grid Margin="10" Background="{DynamicResource PanelBrush}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock x:Name="ModelBenchmarkThresholdReviewStatusText"
                                       Text="{Binding ThresholdReviewStatusText}"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       FontFamily="Segoe UI"
                                       FontSize="10.5"
                                       TextWrapping="Wrap"
                                       Margin="2,0,2,10" />
                            <DataGrid x:Name="ModelBenchmarkThresholdReviewGrid"
                                      Grid.Row="1"
                                      ItemsSource="{Binding ThresholdReviewRows}"
                                      AlternationCount="2"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="&#xBAA8;&#xB378;" Binding="{Binding ModelName}" Width="1.5*" MinWidth="180" />
                                    <DataGridTextColumn Header="&#xC784;&#xACC4;&#xAC12;" Binding="{Binding ConfidenceText}" Width="80" />
                                    <DataGridTextColumn Header="&#xC815;&#xB2F5;" Binding="{Binding GroundTruthCountText}" Width="70" />
                                    <DataGridTextColumn Header="&#xC608;&#xCE21;" Binding="{Binding PredictionCountText}" Width="70" />
                                    <DataGridTextColumn Header="TP" Binding="{Binding TruePositiveCountText}" Width="60" />
                                    <DataGridTextColumn Header="FP" Binding="{Binding FalsePositiveCountText}" Width="60" />
                                    <DataGridTextColumn Header="FN" Binding="{Binding FalseNegativeCountText}" Width="60" />
                                    <DataGridTextColumn Header="Precision" Binding="{Binding PrecisionText}" Width="85" />
                                    <DataGridTextColumn Header="Recall" Binding="{Binding RecallText}" Width="85" />
                                    <DataGridTextColumn Header="F1" Binding="{Binding F1Text}" Width="75" />
                                    <DataGridTextColumn Header="&#xADFC;&#xAC70;" Binding="{Binding EvidenceText}" Width="1.2*" MinWidth="160" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>
    </DockPanel>
</ui:FluentWindow>
