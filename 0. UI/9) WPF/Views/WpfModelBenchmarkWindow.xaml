<ui:FluentWindow x:Class="MvcVisionSystem.WpfModelBenchmarkWindow"
                 x:Name="BenchmarkWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="&#xBAA8;&#xB378; &#xC131;&#xB2A5; &#xBE44;&#xAD50;"
                 Width="1600"
                 Height="900"
                 MinWidth="1050"
                 MinHeight="650"
                 Background="{DynamicResource AppBackgroundBrush}"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="None"
                 WindowCornerPreference="Round"
                 WindowStartupLocation="CenterOwner">
    <ui:FluentWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <SolidColorBrush x:Key="AppBackgroundBrush" Color="#0C0D0F" />
            <SolidColorBrush x:Key="FrameBrush" Color="#0A0B0D" />
            <SolidColorBrush x:Key="PanelBrush" Color="#171717" />
            <SolidColorBrush x:Key="PanelHeaderBrush" Color="#1F1F1F" />
            <SolidColorBrush x:Key="CanvasBrush" Color="#101820" />
            <SolidColorBrush x:Key="BorderBrushDark" Color="#303030" />
            <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F7F7F7" />
            <SolidColorBrush x:Key="SecondaryTextBrush" Color="#B7B7B7" />
            <SolidColorBrush x:Key="AccentBrush" Color="#E53935" />
            <SolidColorBrush x:Key="ToolbarButtonBrush" Color="#252525" />
            <SolidColorBrush x:Key="ToolbarButtonBorderBrush" Color="#3A3A3A" />
            <SolidColorBrush x:Key="ToolbarButtonHoverBrush" Color="#333333" />
            <SolidColorBrush x:Key="DisabledTextBrush" Color="#69707A" />
            <SolidColorBrush x:Key="InputBrush" Color="#242424" />
            <SolidColorBrush x:Key="InputBorderBrush" Color="#3A3A3A" />
            <SolidColorBrush x:Key="GridLineBrush" Color="#2A2A2A" />
            <SolidColorBrush x:Key="GridHeaderBrush" Color="#202020" />
            <SolidColorBrush x:Key="RowHoverBrush" Color="#222A33" />
            <SolidColorBrush x:Key="SelectedRowBrush" Color="#26384F" />
            <SolidColorBrush x:Key="SelectedRowTextBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="BaselineBrush" Color="#22C55E" />
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

            <Style x:Key="BenchmarkActionButtonStyle" TargetType="{x:Type ui:Button}">
                <Setter Property="Height" Value="32" />
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="Padding" Value="10,4" />
                <Setter Property="Background" Value="{DynamicResource ToolbarButtonBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ToolbarButtonBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="FontFamily" Value="Segoe UI" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <Style x:Key="BenchmarkIconButtonStyle"
                   TargetType="{x:Type ui:Button}"
                   BasedOn="{StaticResource BenchmarkActionButtonStyle}">
                <Setter Property="Width" Value="30" />
                <Setter Property="Height" Value="28" />
                <Setter Property="Padding" Value="0" />
            </Style>

            <Style x:Key="BenchmarkListItemStyle" TargetType="{x:Type ListBoxItem}">
                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="0,0,0,7" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="BorderBrush" Value="{DynamicResource ToolbarButtonHoverBrush}" />
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{DynamicResource SelectedRowBrush}" />
                        <Setter Property="Foreground" Value="{DynamicResource SelectedRowTextBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="BenchmarkTabItemStyle" TargetType="{x:Type TabItem}">
                <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
                <Setter Property="Background" Value="{DynamicResource ToolbarButtonBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ToolbarButtonBorderBrush}" />
                <Setter Property="Padding" Value="16,7" />
                <Setter Property="Margin" Value="0,0,3,0" />
                <Setter Property="FontFamily" Value="Segoe UI" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Foreground" Value="{DynamicResource AppBackgroundBrush}" />
                        <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="{x:Type DataGrid}">
                <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
                <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource GridLineBrush}" />
                <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource GridLineBrush}" />
                <Setter Property="RowBackground" Value="{DynamicResource PanelBrush}" />
                <Setter Property="AlternatingRowBackground" Value="{DynamicResource CanvasBrush}" />
                <Setter Property="HeadersVisibility" Value="Column" />
                <Setter Property="AutoGenerateColumns" Value="False" />
                <Setter Property="CanUserAddRows" Value="False" />
                <Setter Property="CanUserDeleteRows" Value="False" />
                <Setter Property="CanUserReorderColumns" Value="False" />
                <Setter Property="CanUserResizeRows" Value="False" />
                <Setter Property="IsReadOnly" Value="True" />
                <Setter Property="SelectionMode" Value="Single" />
                <Setter Property="SelectionUnit" Value="FullRow" />
                <Setter Property="RowHeaderWidth" Value="0" />
                <Setter Property="GridLinesVisibility" Value="Horizontal" />
            </Style>

            <Style TargetType="{x:Type DataGridColumnHeader}">
                <Setter Property="Background" Value="{DynamicResource GridHeaderBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource GridLineBrush}" />
                <Setter Property="BorderThickness" Value="0,0,1,1" />
                <Setter Property="Padding" Value="8,7" />
                <Setter Property="FontFamily" Value="Segoe UI" />
                <Setter Property="FontSize" Value="10" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <Style TargetType="{x:Type DataGridCell}">
                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="8,5" />
                <Setter Property="FontFamily" Value="Segoe UI" />
                <Setter Property="FontSize" Value="10.5" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{DynamicResource SelectedRowBrush}" />
                        <Setter Property="Foreground" Value="{DynamicResource SelectedRowTextBrush}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="{x:Type DataGridRow}">
                <Setter Property="MinHeight" Value="44" />
                <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource RowHoverBrush}" />
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{DynamicResource SelectedRowBrush}" />
                        <Setter Property="Foreground" Value="{DynamicResource SelectedRowTextBrush}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="BenchmarkWrappedCellTextStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>
        </ResourceDictionary>
    </ui:FluentWindow.Resources>

    <DockPanel LastChildFill="True">
        <ui:TitleBar x:Name="ModelBenchmarkTitleBar"
                     DockPanel.Dock="Top"
                     Height="30"
                     Title="&#xBAA8;&#xB378; &#xC131;&#xB2A5; &#xBE44;&#xAD50;"
                     Background="{DynamicResource FrameBrush}"
                     Foreground="{DynamicResource PrimaryTextBrush}"
                     ButtonsForeground="{DynamicResource PrimaryTextBrush}"
                     ButtonsBackground="{DynamicResource ToolbarButtonHoverBrush}" />

        <Border DockPanel.Dock="Top"
                Height="64"
                Background="{DynamicResource FrameBrush}"
                BorderBrush="{DynamicResource AccentBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <iconPacks:PackIconMaterial Kind="ChartBoxOutline"
                                                Width="22"
                                                Height="22"
                                                Foreground="{DynamicResource AccentBrush}"
                                                Margin="0,0,10,0" />
                    <StackPanel>
                        <TextBlock Text="&#xBAA8;&#xB378; &#xC131;&#xB2A5; &#xBE44;&#xAD50;"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="15"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="10.5"
                                   Margin="0,3,0,0"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </StackPanel>
                <ui:Button x:Name="RefreshModelBenchmarkButton"
                           Grid.Column="1"
                           Style="{StaticResource BenchmarkActionButtonStyle}"
                           Command="{Binding RefreshCommand}"
                           ToolTip="&#xC2E4;&#xD589; &#xBCF4;&#xACE0;&#xC11C; &#xC0C8;&#xB85C;&#xACE0;&#xCE68;">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Refresh"
                                                    Width="15"
                                                    Height="15"
                                                    Margin="0,0,6,0" />
                        <TextBlock Text="&#xC0C8;&#xB85C;&#xACE0;&#xCE68;" VerticalAlignment="Center" />
                    </StackPanel>
                </ui:Button>
            </Grid>
        </Border>

        <Grid Margin="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330" MinWidth="280" MaxWidth="480" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" MinWidth="650" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource BorderBrushDark}"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,9">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="116" />
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0">
                            <TextBox x:Name="ModelBenchmarkSearchBox"
                                     Height="32"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Background="{DynamicResource InputBrush}"
                                     Foreground="{DynamicResource PrimaryTextBrush}"
                                     BorderBrush="{DynamicResource InputBorderBrush}"
                                     BorderThickness="1"
                                     Padding="28,5,9,5"
                                     FontFamily="Segoe UI"
                                     FontSize="11"
                                     ToolTip="&#xBAA8;&#xB378;, &#xB7F0;&#xD0C0;&#xC784;, &#xBCF4;&#xACE0;&#xC11C; &#xAC80;&#xC0C9;" />
                            <iconPacks:PackIconMaterial Kind="Magnify"
                                                        Width="14"
                                                        Height="14"
                                                        Foreground="{DynamicResource SecondaryTextBrush}"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center"
                                                        Margin="9,0,0,0"
                                                        IsHitTestVisible="False" />
                        </Grid>
                        <ComboBox x:Name="ModelBenchmarkTaskFilterBox"
                                  Grid.Column="1"
                                  Height="32"
                                  Margin="7,0,0,0"
                                  ItemsSource="{Binding TaskFilters}"
                                  SelectedItem="{Binding SelectedTaskFilter, Mode=TwoWay}"
                                  Background="{DynamicResource InputBrush}"
                                  Foreground="{DynamicResource PrimaryTextBrush}"
                                  BorderBrush="{DynamicResource InputBorderBrush}"
                                  FontFamily="Segoe UI"
                                  FontSize="10.5"
                                  ToolTip="&#xC791;&#xC5C5; &#xC885;&#xB958; &#xD544;&#xD130;" />
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#xC2E4;&#xD589; &#xCE74;&#xD0C8;&#xB85C;&#xADF8;"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="&#xC120;&#xD0DD; &#xCD5C;&#xB300; 6"
                                   Foreground="{DynamicResource DisabledTextBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="9.5"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Row="1"
                                   Grid.ColumnSpan="2"
                                   Text="{Binding CatalogTaskSummaryText}"
                                   Foreground="{DynamicResource DisabledTextBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="9"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding CatalogTaskSummaryText}"
                                   Margin="0,4,0,0" />
                    </Grid>

                    <Grid Grid.Row="2">
                        <ListBox x:Name="ModelBenchmarkCatalogList"
                                 ItemsSource="{Binding FilteredRuns}"
                                 ItemContainerStyle="{StaticResource BenchmarkListItemStyle}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="9,8" ToolTip="{Binding Run.SourcePath}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="32" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  VerticalAlignment="Top"
                                                  Margin="0,2,0,0"
                                                  ToolTip="&#xBE44;&#xAD50; &#xC120;&#xD0DD;" />
                                        <StackPanel Grid.Column="1" Margin="2,0,7,0">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Background="{DynamicResource CanvasBrush}"
                                                        BorderBrush="{DynamicResource BorderBrushDark}"
                                                        BorderThickness="1"
                                                        CornerRadius="3"
                                                        Padding="5,1"
                                                        Margin="0,0,6,0">
                                                    <TextBlock Text="{Binding TaskText}"
                                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                                               FontFamily="Segoe UI"
                                                               FontSize="8.5"
                                                               FontWeight="SemiBold" />
                                                </Border>
                                                <Border Background="#172E20"
                                                        BorderBrush="{DynamicResource BaselineBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="3"
                                                        Padding="5,1"
                                                        Visibility="{Binding IsBaseline, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="&#xAE30;&#xC900;"
                                                               Foreground="{DynamicResource BaselineBrush}"
                                                               FontFamily="Segoe UI"
                                                               FontSize="8.5"
                                                               FontWeight="SemiBold" />
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       FontFamily="Segoe UI"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,5,0,0" />
                                            <TextBlock Text="{Binding RuntimeName}"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       FontFamily="Segoe UI"
                                                       FontSize="9.5"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,3,0,0" />
                                            <TextBlock Foreground="{DynamicResource DisabledTextBrush}"
                                                       FontFamily="Segoe UI"
                                                       FontSize="9"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,2,0,0">
                                                <Run Text="{Binding DateText, Mode=OneWay}" />
                                                <Run Text="  &#xB7;  " />
                                                <Run Text="{Binding EvidenceText, Mode=OneWay}" />
                                                <Run Text="  &#xB7;  " />
                                                <Run Text="{Binding SourceTypeText, Mode=OneWay}" />
                                            </TextBlock>
                                        </StackPanel>
                                        <ui:Button Grid.Column="2"
                                                   Style="{StaticResource BenchmarkIconButtonStyle}"
                                                   Command="{Binding DataContext.SetBaselineCommand, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                                   CommandParameter="{Binding}"
                                                   ToolTip="&#xAE30;&#xC900; &#xC2E4;&#xD589;&#xC73C;&#xB85C; &#xC124;&#xC815;">
                                            <iconPacks:PackIconMaterial Kind="PinOutline" Width="14" Height="14" />
                                        </ui:Button>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock Text="&#xC800;&#xC7A5;&#xB41C; &#xC131;&#xB2A5; &#xBCF4;&#xACE0;&#xC11C;&#xAC00; &#xC5C6;&#xC2B5;&#xB2C8;&#xB2E4;."
                                   Foreground="{DynamicResource DisabledTextBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="24"
                                   Visibility="{Binding IsCatalogEmpty, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </Grid>

                    <ui:Button x:Name="ClearModelBenchmarkSelectionButton"
                               Grid.Row="3"
                               Style="{StaticResource BenchmarkActionButtonStyle}"
                               HorizontalAlignment="Left"
                               Margin="0,9,0,0"
                               Command="{Binding ClearSelectionCommand}"
                               ToolTip="&#xBE44;&#xAD50; &#xC120;&#xD0DD; &#xD574;&#xC81C;">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="SelectionRemove" Width="14" Height="14" Margin="0,0,6,0" />
                            <TextBlock Text="&#xC120;&#xD0DD; &#xD574;&#xC81C;" VerticalAlignment="Center" />
                        </StackPanel>
                    </ui:Button>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="Transparent"
                          ShowsPreview="True"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext" />

            <Grid Grid.Column="2" Margin="10,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border x:Name="ModelBenchmarkComparisonNotice"
                        Grid.Row="0"
                        Background="{DynamicResource CanvasBrush}"
                        BorderBrush="{DynamicResource BorderBrushDark}"
                        BorderThickness="1"
                        CornerRadius="5"
                        Padding="11,8"
                        Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <iconPacks:PackIconMaterial Kind="InformationOutline"
                                                    Width="17"
                                                    Height="17"
                                                    Foreground="{DynamicResource AccentBrush}"
                                                    Margin="0,0,8,0"
                                                    VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding ComparisonNoticeText}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="10.5"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <TabControl x:Name="ModelBenchmarkTabs"
                            Grid.Row="1"
                            Background="Transparent"
                            BorderBrush="{DynamicResource BorderBrushDark}">
                    <TabItem Header="&#xC694;&#xC57D;" Style="{StaticResource BenchmarkTabItemStyle}">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="250" MinHeight="220" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" MinHeight="120" />
                            </Grid.RowDefinitions>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="1.15*" />
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="1.3*" />
                                </Grid.ColumnDefinitions>

                                <Border Background="{DynamicResource PanelBrush}"
                                        BorderBrush="{DynamicResource BorderBrushDark}"
                                        BorderThickness="1"
                                        CornerRadius="5"
                                        Padding="10"
                                        Margin="0,0,7,0">
                                    <StackPanel>
                                        <TextBlock Text="&#xD3C9;&#xAC00; &#xADFC;&#xAC70;"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   FontFamily="Segoe UI"
                                                   FontSize="9.5"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding DashboardEvidenceText}"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                   FontFamily="Segoe UI"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding DashboardEvidenceText}"
                                                   Margin="0,5,0,0" />
                                        <TextBlock Text="{Binding DashboardEvidenceDetailText}"
                                                   Foreground="{DynamicResource DisabledTextBrush}"
                                                   FontFamily="Segoe UI"
                                                   FontSize="8.8"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding DashboardEvidenceDetailText}"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1"
                                        Background="{DynamicResource PanelBrush}"
                                        BorderBrush="{DynamicResource BorderBrushDark}"
                                        BorderThickness="1"
                                        CornerRadius="5"
                                        Padding="10"
                                        Margin="0,0,7,0">
                                    <StackPanel>
                                        <TextBlock Text="&#xB300;&#xD45C; &#xC9C0;&#xD45C;"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   FontFamily="Segoe UI"
                                                   FontSize="9.5"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding DashboardQualityText}"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                   FontFamily="Segoe UI"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding DashboardQualityText}"
                                                   Margin="0,5,0,0" />
                                        <TextBlock Text="{Binding DashboardQualityDetailText}"
                                                   Foreground="{DynamicResource DisabledTextBrush}"
                                                   FontFamily="Segoe UI"
                                                   FontSize="8.8"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding DashboardQualityDetailText}"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2"
                                        Background="{DynamicResource PanelBrush}"
                                        BorderBrush="{DynamicResource BorderBrushDark}"
                                        BorderThickness="1"
                                        CornerRadius="5"
                                        Padding="10"
                                        Margin="0,0,7,0">
                                    <StackPanel>
                                        <TextBlock Text="Takt"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   FontFamily="Segoe UI"
                                                   FontSize="9.5"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding DashboardTaktText}"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                   FontFamily="Segoe UI"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding DashboardTaktText}"
                                                   Margin="0,5,0,0" />
                                        <TextBlock Text="{Binding DashboardTaktDetailText}"
                                                   Foreground="{DynamicResource DisabledTextBrush}"
                                                   FontFamily="Segoe UI"
                                                   FontSize="8.8"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding DashboardTaktDetailText}"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="3"
                                        Background="{DynamicResource PanelBrush}"
                                        BorderBrush="{DynamicResource BorderBrushDark}"
                                        BorderThickness="1"
                                        CornerRadius="5"
                                        Padding="10">
                                    <StackPanel>
                                        <TextBlock Text="&#xBCF4;&#xACE0;&#xC11C; &#xD310;&#xC815;"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   FontFamily="Segoe UI"
                                                   FontSize="9.5"
                                                   FontWeight="SemiBold" />
