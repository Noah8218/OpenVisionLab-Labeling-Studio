<UserControl x:Class="MvcVisionSystem.WpfObjectReviewPanel"
             x:Name="ObjectReviewRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MvcVisionSystem"
                          xmlns:mvvm="clr-namespace:OpenVisionLab.Mvvm.Behaviors;assembly=OpenVisionLab.Mvvm"
xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <UserControl.Resources>
        <Style x:Key="ObjectReviewButtonStyle" TargetType="{x:Type ui:Button}">
            <Setter Property="Background" Value="{DynamicResource ToolbarButtonBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ToolbarButtonBorderBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="MinHeight" Value="26" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
                    <Setter Property="Opacity" Value="0.45" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ObjectReviewQualityButtonStyle"
               TargetType="{x:Type ui:Button}"
               BasedOn="{StaticResource ObjectReviewButtonStyle}">
            <Setter Property="Height" Value="25" />
            <Setter Property="Padding" Value="5,0" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="FontSize" Value="10.5" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SelectedRowBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ObjectReviewComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="24" />
            <Setter Property="Background" Value="{DynamicResource InputBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,3,0,0" />
            <Setter Property="MaxDropDownHeight" Value="220" />
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="{DynamicResource InputBrush}" />
                        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                        <Setter Property="Padding" Value="6,3" />
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid MinWidth="{TemplateBinding ActualWidth}">
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          ClickMode="Press"
                                          HorizontalAlignment="Stretch"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="2">
                                            <ContentPresenter />
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <Grid>
                                    <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                      Margin="6,2,24,2"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left" />
                                    <Path Data="M 0 0 L 4 4 L 8 0 Z"
                                          Width="8"
                                          Height="4"
                                          Stretch="Fill"
                                          Fill="{TemplateBinding Foreground}"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          Margin="0,0,8,0" />
                                </Grid>
                            </ToggleButton>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False">
                                <Border MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="{DynamicResource InputBrush}"
                                        BorderBrush="{DynamicResource InputBorderBrush}"
                                        BorderThickness="1">
                                    <ScrollViewer CanContentScroll="True">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#202833" />
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#202833" />
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#334052" />
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#F4F7FB" />
            </Style.Resources>
        </Style>

        <Style x:Key="ObjectReviewListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource RowHoverBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SelectedRowBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource SelectedRowTextBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ObjectReviewLabelSaveBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="#1A2736" />
            <Setter Property="BorderBrush" Value="#46515F" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding LabelSaveStateKey}" Value="Dirty">
                    <Setter Property="Background" Value="#3D2517" />
                    <Setter Property="BorderBrush" Value="#F5A623" />
                </DataTrigger>
                <DataTrigger Binding="{Binding LabelSaveStateKey}" Value="Saved">
                    <Setter Property="Background" Value="#173B29" />
                    <Setter Property="BorderBrush" Value="#57C785" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border x:Name="ObjectReviewModePanel"
                AutomationProperties.AutomationId="ObjectReviewModePanel"
                Background="{DynamicResource CanvasBrush}"
                BorderBrush="{DynamicResource BorderBrushDark}"
                BorderThickness="1"
                CornerRadius="5"
                Padding="8,6"
                Margin="0,0,0,8">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="ObjectReviewModeTitleText"
                               AutomationProperties.AutomationId="ObjectReviewModeTitleText"
                               Text="{Binding PanelModeTitleText}"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               FontFamily="Segoe UI"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                    <Border x:Name="ObjectReviewModeBadge"
                            Grid.Column="1"
                            AutomationProperties.AutomationId="ObjectReviewModeBadge"
                            Background="#173B29"
                            BorderBrush="#57C785"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="6,2"
                            Margin="6,0,0,0"
                            VerticalAlignment="Center">
                        <TextBlock x:Name="ObjectReviewModeBadgeText"
                                   AutomationProperties.AutomationId="ObjectReviewModeBadgeText"
                                   Text="{Binding PanelModeBadgeText}"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                    </Border>
                </Grid>
                <TextBlock x:Name="ObjectReviewModeScopeText"
                           AutomationProperties.AutomationId="ObjectReviewModeScopeText"
                           Text="{Binding PanelModeScopeText}"
                           Foreground="#57C785"
                           FontFamily="Segoe UI"
                           FontSize="10"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           Margin="0,3,0,0" />
                <TextBlock x:Name="ObjectReviewModeDetailText"
                           AutomationProperties.AutomationId="ObjectReviewModeDetailText"
                           Text="{Binding PanelModeDetailText}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontFamily="Segoe UI"
                           FontSize="10"
                           TextWrapping="Wrap"
                           Visibility="Collapsed"
                           Margin="0,2,0,0" />
                <TextBlock x:Name="ObjectReviewActionGuideText"
                           AutomationProperties.AutomationId="ObjectReviewActionGuideText"
                           Text="{Binding ActionGuideText}"
                           Foreground="{DynamicResource DisabledTextBrush}"
                           FontFamily="Segoe UI"
                           FontSize="10"
                           TextWrapping="Wrap"
                           Visibility="Collapsed"
                           Margin="0,3,0,0" />
            </StackPanel>
        </Border>
        <Border x:Name="ObjectReviewCurrentTaskPanel"
                AutomationProperties.AutomationId="ObjectReviewCurrentTaskPanel"
                Grid.Row="1"
                Background="{DynamicResource CanvasBrush}"
                BorderBrush="{DynamicResource BorderBrushDark}"
                BorderThickness="1"
                CornerRadius="5"
                Padding="8,6"
                Margin="0,0,0,8">
            <StackPanel>
                <TextBlock x:Name="ObjectReviewSummaryText"
                           AutomationProperties.AutomationId="ObjectReviewSummaryText"
                           Text="{Binding SummaryText}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontFamily="Segoe UI"
                           FontSize="10.5"
                           TextTrimming="CharacterEllipsis" />
                <Grid Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border x:Name="ObjectReviewLabelSaveBadge"
                            AutomationProperties.AutomationId="ObjectReviewLabelSaveBadge"
                            Style="{StaticResource ObjectReviewLabelSaveBadgeStyle}">
                        <TextBlock x:Name="ObjectReviewLabelSaveBadgeText"
                                   AutomationProperties.AutomationId="ObjectReviewLabelSaveBadgeText"
                                   Text="{Binding LabelSaveBadgeText}"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                    </Border>
                    <TextBlock x:Name="ObjectReviewLabelSaveDetailText"
                               Grid.Column="1"
                               AutomationProperties.AutomationId="ObjectReviewLabelSaveDetailText"
                               Text="{Binding LabelSaveDetailText}"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontFamily="Segoe UI"
                               FontSize="10"
                               Margin="6,1,0,0"
                               TextWrapping="Wrap" />
                </Grid>
                <Border Height="1"
                        Background="{DynamicResource BorderBrushDark}"
                        Margin="0,7,0,6" />
                <Grid x:Name="ObjectQualityReviewPanel"
                      AutomationProperties.AutomationId="ObjectQualityReviewPanel">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#xD488;&#xC9C8; &#xAC80;&#xC218;"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="ObjectQualityReviewStatusText"
                                   Grid.Column="1"
                                   AutomationProperties.AutomationId="ObjectQualityReviewStatusText"
                                   Text="{Binding QualityReviewStatusText}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </Grid>
                    <UniformGrid Grid.Row="1" Columns="3" Margin="-2,5,-2,0">
                        <ui:Button x:Name="MarkQualityUnreviewedButton"
                                   AutomationProperties.AutomationId="MarkQualityUnreviewedButton"
                                   AutomationProperties.Name="&#xBBF8;&#xAC80;&#xD1A0;"
                                   Style="{StaticResource ObjectReviewQualityButtonStyle}"
                                   Content="&#xBBF8;&#xAC80;&#xD1A0;"
                                   Tag="{Binding IsQualityUnreviewedActive}"
                                   IsEnabled="{Binding IsQualityReviewEnabled}"
                                   Command="{Binding MarkQualityUnreviewedCommand}" />
                        <ui:Button x:Name="MarkQualityNeedsFixButton"
                                   AutomationProperties.AutomationId="MarkQualityNeedsFixButton"
                                   AutomationProperties.Name="&#xC218;&#xC815; &#xD544;&#xC694;"
                                   Style="{StaticResource ObjectReviewQualityButtonStyle}"
                                   Content="&#xC218;&#xC815; &#xD544;&#xC694;"
                                   Tag="{Binding IsQualityNeedsFixActive}"
                                   IsEnabled="{Binding IsQualityReviewEnabled}"
                                   Command="{Binding MarkQualityNeedsFixCommand}" />
                        <ui:Button x:Name="MarkQualityReviewedButton"
                                   AutomationProperties.AutomationId="MarkQualityReviewedButton"
                                   AutomationProperties.Name="&#xAC80;&#xC218; &#xC644;&#xB8CC;"
                                   Style="{StaticResource ObjectReviewQualityButtonStyle}"
                                   Content="&#xAC80;&#xC218; &#xC644;&#xB8CC;"
                                   Tag="{Binding IsQualityReviewedActive}"
                                   IsEnabled="{Binding IsMarkQualityReviewedEnabled}"
                                   Command="{Binding MarkQualityReviewedCommand}" />
                    </UniformGrid>
                    <Grid Grid.Row="2" Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="54" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#xC218;&#xC815; &#xC0AC;&#xC720;"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="10"
                                   VerticalAlignment="Center" />
                        <TextBox x:Name="QualityReviewNoteTextBox"
                                 Grid.Column="1"
                                 AutomationProperties.AutomationId="QualityReviewNoteTextBox"
                                 AutomationProperties.Name="&#xC218;&#xC815; &#xC0AC;&#xC720;"
                                 Text="{Binding QualityReviewNoteText, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding IsQualityReviewEnabled}"
                                 MaxLength="200"
                                 Height="24"
                                 Padding="5,0"
                                 VerticalContentAlignment="Center"
                                 Background="{DynamicResource InputBrush}"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 BorderBrush="{DynamicResource InputBorderBrush}"
                                 BorderThickness="1"
                                 FontFamily="Segoe UI"
                                 FontSize="10.5"
                                 ToolTip="&#xC0AC;&#xC720;&#xB97C; &#xC785;&#xB825;&#xD558;&#xACE0; &#xC218;&#xC815; &#xD544;&#xC694;&#xB97C; &#xB204;&#xB974;&#xBA74; &#xD568;&#xAED8; &#xC800;&#xC7A5;&#xB429;&#xB2C8;&#xB2E4;." />
                    </Grid>
                    <Grid Grid.Row="3" Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ObjectQualityReviewDetailText"
                                   AutomationProperties.AutomationId="ObjectQualityReviewDetailText"
                                   Text="{Binding QualityReviewDetailText}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontFamily="Segoe UI"
                                   FontSize="9.5"
                                   TextWrapping="Wrap"
                                   MaxHeight="28"
                                   VerticalAlignment="Center" />
                        <ui:Button x:Name="ExportQualityReviewReportButton"
                                   Grid.Column="1"
                                   AutomationProperties.AutomationId="ExportQualityReviewReportButton"
                                   AutomationProperties.Name="QA &#xBCF4;&#xACE0;&#xC11C;"
                                   Style="{StaticResource ObjectReviewButtonStyle}"
                                   Content="QA &#xBCF4;&#xACE0;&#xC11C;"
                                   Command="{Binding ExportQualityReviewReportCommand}"
                                   IsEnabled="{Binding IsQualityReviewEnabled}"
                                   Height="25"
                                   Padding="6,0"
                                   Margin="6,0,0,0"
                                   FontSize="10"
                                   ToolTip="&#xC800;&#xC7A5; &#xD3F4;&#xB354;&#xC5D0; label-quality-review.md&#xB85C; &#xC800;&#xC7A5;&#xD569;&#xB2C8;&#xB2E4;." />
                    </Grid>
                </Grid>
                <TextBlock x:Name="ObjectReviewSelectedTaskTitleText"
                           AutomationProperties.AutomationId="ObjectReviewSelectedTaskTitleText"
                           Text="{Binding SelectedObjectTaskTitleText}"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           FontFamily="Segoe UI"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Margin="0,3,0,0"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="ObjectReviewSelectedTaskDetailText"
                           AutomationProperties.AutomationId="ObjectReviewSelectedTaskDetailText"
                           Text="{Binding SelectedObjectTaskDetailText}"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           Margin="0,2,0,0"
                           TextWrapping="Wrap" />
                <TextBlock x:Name="ObjectReviewSelectedTaskActionText"
                           AutomationProperties.AutomationId="ObjectReviewSelectedTaskActionText"
                           Text="{Binding SelectedObjectTaskActionText}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontFamily="Segoe UI"
                           FontSize="10"
                           Margin="0,3,0,0"
                           Visibility="Collapsed"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>
        <Border x:Name="ObjectReviewEditPanel"
                AutomationProperties.AutomationId="ObjectReviewEditPanel"
                Grid.Row="2"
                Background="{DynamicResource CanvasBrush}"
                BorderBrush="{DynamicResource BorderBrushDark}"
                BorderThickness="1"
                CornerRadius="5"
                Padding="8,6"
                Margin="0,0,0,8">
            <StackPanel>
                <Grid Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="ObjectReviewEditTitleText"
                               AutomationProperties.AutomationId="ObjectReviewEditTitleText"
                               Text="&#xC120;&#xD0DD; &#xB77C;&#xBCA8; &#xC218;&#xC815;"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               FontFamily="Segoe UI"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                    <ui:Button x:Name="DeleteObjectButton"
                               Grid.Column="1"
                               AutomationProperties.AutomationId="DeleteObjectButton"
                               Style="{StaticResource ObjectReviewButtonStyle}"
                               MinWidth="58"
                               Height="24"
                               Padding="8,0"
                               Content="&#xC0AD;&#xC81C;"
                               ToolTip="&#xC120;&#xD0DD;&#xD55C; &#xC800;&#xC7A5; &#xB77C;&#xBCA8; &#xC0AD;&#xC81C;"
                               IsEnabled="{Binding IsDeleteEnabled}"
                               Command="{Binding DeleteObjectCommand}" />
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="ObjectClassBox"
                              AutomationProperties.AutomationId="ObjectClassBox"
                              Style="{StaticResource ObjectReviewComboBoxStyle}"
                              ItemsSource="{Binding ClassNames}"
                              SelectedItem="{Binding SelectedClassName, Mode=TwoWay}"
                              ToolTip="&#xC120;&#xD0DD;&#xD55C; &#xC800;&#xC7A5; &#xB77C;&#xBCA8;&#xC5D0; &#xC801;&#xC6A9;&#xD560; &#xD074;&#xB798;&#xC2A4;" />
                    <ui:Button x:Name="ApplyObjectClassButton"
                               Grid.Column="1"
                               AutomationProperties.AutomationId="ApplyObjectClassButton"
                               Style="{StaticResource ObjectReviewButtonStyle}"
                               MinWidth="58"
                               Height="24"
                               Padding="8,0"
                               Margin="6,0,0,0"
                               Content="&#xC801;&#xC6A9;"
                               ToolTip="&#xC120;&#xD0DD;&#xD55C; &#xC800;&#xC7A5; &#xB77C;&#xBCA8; &#xD074;&#xB798;&#xC2A4; &#xBCC0;&#xACBD;"
                               IsEnabled="{Binding IsApplyClassEnabled}"
                               Command="{Binding ApplyObjectClassCommand}" />
                </Grid>
            </StackPanel>
        </Border>
        <ListBox x:Name="ObjectListBox"
                 AutomationProperties.AutomationId="ObjectListBox"
                 Grid.Row="3"
                 Background="Transparent"
                 BorderThickness="0"
                 Foreground="{DynamicResource SecondaryTextBrush}"
                 ItemsSource="{Binding Objects}"
                 SelectedItem="{Binding SelectedObject, Mode=TwoWay}"
                 ItemContainerStyle="{StaticResource ObjectReviewListBoxItemStyle}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.CanContentScroll="True"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 mvvm:InputCommandBehaviors.SelectedItemChangedCommand="{Binding ObjectSelectionChangedCommand}"
                 mvvm:InputCommandBehaviors.PreviewKeyInputCommand="{Binding ObjectPreviewKeyDownCommand}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding DisplayText}"
                               ToolTip="{Binding ToolTip}"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
