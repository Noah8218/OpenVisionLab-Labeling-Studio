<UserControl x:Class="MvcVisionSystem.WpfProjectConfigPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <UserControl.Resources>
        <Style x:Key="ProjectConfigLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,6,8,0" />
        </Style>

        <Style x:Key="ProjectConfigTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="26" />
            <Setter Property="MinWidth" Value="128" />
            <Setter Property="Background" Value="{DynamicResource InputBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="Margin" Value="0,5,0,0" />
            <Setter Property="IsReadOnly" Value="True" />
        </Style>

        <Style x:Key="ProjectConfigComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="26" />
            <Setter Property="Background" Value="{DynamicResource InputBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,5,5,0" />
            <Setter Property="MaxDropDownHeight" Value="220" />
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="{DynamicResource InputBrush}" />
                        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                        <Setter Property="Padding" Value="6,3" />
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid MinWidth="{TemplateBinding ActualWidth}">
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          ClickMode="Press"
                                          HorizontalAlignment="Stretch"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="2">
                                            <ContentPresenter />
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <Grid>
                                    <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                      Margin="6,2,24,2"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left" />
                                    <Path Data="M 0 0 L 4 4 L 8 0 Z"
                                          Width="8"
                                          Height="4"
                                          Stretch="Fill"
                                          Fill="{TemplateBinding Foreground}"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          Margin="0,0,8,0" />
                                </Grid>
                            </ToggleButton>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False">
                                <Border MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="{DynamicResource InputBrush}"
                                        BorderBrush="{DynamicResource InputBorderBrush}"
                                        BorderThickness="1">
                                    <ScrollViewer CanContentScroll="True">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#202833" />
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#202833" />
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#334052" />
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#F4F7FB" />
            </Style.Resources>
        </Style>

        <Style x:Key="ProjectConfigButtonStyle" TargetType="{x:Type ui:Button}">
            <Setter Property="Height" Value="30" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Margin" Value="0,0,5,5" />
            <Setter Property="Background" Value="{DynamicResource ToolbarButtonBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ToolbarButtonBorderBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
                    <Setter Property="Opacity" Value="0.45" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ProjectConfigIconStyle" TargetType="{x:Type iconPacks:PackIconMaterial}">
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Expander x:Name="ProjectConfigExpander"
              Header="프로젝트"
              IsExpanded="True"
              Foreground="{DynamicResource PrimaryTextBrush}"
              Margin="0,12,0,0">
        <StackPanel Margin="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="74" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="Recipe"
                           Style="{StaticResource ProjectConfigLabelStyle}" />
                <TextBox x:Name="ProjectRecipeNameBox"
                         Grid.Column="1"
                         Style="{StaticResource ProjectConfigTextBoxStyle}"
                         IsReadOnly="False"
                         Text="{Binding RecipeName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="{Binding RecipeName}" />
                <ui:Button x:Name="ApplyProjectRecipeButton"
                           Grid.Column="2"
                           Style="{StaticResource ProjectConfigButtonStyle}"
                           IsEnabled="{Binding IsApplyRecipeEnabled}"
                           MinWidth="56"
                           AutomationProperties.Name="Recipe 적용"
                           ToolTip="입력한 recipe로 전환하거나 새로 생성"
                           Click="ApplyProjectRecipeButton_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <iconPacks:PackIconMaterial Style="{StaticResource ProjectConfigIconStyle}" Kind="Check" />
                        <TextBlock Text="적용" VerticalAlignment="Center" />
                    </StackPanel>
                </ui:Button>

                <TextBlock Grid.Row="1"
                           Text="목록"
                           Style="{StaticResource ProjectConfigLabelStyle}" />
                <ComboBox x:Name="ProjectRecipeListBox"
                          Grid.Row="1"
                          Grid.Column="1"
                          Style="{StaticResource ProjectConfigComboBoxStyle}"
                          ItemsSource="{Binding RecipeNames}"
                          SelectedItem="{Binding SelectedRecipeName, Mode=TwoWay}"
                          SelectionChanged="ProjectRecipeListBox_SelectionChanged"
                          ToolTip="{Binding SelectedRecipeName}" />
                <ui:Button x:Name="RefreshProjectRecipeListButton"
                           Grid.Row="1"
                           Grid.Column="2"
                           Style="{StaticResource ProjectConfigButtonStyle}"
                           IsEnabled="{Binding IsRefreshRecipeListEnabled}"
                           MinWidth="56"
                           AutomationProperties.Name="Recipe 목록 갱신"
                           ToolTip="RECIPE 폴더를 다시 읽습니다"
                           Click="RefreshProjectRecipeListButton_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <iconPacks:PackIconMaterial Style="{StaticResource ProjectConfigIconStyle}" Kind="Refresh" />
                        <TextBlock Text="갱신" VerticalAlignment="Center" />
                    </StackPanel>
                </ui:Button>

                <TextBlock Grid.Row="2"
                           Text="Config"
                           Style="{StaticResource ProjectConfigLabelStyle}" />
                <TextBox x:Name="ProjectConfigPathBox"
                         Grid.Row="2"
                         Grid.Column="1"
                         Grid.ColumnSpan="2"
                         Style="{StaticResource ProjectConfigTextBoxStyle}"
                         Text="{Binding ConfigPath, Mode=OneWay}"
                         ToolTip="{Binding ConfigPath}" />
            </Grid>

            <WrapPanel Margin="0,8,0,0">
                <ui:Button x:Name="SaveProjectConfigButton"
                           Style="{StaticResource ProjectConfigButtonStyle}"
                           IsEnabled="{Binding IsSaveProjectConfigEnabled}"
                           MinWidth="92"
                           AutomationProperties.Name="프로젝트 설정 저장"
                           ToolTip="현재 recipe의 VISION.xml 설정 저장"
                           Click="SaveProjectConfigButton_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <iconPacks:PackIconMaterial Style="{StaticResource ProjectConfigIconStyle}" Kind="ContentSaveOutline" />
                        <TextBlock Text="설정 저장" VerticalAlignment="Center" />
                    </StackPanel>
                </ui:Button>
                <ui:Button x:Name="OpenProjectConfigFolderButton"
                           Style="{StaticResource ProjectConfigButtonStyle}"
                           IsEnabled="{Binding IsOpenProjectConfigFolderEnabled}"
                           MinWidth="82"
                           AutomationProperties.Name="프로젝트 설정 폴더 열기"
                           ToolTip="현재 recipe 설정 폴더 열기"
                           Click="OpenProjectConfigFolderButton_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <iconPacks:PackIconMaterial Style="{StaticResource ProjectConfigIconStyle}" Kind="FolderOpenOutline" />
                        <TextBlock Text="폴더" VerticalAlignment="Center" />
                    </StackPanel>
                </ui:Button>
            </WrapPanel>

            <TextBlock x:Name="ProjectConfigStatusText"
                       Text="{Binding StatusText}"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       FontFamily="Segoe UI"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0" />
        </StackPanel>
    </Expander>
</UserControl>
