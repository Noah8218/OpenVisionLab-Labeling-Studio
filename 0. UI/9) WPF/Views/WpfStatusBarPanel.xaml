<UserControl x:Class="MvcVisionSystem.WpfStatusBarPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Height="36"
            Background="{DynamicResource StatusBarBrush}"
            BorderBrush="{DynamicResource BorderBrushDark}"
            BorderThickness="0,1,0,0">
        <Grid Margin="12,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.25*" />
                <ColumnDefinition Width="0.85*" />
                <ColumnDefinition Width="0.95*" />
                <ColumnDefinition Width="1.25*" />
                <ColumnDefinition Width="0.95*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="DatasetStatusText"
                       AutomationProperties.AutomationId="DatasetStatusText"
                       Text="{Binding DatasetStatusText}"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       FontFamily="Segoe UI"
                       FontSize="11"
                       TextTrimming="CharacterEllipsis"
                       VerticalAlignment="Center" />

            <TextBlock Grid.Column="1"
                       x:Name="WorkflowStageText"
                       AutomationProperties.AutomationId="WorkflowStageText"
                       Text="{Binding WorkflowStageText}"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       FontFamily="Segoe UI"
                       FontSize="11"
                       FontWeight="SemiBold"
                       TextTrimming="CharacterEllipsis"
                       Margin="8,0,0,0"
                       VerticalAlignment="Center" />

            <TextBlock Grid.Column="2"
                       x:Name="WorkflowProgressText"
                       AutomationProperties.AutomationId="WorkflowProgressText"
                       Text="{Binding WorkflowProgressText}"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       FontFamily="Segoe UI"
                       FontSize="11"
                       TextTrimming="CharacterEllipsis"
                       Margin="8,0,0,0"
                       VerticalAlignment="Center" />

            <TextBlock Grid.Column="3"
                       x:Name="WorkflowNextActionText"
                       AutomationProperties.AutomationId="WorkflowNextActionText"
                       Text="{Binding WorkflowNextActionText}"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       FontFamily="Segoe UI"
                       FontSize="11"
                       FontWeight="SemiBold"
                       TextTrimming="CharacterEllipsis"
                       Margin="8,0,0,0"
                       VerticalAlignment="Center" />

            <TextBlock Grid.Column="4"
                       x:Name="PythonStatusText"
                       Text="{Binding PythonStatusText}"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       FontFamily="Segoe UI"
                       FontSize="11"
                       TextTrimming="CharacterEllipsis"
                       Margin="8,0"
                       VerticalAlignment="Center" />

            <Border Grid.Column="5"
                    CornerRadius="3"
                    Padding="7,3"
                    Margin="8,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    ToolTip="{Binding AnnotationSaveStatusToolTip}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#172E22" />
                        <Setter Property="BorderBrush" Value="#2FB36D" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAnnotationDirty}" Value="True">
                                <Setter Property="Background" Value="#3A2C14" />
                                <Setter Property="BorderBrush" Value="#D08A18" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock x:Name="AnnotationSaveStatusText"
                           AutomationProperties.AutomationId="AnnotationSaveStatusText"
                           Text="{Binding AnnotationSaveStatusText}"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           FontFamily="Segoe UI"
                           FontSize="10"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" />
            </Border>

            <TextBlock Grid.Column="6"
                       x:Name="ModelStatusText"
                       AutomationProperties.AutomationId="ModelStatusText"
                       AutomationProperties.HelpText="{Binding ModelStatusAutomationText}"
                       Text="{Binding ModelStatusText}"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       FontFamily="Segoe UI"
                       FontSize="11"
                       TextTrimming="CharacterEllipsis"
                       TextAlignment="Right"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center" />
        </Grid>
    </Border>
</UserControl>
