<UserControl x:Class="MvcVisionSystem.WpfTrainingSettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mvvm="clr-namespace:OpenVisionLab.Mvvm.Behaviors;assembly=OpenVisionLab.Mvvm"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <UserControl.Resources>
        <Style x:Key="TrainingLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Margin" Value="0,8,8,0" />
        </Style>

        <Style x:Key="TrainingHelpTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,3,0,0" />
        </Style>

        <Style x:Key="TrainingTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="26" />
            <Setter Property="Background" Value="{DynamicResource InputBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="6,3" />
        </Style>

        <Style x:Key="TrainingComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="26" />
            <Setter Property="Background" Value="{DynamicResource InputBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="{DynamicResource InputBrush}" />
                        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                        <Setter Property="Padding" Value="6,3" />
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="2">
                                            <ContentPresenter />
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <Grid>
                                    <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                      Margin="6,2,24,2"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left" />
                                    <Path Data="M 0 0 L 4 4 L 8 0 Z"
                                          Width="8"
                                          Height="4"
                                          Stretch="Fill"
                                          Fill="{TemplateBinding Foreground}"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          Margin="0,0,8,0" />
                                </Grid>
                            </ToggleButton>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False">
                                <Border MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="{DynamicResource InputBrush}"
                                        BorderBrush="{DynamicResource InputBorderBrush}"
                                        BorderThickness="1">
                                    <ScrollViewer CanContentScroll="True">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#202833" />
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#202833" />
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#334052" />
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#F4F7FB" />
            </Style.Resources>
        </Style>

        <Style x:Key="TrainingCommandButtonStyle" TargetType="{x:Type ui:Button}">
            <Setter Property="Height" Value="30" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Margin" Value="0,0,5,5" />
            <Setter Property="Background" Value="{DynamicResource ToolbarButtonBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ToolbarButtonBorderBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
                    <Setter Property="Opacity" Value="0.45" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Expander x:Name="TrainingSettingsExpander"
              AutomationProperties.AutomationId="TrainingSettingsExpander"
              Header="&#xD559;&#xC2B5; &#xC694;&#xC57D; / &#xC124;&#xC815;"
              Foreground="{DynamicResource PrimaryTextBrush}"
              Margin="0,12,0,0">
        <StackPanel Margin="0,8,0,0">
            <Border x:Name="TrainingSettingsSummaryPanel"
                    AutomationProperties.AutomationId="TrainingSettingsSummaryPanel"
                    Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource AccentBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="8"
                    Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock x:Name="TrainingSettingsSummaryTitleText"
                               AutomationProperties.AutomationId="TrainingSettingsSummaryTitleText"
                               Text="{Binding TrainingSettingsSummaryTitleText}"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               FontFamily="Segoe UI"
                               FontSize="12"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="TrainingSettingsSummaryModelText"
                               AutomationProperties.AutomationId="TrainingSettingsSummaryModelText"
                               Text="{Binding TrainingSettingsSummaryModelText}"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               FontFamily="Segoe UI"
                               FontSize="10.5"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0" />
                    <TextBlock x:Name="TrainingSettingsSummaryRuntimeText"
                               AutomationProperties.AutomationId="TrainingSettingsSummaryRuntimeText"
                               Text="{Binding TrainingSettingsSummaryRuntimeText}"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontFamily="Segoe UI"
                               FontSize="10"
                               TextWrapping="Wrap"
                               Margin="0,2,0,0" />
                    <TextBlock x:Name="TrainingSettingsSummarySplitText"
                               AutomationProperties.AutomationId="TrainingSettingsSummarySplitText"
                               Text="{Binding TrainingSettingsSummarySplitText}"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontFamily="Segoe UI"
                               FontSize="10"
                               TextWrapping="Wrap"
                               Margin="0,2,0,0" />
                    <TextBlock x:Name="TrainingSettingsSummaryActionText"
                               AutomationProperties.AutomationId="TrainingSettingsSummaryActionText"
                               Text="{Binding TrainingSettingsSummaryActionText}"
                               Foreground="{DynamicResource AccentBrush}"
                               FontFamily="Segoe UI"
                               FontSize="9.5"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <Border Background="#151D26"
                    BorderBrush="{DynamicResource InputBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="8"
                    Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="{Binding TrainingRecommendationTitleText}"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               FontFamily="Segoe UI"
                               FontSize="12"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="TrainingRecommendationText"
                               Text="{Binding TrainingRecommendationText}"
                               Visibility="Collapsed"
                               Style="{StaticResource TrainingHelpTextStyle}" />
                    <ui:Button x:Name="ApplyFastTrainingPresetButton"
                               AutomationProperties.AutomationId="ApplyFastTrainingPresetButton"
                               AutomationProperties.Name="&#xBE60;&#xB978; &#xCD94;&#xCC9C;&#xAC12; &#xC801;&#xC6A9;"
                               Style="{StaticResource TrainingCommandButtonStyle}"
                               IsEnabled="{Binding IsApplyFastRecommendationEnabled}"
                               MinWidth="116"
                               HorizontalAlignment="Left"
                               Margin="0,7,0,0"
                               Content="&#xBE60;&#xB978; &#xCD94;&#xCC9C; &#xC801;&#xC6A9;"
                               ToolTip="{Binding TrainingRecommendationText}"
                               Command="{Binding ApplyFastRecommendationCommand}" />
                </StackPanel>
            </Border>

            <Expander x:Name="TrainingAdvancedSettingsExpander"
                      AutomationProperties.AutomationId="TrainingAdvancedSettingsExpander"
                      Header="{Binding AdvancedTrainingSettingsHeaderText}"
                      Foreground="{DynamicResource PrimaryTextBrush}"
                      Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="82" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="&#xC774;&#xBBF8;&#xC9C0; &#xD06C;&#xAE30;" Style="{StaticResource TrainingLabelStyle}" />
                <StackPanel Grid.Column="1" Margin="0,4,0,5">
                    <TextBox x:Name="TrainingImageSizeBox"
                             Style="{StaticResource TrainingTextBoxStyle}"
                             Text="{Binding ImageSizeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="{Binding ImageSizeGuideText}"
                             mvvm:InputCommandBehaviors.TextInputFilter="Integer" />
                    <TextBlock x:Name="TrainingImageSizeGuideText"
                               Text="{Binding ImageSizeGuideText}"
                               Visibility="Collapsed"
                               Style="{StaticResource TrainingHelpTextStyle}" />
                </StackPanel>

                <TextBlock Grid.Row="1" Text="&#xBC30;&#xCE58;" Style="{StaticResource TrainingLabelStyle}" />
                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,4,0,5">
                    <TextBox x:Name="TrainingBatchBox"
                             Style="{StaticResource TrainingTextBoxStyle}"
                             Text="{Binding BatchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="{Binding BatchGuideText}"
                             mvvm:InputCommandBehaviors.TextInputFilter="Integer" />
                    <TextBlock x:Name="TrainingBatchGuideText"
                               Text="{Binding BatchGuideText}"
                               Visibility="Collapsed"
                               Style="{StaticResource TrainingHelpTextStyle}" />
                </StackPanel>

                <TextBlock Grid.Row="2" Text="&#xC5D0;&#xD3ED;" Style="{StaticResource TrainingLabelStyle}" />
                <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,4,0,5">
                    <TextBox x:Name="TrainingEpochBox"
                             Style="{StaticResource TrainingTextBoxStyle}"
                             Text="{Binding EpochText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="{Binding EpochGuideText}"
                             mvvm:InputCommandBehaviors.TextInputFilter="Integer" />
                    <TextBlock x:Name="TrainingEpochGuideText"
                               Text="{Binding EpochGuideText}"
                               Visibility="Collapsed"
                               Style="{StaticResource TrainingHelpTextStyle}" />
                </StackPanel>

                <TextBlock Grid.Row="3" Text="&#xBAA8;&#xB378; &#xAD6C;&#xC870;" Style="{StaticResource TrainingLabelStyle}" />
                <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,4,0,5">
                    <ComboBox x:Name="TrainingCfgBox"
                              SelectedItem="{Binding Cfg, Mode=TwoWay}"
                              Style="{StaticResource TrainingComboBoxStyle}"
                              ToolTip="{Binding CfgGuideText}" />
                    <TextBlock x:Name="TrainingCfgGuideText"
                               Text="{Binding CfgGuideText}"
                               Visibility="Collapsed"
                               Style="{StaticResource TrainingHelpTextStyle}" />
                </StackPanel>

                <TextBlock Grid.Row="4" Text="&#xD559;&#xC2B5; &#xC2DC;&#xC791; &#xAC00;&#xC911;&#xCE58;" Style="{StaticResource TrainingLabelStyle}" />
                <StackPanel Grid.Row="4" Grid.Column="1" Margin="0,4,0,5">
                    <ComboBox x:Name="TrainingWeightBox"
                              SelectedItem="{Binding Weight, Mode=TwoWay}"
                              Style="{StaticResource TrainingComboBoxStyle}"
                              ToolTip="{Binding WeightGuideText}" />
                    <TextBlock x:Name="TrainingWeightGuideText"
                               Text="{Binding WeightGuideText}"
                               Visibility="Collapsed"
                               Style="{StaticResource TrainingHelpTextStyle}" />
                </StackPanel>

                <TextBlock Grid.Row="5" Text="&#xAC80;&#xC99D; %" Style="{StaticResource TrainingLabelStyle}" />
                <StackPanel Grid.Row="5" Grid.Column="1" Margin="0,4,0,5">
                    <TextBox x:Name="TrainingValidationPercentBox"
                             Style="{StaticResource TrainingTextBoxStyle}"
                             Text="{Binding ValidationPercentText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="{Binding ValidationPercentGuideText}"
                             mvvm:InputCommandBehaviors.TextInputFilter="Integer" />
                    <TextBlock x:Name="TrainingValidationPercentGuideText"
                               Text="{Binding ValidationPercentGuideText}"
                               Visibility="Collapsed"
                               Style="{StaticResource TrainingHelpTextStyle}" />
                </StackPanel>

                <TextBlock Grid.Row="6" Text="&#xBD84;&#xD560; &#xAE30;&#xC900;&#xAC12;" Style="{StaticResource TrainingLabelStyle}" />
                <StackPanel Grid.Row="6" Grid.Column="1" Margin="0,4,0,5">
                    <TextBox x:Name="TrainingSplitSeedBox"
                             Style="{StaticResource TrainingTextBoxStyle}"
                             Text="{Binding SplitSeedText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="{Binding SplitSeedGuideText}"
                             mvvm:InputCommandBehaviors.TextInputFilter="Integer" />
                    <TextBlock x:Name="TrainingSplitSeedGuideText"
                               Text="{Binding SplitSeedGuideText}"
                               Visibility="Collapsed"
                               Style="{StaticResource TrainingHelpTextStyle}" />
                </StackPanel>

                <TextBlock Grid.Row="7" Text="&#xCD5C;&#xC885; &#xAC80;&#xC99D; %" Style="{StaticResource TrainingLabelStyle}" />
                <StackPanel Grid.Row="7" Grid.Column="1" Margin="0,4,0,5">
                    <TextBox x:Name="TrainingTestPercentBox"
                             Style="{StaticResource TrainingTextBoxStyle}"
                             Text="{Binding TestPercentText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="&#xCD5C;&#xC885; &#xAC80;&#xC99D; &#xBE44;&#xC728; (0~10% &#xAD8C;&#xC7A5;)"
                             mvvm:InputCommandBehaviors.TextInputFilter="Integer" />
                    <TextBlock x:Name="TrainingTestPercentGuideText"
                               Text="{Binding TestPercentGuideText}"
                               Visibility="Collapsed"
                               Style="{StaticResource TrainingHelpTextStyle}" />
                </StackPanel>

                <TextBlock x:Name="TrainingSplitPolicyHintText"
                           Grid.Row="8"
                           Grid.ColumnSpan="2"
                           Text="{Binding SplitPolicyHintText}"
                           Style="{StaticResource TrainingHelpTextStyle}"
                           Visibility="Collapsed"
                           Margin="0,8,0,0" />
            </Grid>
            </Expander>

            <WrapPanel Margin="0,8,0,0">
                <ui:Button x:Name="RefreshTrainingReadinessButton"
                           AutomationProperties.AutomationId="RefreshTrainingReadinessButton"
                           AutomationProperties.Name="&#xD559;&#xC2B5; &#xC0C1;&#xD0DC; &#xC0C8;&#xB85C;&#xACE0;&#xCE68;"
                           Style="{StaticResource TrainingCommandButtonStyle}"
                           IsEnabled="{Binding IsRefreshReadinessEnabled}"
                           MinWidth="78"
                           Content="&#xC0C8;&#xB85C;&#xACE0;&#xCE68;"
                           ToolTip="&#xD604;&#xC7AC; &#xB370;&#xC774;&#xD130;&#xC14B;&#xACFC; &#xD559;&#xC2B5; &#xC124;&#xC815;&#xC774; &#xC2DC;&#xC791; &#xAC00;&#xB2A5;&#xD55C;&#xC9C0; &#xB2E4;&#xC2DC; &#xD655;&#xC778;&#xD569;&#xB2C8;&#xB2E4;."
                           Command="{Binding RefreshReadinessCommand}" />
                <ui:Button x:Name="StartTrainingButton"
                           AutomationProperties.AutomationId="StartTrainingButton"
                           AutomationProperties.Name="&#xD559;&#xC2B5; &#xC2DC;&#xC791;"
                           Style="{StaticResource TrainingCommandButtonStyle}"
                           IsEnabled="{Binding IsStartTrainingEnabled}"
                           MinWidth="70"
                           Content="&#xC2DC;&#xC791;"
                           ToolTip="{Binding StartTrainingToolTip}"
                           Command="{Binding StartTrainingCommand}" />
                <ui:Button x:Name="StopTrainingButton"
                           Style="{StaticResource TrainingCommandButtonStyle}"
                           IsEnabled="{Binding IsStopTrainingEnabled}"
                           MinWidth="68"
                           Content="&#xC911;&#xC9C0;"
                           ToolTip="&#xC9C4;&#xD589; &#xC911;&#xC778; &#xD559;&#xC2B5;&#xC744; &#xC911;&#xC9C0;&#xD569;&#xB2C8;&#xB2E4;."
                           Command="{Binding StopTrainingCommand}" />
            </WrapPanel>

            <TextBlock x:Name="TrainingReadinessText"
                       Text="{Binding TrainingReadinessText}"
                       Foreground="{Binding TrainingReadinessForeground}"
                       FontFamily="Segoe UI"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0,8,0,0" />
            <ProgressBar x:Name="TrainingProgressBar"
                         Height="5"
                         Minimum="0"
                         Maximum="100"
                         Value="{Binding TrainingProgressValue, Mode=OneWay}"
                         IsIndeterminate="{Binding TrainingProgressIsIndeterminate, Mode=OneWay}"
                         Foreground="{Binding TrainingProgressForeground, Mode=OneWay}"
                         Margin="0,5,0,0" />
            <Grid Margin="0,5,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TrainingProgressText"
                           Text="{Binding TrainingProgressText}"
                           Foreground="{Binding TrainingProgressForeground}"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           TextWrapping="Wrap" />
                <TextBlock x:Name="TrainingEpochText"
                           Grid.Column="1"
                           Text="{Binding TrainingEpochStatusText}"
                           Foreground="{DynamicResource DisabledTextBrush}"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           Margin="8,0,0,0" />
            </Grid>

            <Border x:Name="PostTrainingModelActionPanel"
                    AutomationProperties.AutomationId="PostTrainingModelActionPanel"
                    Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource ToolbarButtonBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="8"
                    Margin="0,8,0,0">
                <StackPanel>
                    <TextBlock x:Name="PostTrainingModelActionTitleText"
                               AutomationProperties.AutomationId="PostTrainingModelActionTitleText"
                               Text="{Binding PostTrainingModelActionTitleText}"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               FontFamily="Segoe UI"
                               FontSize="12"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="PostTrainingModelStatusText"
                               AutomationProperties.AutomationId="PostTrainingModelStatusText"
                               Text="{Binding PostTrainingModelStatusText}"
                               Foreground="{DynamicResource AccentBrush}"
                               FontFamily="Segoe UI"
                               FontSize="10.5"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0" />
                    <TextBlock x:Name="PostTrainingModelDetailText"
                               AutomationProperties.AutomationId="PostTrainingModelDetailText"
                               Text="{Binding PostTrainingModelDetailText}"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontFamily="Segoe UI"
                               FontSize="10"
                               TextWrapping="Wrap"
                               Margin="0,2,0,0" />
                    <WrapPanel Margin="0,7,0,0">
                        <ui:Button x:Name="ReviewTrainedModelButton"
                                   AutomationProperties.AutomationId="ReviewTrainedModelButton"
                                   AutomationProperties.Name="{Binding ReviewTrainedModelActionText}"
                                   Style="{StaticResource TrainingCommandButtonStyle}"
                                   IsEnabled="{Binding IsReviewTrainedModelEnabled}"
                                   MinWidth="86"
                                   ToolTip="{Binding ReviewTrainedModelToolTip}"
                                   Command="{Binding ReviewTrainedModelCommand}">
                            <TextBlock x:Name="ReviewTrainedModelButtonText"
                                       Text="{Binding ReviewTrainedModelActionText}"
                                       VerticalAlignment="Center" />
                        </ui:Button>
                        <ui:Button x:Name="ConfirmTrainedModelButton"
                                   AutomationProperties.AutomationId="ConfirmTrainedModelButton"
                                   AutomationProperties.Name="{Binding ConfirmTrainedModelActionText}"
                                   Style="{StaticResource TrainingCommandButtonStyle}"
                                   IsEnabled="{Binding IsConfirmTrainedModelEnabled}"
                                   MinWidth="112"
                                   ToolTip="{Binding ConfirmTrainedModelToolTip}"
                                   Command="{Binding ConfirmTrainedModelCommand}">
                            <TextBlock x:Name="ConfirmTrainedModelButtonText"
                                       Text="{Binding ConfirmTrainedModelActionText}"
                                       VerticalAlignment="Center" />
                        </ui:Button>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </Expander>
</UserControl>
