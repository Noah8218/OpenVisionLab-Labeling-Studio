<Window x:Class="OpenVisionLab.ImageCanvas.Views.AddRoiArrayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"             
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"			 
             xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
			 WindowStyle="None"
             Width="450" Height="300" >
	<Window.Resources>
		<BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
		<Geometry x:Key="IconCheck">M21,7L9,19L3.5,13.5L4.91,12.09L9,16.17L19.59,5.59L21,7Z</Geometry>
		<Geometry x:Key="IconCancel">M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M15.5,7L17,8.5L13.5,12L17,15.5L15.5,17L12,13.5L8.5,17L7,15.5L10.5,12L7,8.5L8.5,7L12,10.5L15.5,7Z</Geometry>
		<Style TargetType="Grid">
			<Setter Property="Background" Value="#262626"/>
		</Style>
	</Window.Resources>

	<!-- Height property is not set, so it will be determined by the content -->
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="1*"/>
			<RowDefinition Height="0.7*"/>
			<RowDefinition Height="1*"/>
			<RowDefinition Height="0.7*"/>
			<RowDefinition Height="1*"/>
		</Grid.RowDefinitions>

		<Grid.ColumnDefinitions>
			<ColumnDefinition/>
			<ColumnDefinition/>
		</Grid.ColumnDefinitions>

		<TextBlock Grid.Row="0" Text="Row :" FontSize="25" Margin="5" VerticalAlignment="Center" HorizontalAlignment="Left" Foreground="White" />
		<TextBox Grid.Row="1" x:Name="RowsTextBox" Text="{Binding Rows, UpdateSourceTrigger=PropertyChanged}" Margin="5" VerticalAlignment="Stretch" VerticalContentAlignment="Center" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>

		<TextBlock Grid.Row="0" Grid.Column="1" FontSize="25" Text="Column :" Margin="5" VerticalAlignment="Center" HorizontalAlignment="Left" Foreground="White"/>
		<TextBox Grid.Row="1" Grid.Column="1" x:Name="ColumnsTextBox" Text="{Binding Columns, UpdateSourceTrigger=PropertyChanged}" Margin="5" VerticalAlignment="Stretch" VerticalContentAlignment="Center" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>

		<TextBlock Grid.Row="2" Text="Row Gap(mm):" FontSize="25" Margin="5" VerticalAlignment="Center" HorizontalAlignment="Left" Foreground="White"/>
		<TextBox Grid.Row="3" x:Name="RowSpacingTextBox" Text="{Binding RowSpacing, UpdateSourceTrigger=PropertyChanged}" Margin="5" VerticalAlignment="Stretch" VerticalContentAlignment="Center" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>

		<TextBlock Grid.Row="2" Grid.Column="1" FontSize="25" Text="Column Gap(mm):" Margin="5" VerticalAlignment="Center" HorizontalAlignment="Left" Foreground="White"/>
		<TextBox Grid.Row="3" Grid.Column="1" x:Name="ColumnSpacingTextBox" Text="{Binding ColumnSpacing, UpdateSourceTrigger=PropertyChanged}" Margin="5" VerticalAlignment="Stretch" VerticalContentAlignment="Center" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>

		<Button Grid.Row="4" Height="30" Command="{Binding ApplyCommand}" Margin="5" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
			<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" >
				<Path Data="{StaticResource IconCheck}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="15" Height="15" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" />
				<TextBlock Text="Apply" FontSize="15" Margin="10,0,0,0" VerticalAlignment="Center" />
			</StackPanel>
		</Button>

		<Button Grid.Row="4" Grid.Column="1" Height="30" Command="{Binding CancelCommand}" Margin="5">
			<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
				<Path Data="{StaticResource IconCancel}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="15" Height="15" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" />
				<TextBlock Text="Cancel" FontSize="15" Margin="10,0,0,0" VerticalAlignment="Center" />
			</StackPanel>
		</Button>
	</Grid>
</Window>
