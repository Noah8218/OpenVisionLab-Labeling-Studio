<UserControl x:Class="OpenVisionLab.Wpf.MessageDialogs.WpfMessageDialogControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="420"
             MaxWidth="620">
    <UserControl.Resources>
        <Style x:Key="DialogButtonBaseStyle" TargetType="{x:Type Button}">
            <Setter Property="MinWidth" Value="90" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.76" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryDialogButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource DialogButtonBaseStyle}">
            <Setter Property="Background" Value="#E53935" />
            <Setter Property="BorderBrush" Value="#E53935" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style x:Key="SecondaryDialogButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource DialogButtonBaseStyle}">
            <Setter Property="Background" Value="#2B2D31" />
            <Setter Property="BorderBrush" Value="#4A4F57" />
            <Setter Property="Foreground" Value="#E8EAED" />
        </Style>
    </UserControl.Resources>

    <Border x:Name="ShellBorder"
            Background="#1D1F23"
            BorderBrush="#3A3F46"
            BorderThickness="1"
            CornerRadius="8"
            Padding="22"
            SnapsToDevicePixels="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border x:Name="KindBadge"
                    Width="44"
                    Height="44"
                    CornerRadius="22"
                    Background="#3B82F6"
                    Margin="0,0,16,0"
                    VerticalAlignment="Top">
                <TextBlock x:Name="KindGlyph"
                           Text="i"
                           Foreground="White"
                           FontFamily="Segoe UI"
                           FontSize="20"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>

            <StackPanel Grid.Column="1">
                <Border x:Name="AccentBar"
                        Height="3"
                        Width="52"
                        HorizontalAlignment="Left"
                        Background="#3B82F6"
                        CornerRadius="2"
                        Margin="0,0,0,12" />
                <TextBlock x:Name="TitleText"
                           Text="Message"
                           Foreground="#F4F6F8"
                           FontFamily="Segoe UI"
                           FontSize="18"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
                <TextBlock x:Name="MessageText"
                           Text=""
                           Foreground="#D3D7DE"
                           FontFamily="Segoe UI"
                           FontSize="13"
                           LineHeight="20"
                           TextWrapping="Wrap"
                           Margin="0,10,0,0"
                           MaxHeight="240" />
                <Border x:Name="DetailsContainer"
                        Visibility="Collapsed"
                        Background="#15171A"
                        BorderBrush="#32363D"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10"
                        Margin="0,14,0,0">
                    <StackPanel>
                        <Button x:Name="DetailsToggleButton"
                                Content="Details"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="#8AB4F8"
                                FontFamily="Segoe UI"
                                FontSize="12"
                                HorizontalAlignment="Left"
                                Padding="0"
                                Click="OnDetailsToggleClicked" />
                        <TextBox x:Name="DetailsTextBox"
                                 Visibility="Collapsed"
                                 IsReadOnly="True"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="#C7CBD1"
                                 FontFamily="Consolas"
                                 FontSize="11"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 MaxHeight="180"
                                 Margin="0,8,0,0"
                                 VerticalScrollBarVisibility="Auto" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel x:Name="ButtonPanel"
                        Grid.Row="1"
                        Grid.ColumnSpan="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,24,0,0" />
        </Grid>
    </Border>
</UserControl>
