<Window x:Class="OpenVisionLab.Wpf.MessageDialogs.WpfMessageDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:OpenVisionLab.Wpf.MessageDialogs"
        Title="Message"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        KeyDown="OnWindowKeyDown">
    <Grid Margin="12">
        <Grid.Effect>
            <DropShadowEffect Color="#000000"
                              BlurRadius="24"
                              ShadowDepth="6"
                              Opacity="0.45" />
        </Grid.Effect>
        <local:WpfMessageDialogControl x:Name="DialogControl" />
    </Grid>
</Window>
