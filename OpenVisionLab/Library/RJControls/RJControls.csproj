<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <OutputType>Library</OutputType>
    <RootNamespace>RJControls</RootNamespace>
    <AssemblyName>RJControls</AssemblyName>
    <UseWindowsForms>true</UseWindowsForms>
    <Deterministic>false</Deterministic>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Debug|x86'">
    <PlatformTarget>x86</PlatformTarget>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Release|x86'">
    <PlatformTarget>x86</PlatformTarget>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Debug|x64'">
    <PlatformTarget>x64</PlatformTarget>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Release|x64'">
    <PlatformTarget>x64</PlatformTarget>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="FontAwesome.Sharp">
      <HintPath>..\..\dll\FontAwesome.Sharp.dll</HintPath>
      <Private>True</Private>
    </Reference>
    <PackageReference Include="System.Configuration.ConfigurationManager" Version="10.0.8" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\OpenVisionLab.MessageBox\OpenVisionLab.MessageBox.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="RJChart.cs" />
    <Compile Remove="RJForms\VisionTestForm.cs" />
    <Compile Remove="Settings\UIAppearanceSettings1.Designer.cs" />
    <EmbeddedResource Remove="RJForms\VisionTestForm.resx" />
  </ItemGroup>

  <ItemGroup>
    <Compile Update="RJButton.cs">
      <SubType>Component</SubType>
    </Compile>
    <Compile Update="RJCheckBox.cs">
      <SubType>Component</SubType>
    </Compile>
    <Compile Update="RJCircularPictureBox.cs">
      <SubType>Component</SubType>
    </Compile>
    <Compile Update="RJComboBox.cs">
      <SubType>UserControl</SubType>
    </Compile>
    <Compile Update="RJDataGridView.cs">
      <SubType>Component</SubType>
    </Compile>
    <Compile Update="RJDatePicker.cs">
      <SubType>UserControl</SubType>
    </Compile>
    <Compile Update="RJDragControl.cs">
      <SubType>Component</SubType>
    </Compile>
    <Compile Update="RJDropdownMenu.cs">
      <SubType>Component</SubType>
    </Compile>
    <Compile Update="RJImageColorOverlay.cs">
      <SubType>Component</SubType>
    </Compile>
    <Compile Update="RJLabel.cs">
      <SubType>Component</SubType>
    </Compile>
    <Compile Update="RJMenuButton.cs">
      <SubType>Component</SubType>
    </Compile>
    <Compile Update="RJMenuIcon.cs">
      <SubType>Component</SubType>
    </Compile>
    <Compile Update="RJPanel.cs">
      <SubType>Component</SubType>
    </Compile>
    <Compile Update="RJPictureBox.cs">
      <SubType>Component</SubType>
    </Compile>
    <Compile Update="RJProgressBar.cs">
      <SubType>Component</SubType>
    </Compile>
    <Compile Update="RJRadioButton.cs">
      <SubType>Component</SubType>
    </Compile>
    <Compile Update="RJTextBox.cs">
      <SubType>UserControl</SubType>
    </Compile>
    <Compile Update="RJToggleButton.cs">
      <SubType>Component</SubType>
    </Compile>
    <Compile Update="RJTrackBar.cs">
      <SubType>Component</SubType>
    </Compile>
    <Compile Update="RJForms\RJBaseForm.cs">
      <SubType>Form</SubType>
    </Compile>
    <Compile Update="RJForms\RJChildForm.cs">
      <SubType>Form</SubType>
    </Compile>
    <Compile Update="RJForms\RJMainForm.cs">
      <SubType>Form</SubType>
    </Compile>
    <Compile Update="RJForms\RJPrintForm.cs">
      <SubType>Form</SubType>
    </Compile>
    <Compile Update="RJForms\RJPrintForm.designer.cs">
      <DependentUpon>RJPrintForm.cs</DependentUpon>
    </Compile>
    <Compile Update="RJForms\RJSettingsForm.cs">
      <SubType>Form</SubType>
    </Compile>
    <Compile Update="RJForms\RJSettingsForm.Designer.cs">
      <DependentUpon>RJSettingsForm.cs</DependentUpon>
    </Compile>
    <Compile Update="Settings\UIAppearanceSettings.Designer.cs">
      <AutoGen>True</AutoGen>
      <DesignTimeSharedInput>True</DesignTimeSharedInput>
      <DependentUpon>UIAppearanceSettings.settings</DependentUpon>
    </Compile>
    <EmbeddedResource Update="RJPanel.resx">
      <DependentUpon>RJPanel.cs</DependentUpon>
    </EmbeddedResource>
    <EmbeddedResource Update="RJForms\RJPrintForm.resx">
      <DependentUpon>RJPrintForm.cs</DependentUpon>
    </EmbeddedResource>
    <EmbeddedResource Update="RJForms\RJSettingsForm.resx">
      <DependentUpon>RJSettingsForm.cs</DependentUpon>
    </EmbeddedResource>
    <None Update="Settings\UIAppearanceSettings.settings">
      <Generator>SettingsSingleFileGenerator</Generator>
      <LastGenOutput>UIAppearanceSettings.Designer.cs</LastGenOutput>
    </None>
  </ItemGroup>
</Project>
