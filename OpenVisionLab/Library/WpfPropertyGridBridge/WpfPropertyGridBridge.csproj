<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <OutputType>Library</OutputType>
    <RootNamespace>WpfPropertyGridBridge</RootNamespace>
    <AssemblyName>WpfPropertyGridBridge</AssemblyName>
    <UseWPF>true</UseWPF>
    <Deterministic>false</Deterministic>
    <WpgCustomBuildEnabled Condition="'$(WpgCustomBuildEnabled)' == ''">false</WpgCustomBuildEnabled>
    <WpgCustomSourceRoot Condition="'$(WpgCustomSourceRoot)' == ''">$(MSBuildProjectDirectory)\..\..\..\..\WPG-CUSTOM</WpgCustomSourceRoot>
    <WpgCustomProject>$(WpgCustomSourceRoot)\Main\WpfPropertyGrid\WpfPropertyGrid.csproj</WpgCustomProject>
    <WpgCustomOutputDir>$(WpgCustomSourceRoot)\Main\WpfPropertyGrid\bin\$(Configuration)\</WpgCustomOutputDir>
    <WpgCustomTargetDir>$(MSBuildProjectDirectory)\..\..\dll\</WpgCustomTargetDir>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Debug|x86'">
    <PlatformTarget>x86</PlatformTarget>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Release|x86'">
    <PlatformTarget>x86</PlatformTarget>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Debug|x64'">
    <PlatformTarget>x64</PlatformTarget>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Release|x64'">
    <PlatformTarget>x64</PlatformTarget>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="System.Windows.Controls.WpfPropertyGrid">
      <HintPath>..\..\dll\System.Windows.Controls.WpfPropertyGrid.dll</HintPath>
      <Private>True</Private>
      <Aliases>WpfPropertyGridOriginal</Aliases>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\PropertyGrid.Abstractions\PropertyGrid.Abstractions.csproj" />
    <ProjectReference Include="..\OpenVisionLab.Localization\OpenVisionLab.Localization.csproj" />
  </ItemGroup>

  <Target Name="BuildAndCopyWpgCustomPropertyGrid"
          BeforeTargets="ResolveReferences"
          Condition="'$(WpgCustomBuildEnabled)' == 'true' and '$(DesignTimeBuild)' != 'true' and Exists('$(WpgCustomProject)')">
    <MSBuild Projects="$(WpgCustomProject)"
             Targets="Build"
             Properties="Configuration=$(Configuration);Platform=AnyCPU;RestorePackages=false"
             RemoveProperties="OutDir;OutputPath;TargetFramework;TargetFrameworks;RuntimeIdentifier;RuntimeIdentifiers" />

    <ItemGroup>
      <WpgCustomArtifacts Include="$(WpgCustomOutputDir)System.Windows.Controls.WpfPropertyGrid.dll"
                          Condition="Exists('$(WpgCustomOutputDir)System.Windows.Controls.WpfPropertyGrid.dll')" />
      <WpgCustomArtifacts Include="$(WpgCustomOutputDir)System.Windows.Controls.WpfPropertyGrid.xml"
                          Condition="Exists('$(WpgCustomOutputDir)System.Windows.Controls.WpfPropertyGrid.xml')" />
    </ItemGroup>

    <Copy SourceFiles="@(WpgCustomArtifacts)"
          DestinationFolder="$(WpgCustomTargetDir)"
          SkipUnchangedFiles="true"
          Condition="'@(WpgCustomArtifacts)' != ''" />
  </Target>

  <Target Name="ValidateWpgPropertyGridReference"
          BeforeTargets="ResolveReferences"
          Condition="'$(DesignTimeBuild)' != 'true' and '$(WpgCustomBuildEnabled)' != 'true' and !Exists('$(WpgCustomTargetDir)System.Windows.Controls.WpfPropertyGrid.dll')">
    <Error Text="Missing WPG runtime: $(WpgCustomTargetDir)System.Windows.Controls.WpfPropertyGrid.dll. Copy the WPG-CUSTOM build artifact to dll, or build with /p:WpgCustomBuildEnabled=true on a PC that has the .NET Framework 3.5 targeting pack." />
  </Target>
</Project>
